<section class="lx-prods">
  <div class="lx-container">
    <div class="lx-section-head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    {% assign featured_collection = collections[section.settings.collection] %}
    {% if featured_collection != blank and featured_collection.products.size > 0 %}
    <div class="lx-prods__grid">
      {% for product in featured_collection.products limit: section.settings.limit %}
      <article class="lx-pcard lx-fade-in">
        <a href="{{ product.url }}" class="lx-pcard__img-link" aria-label="{{ product.title }}">
          <div class="lx-pcard__img">
            {% if product.featured_image != blank %}
            <img
              src="{{ product.featured_image | img_url: '600x' }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="600"
              height="450"
            >
            {% else %}
            <svg class="lx-pcard__img-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            {% endif %}
            {% if product.compare_at_price > product.price %}
            <span class="lx-pcard__sale" aria-label="Sale">SALE</span>
            {% endif %}
            {% if product.tags contains 'best-seller' or product.tags contains 'Best Seller' %}
            <span class="lx-pcard__bestseller" aria-label="Best Seller">Best Seller</span>
            {% endif %}
          </div>
        </a>
        <div class="lx-pcard__body">
          {% if product.type != blank %}
          <div class="lx-pcard__cat">{{ product.type }}</div>
          {% endif %}
          <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
          {% if product.description != blank %}
          <p class="lx-pcard__desc">{{ product.description | strip_html | truncate: 100 }}</p>
          {% endif %}
          <div class="lx-pcard__price-row">
            <span class="lx-pcard__price">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
            <span class="lx-pcard__compare">{{ product.compare_at_price | money }}</span>
            {% assign saving = product.compare_at_price | minus: product.price %}
            <span class="lx-pcard__save">Save {{ saving | money }}</span>
            {% endif %}
          </div>
          <div class="lx-pcard__add-form">
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="lx-pcard__add-btn" {% unless product.available %}disabled{% endunless %}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {% if product.available %}Add to Basket{% else %}Sold Out{% endif %}
              </button>
            </form>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    {% if section.settings.view_all_url != blank %}
    <div class="lx-prods__cta lx-fade-in">
      <a href="{{ section.settings.view_all_url }}" class="lx-btn lx-btn--ghost-navy">
        View All Products
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    {% endif %}

    {% else %}
    <div class="lx-coll__empty">
      <p>No products found. Please select a collection in the theme editor.</p>
    </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings":[
    {"type":"text","id":"badge","label":"Badge","default":"Our Products"},
    {"type":"textarea","id":"heading","label":"Heading","default":"Clinically proven fertility\nsupplements & diagnostics"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Formulated by fertility specialists and backed by clinical research."},
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"range","id":"limit","label":"Products to show","min":3,"max":12,"step":3,"default":6},
    {"type":"url","id":"view_all_url","label":"View All URL","default":"/collections/all"}
  ],
  "presets":[{"name":"Featured Products"}]
}
{% endschema %}
