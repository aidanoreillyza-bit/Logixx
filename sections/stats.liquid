<section class="stats-section" id="stats" aria-labelledby="stats-heading">
  <div class="container">
    <h2 class="sr-only" id="stats-heading">Our Key Statistics</h2>
    <ul class="stats-grid" role="list">
      {% assign icons = 'M22 12 18 12 15 21 9 3 6 12 2 12|M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2 M9 7 circle|M12 12 circle r10 M12 6 12 12 16 14|M22 11.08V12a10 10 0 11-5.93-9.14 M22 4 12 14.01 9 11.01' | split: '|' %}
      {% for block in section.blocks %}
        {% if block.type == 'stat_item' %}
          <li class="stat-item" {{ block.shopify_attributes }}>
            <div class="stat-icon" aria-hidden="true">
              {% case forloop.index %}
                {% when 1 %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                {% when 2 %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                {% when 3 %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {% when 4 %}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {% endcase %}
            </div>
            <span class="stat-big-number">{{ block.settings.number }}</span>
            <span class="stat-description">{{ block.settings.description }}</span>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Stats",
  "blocks": [
    {
      "type": "stat_item",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "85%" },
        { "type": "text", "id": "description", "label": "Description", "default": "Clinical Success Rate" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats",
      "blocks": [
        { "type": "stat_item", "settings": { "number": "85%", "description": "Clinical Success Rate" } },
        { "type": "stat_item", "settings": { "number": "10k+", "description": "Families Helped" } },
        { "type": "stat_item", "settings": { "number": "15+", "description": "Years of Experience" } },
        { "type": "stat_item", "settings": { "number": "98%", "description": "Patient Satisfaction" } }
      ]
    }
  ]
}
{% endschema %}
