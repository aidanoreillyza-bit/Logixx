{% assign blog = blogs[section.settings.blog] %}
{% assign has_articles = false %}
{% if blog and blog.articles.size > 0 %}
  {% assign has_articles = true %}
{% endif %}

<section class="lx-news">
  <div class="lx-container">

    <div class="lx-section-head lx-fade-in">
      <span class="lx-badge lx-badge--mint">Latest News</span>
      <h2>From our <em>blog</em></h2>
      <p>Research updates, fertility tips and company news.</p>
    </div>

    <div class="lx-news__grid">

      {% if has_articles %}

        {% for article in blog.articles limit: 3 %}
        <a href="{{ article.url }}" class="lx-news__card lx-fade-in">
          <div class="lx-news__img">
            {% if article.image %}
              <img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.image.alt | escape }}" loading="lazy" width="600" height="400">
            {% endif %}
            {% if article.tags.first %}
              <span class="lx-news__tag">{{ article.tags.first }}</span>
            {% endif %}
          </div>
          <div class="lx-news__body">
            <div class="lx-news__date">{{ article.published_at | date: "%d %b %Y" }}</div>
            <h3 class="lx-news__title">{{ article.title }}</h3>
            <p class="lx-news__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
            <span class="lx-news__more">Read more →</span>
          </div>
        </a>
        {% endfor %}

      {% else %}

        <div class="lx-news__card lx-fade-in">
          <div class="lx-news__img lx-news__img--navy">
            <span class="lx-news__tag">Coming soon</span>
          </div>
          <div class="lx-news__body">
            <div class="lx-news__date">— — ——</div>
            <h3 class="lx-news__title">Understanding Male Infertility</h3>
            <p class="lx-news__excerpt">A comprehensive look at the causes, diagnosis, and treatment options available today.</p>
            <span class="lx-news__more">Read more →</span>
          </div>
        </div>

        <div class="lx-news__card lx-fade-in">
          <div class="lx-news__img lx-news__img--blue">
            <span class="lx-news__tag">Coming soon</span>
          </div>
          <div class="lx-news__body">
            <div class="lx-news__date">— — ——</div>
            <h3 class="lx-news__title">How Oxidative Stress Affects Fertility</h3>
            <p class="lx-news__excerpt">The science behind free radicals and how antioxidants can protect sperm health.</p>
            <span class="lx-news__more">Read more →</span>
          </div>
        </div>

        <div class="lx-news__card lx-fade-in">
          <div class="lx-news__img lx-news__img--mint">
            <span class="lx-news__tag">Coming soon</span>
          </div>
          <div class="lx-news__body">
            <div class="lx-news__date">— — ——</div>
            <h3 class="lx-news__title">Proxeed Plus: Clinical Evidence</h3>
            <p class="lx-news__excerpt">An in-depth review of the peer-reviewed studies supporting Proxeed Plus efficacy.</p>
            <span class="lx-news__more">Read more →</span>
          </div>
        </div>

      {% endif %}

    </div>

    <div class="lx-news__cta lx-fade-in">
      <a href="/blogs/news" class="lx-btn lx-btn--ghost-navy">View all articles →</a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "News Preview",
  "settings": [
    {"type": "blog", "id": "blog", "label": "Blog"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "From our <em>blog</em>"}
  ],
  "presets": [{"name": "News Preview"}]
}
{% endschema %}
