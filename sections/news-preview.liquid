{% assign blog = blogs[section.settings.blog] %}
{% assign has_articles = false %}
{% if blog and blog.articles.size > 0 %}
  {% assign has_articles = true %}
{% endif %}

<section style="background:#fafbfc;padding:96px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:56px;">
      <div style="font-size:11px;font-weight:700;color:#00b894;text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px;">Latest News</div>
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.5vw,2.6rem);color:#0f1f3a;margin:0 0 14px;line-height:1.15;">
        From our <em style="color:#3366d9;font-style:italic;">blog</em>
      </h2>
      <p style="font-size:15px;color:#6b7485;margin:0;">Research updates, fertility tips and company news.</p>
    </div>

    <!-- Article grid -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;">

      {% if has_articles %}

        {% for article in blog.articles limit: 3 %}
        <a href="{{ article.url }}" style="text-decoration:none;color:inherit;display:block;border:1.5px solid #e5e8ee;border-radius:16px;background:#fff;overflow:hidden;transition:transform .25s,box-shadow .25s,border-color .25s;"
           onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 48px rgba(15,31,58,.1)';this.style.borderColor='#00B8D4';"
           onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#e5e8ee';">
          <!-- Image area -->
          <div style="position:relative;height:200px;background:#e5e8ee;overflow:hidden;">
            {% if article.image %}
              <img src="{{ article.image | img_url: '600x400', crop: 'center' }}" alt="{{ article.image.alt | escape }}"
                   style="width:100%;height:100%;object-fit:cover;display:block;">
            {% endif %}
            {% if article.tags.first %}
              <span style="position:absolute;top:12px;left:12px;font-size:11px;font-weight:700;color:#00B8D4;background:rgba(0,184,212,.1);border:1px solid #00B8D4;border-radius:20px;padding:3px 10px;">
                {{ article.tags.first }}
              </span>
            {% endif %}
          </div>
          <!-- Card body -->
          <div style="padding:20px;">
            <div style="font-size:12px;color:#6b7485;margin-bottom:8px;">{{ article.published_at | date: "%d %b %Y" }}</div>
            <h3 style="font-family:'Instrument Serif',serif;font-size:20px;color:#0f1f3a;margin:0 0 10px;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {{ article.title }}
            </h3>
            <p style="font-size:13px;color:#6b7485;margin:0 0 16px;line-height:1.6;">
              {{ article.excerpt_or_content | strip_html | truncate: 100 }}
            </p>
            <span style="font-size:13px;font-weight:600;color:#00B8D4;">Read more →</span>
          </div>
        </a>
        {% endfor %}

      {% else %}

        <!-- Placeholder card 1 -->
        <div style="border:1.5px solid #e5e8ee;border-radius:16px;background:#fff;overflow:hidden;transition:transform .25s,box-shadow .25s,border-color .25s;"
             onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 48px rgba(15,31,58,.1)';this.style.borderColor='#00B8D4';"
             onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#e5e8ee';">
          <div style="position:relative;height:200px;background:linear-gradient(135deg,#0f1f3a,#1a3560);overflow:hidden;">
            <span style="position:absolute;top:12px;left:12px;font-size:11px;font-weight:700;color:#00B8D4;background:rgba(0,184,212,.1);border:1px solid #00B8D4;border-radius:20px;padding:3px 10px;">Coming soon</span>
          </div>
          <div style="padding:20px;">
            <div style="font-size:12px;color:#6b7485;margin-bottom:8px;">— — ——</div>
            <h3 style="font-family:'Instrument Serif',serif;font-size:20px;color:#0f1f3a;margin:0 0 10px;line-height:1.3;">Understanding Male Infertility</h3>
            <p style="font-size:13px;color:#6b7485;margin:0 0 16px;line-height:1.6;">A comprehensive look at the causes, diagnosis, and treatment options available today.</p>
            <span style="font-size:13px;font-weight:600;color:#00B8D4;">Read more →</span>
          </div>
        </div>

        <!-- Placeholder card 2 -->
        <div style="border:1.5px solid #e5e8ee;border-radius:16px;background:#fff;overflow:hidden;transition:transform .25s,box-shadow .25s,border-color .25s;"
             onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 48px rgba(15,31,58,.1)';this.style.borderColor='#00B8D4';"
             onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#e5e8ee';">
          <div style="position:relative;height:200px;background:linear-gradient(135deg,#3366d9,#5588ff);overflow:hidden;">
            <span style="position:absolute;top:12px;left:12px;font-size:11px;font-weight:700;color:#00B8D4;background:rgba(0,184,212,.1);border:1px solid #00B8D4;border-radius:20px;padding:3px 10px;">Coming soon</span>
          </div>
          <div style="padding:20px;">
            <div style="font-size:12px;color:#6b7485;margin-bottom:8px;">— — ——</div>
            <h3 style="font-family:'Instrument Serif',serif;font-size:20px;color:#0f1f3a;margin:0 0 10px;line-height:1.3;">How Oxidative Stress Affects Fertility</h3>
            <p style="font-size:13px;color:#6b7485;margin:0 0 16px;line-height:1.6;">The science behind free radicals and how antioxidants can protect sperm health.</p>
            <span style="font-size:13px;font-weight:600;color:#00B8D4;">Read more →</span>
          </div>
        </div>

        <!-- Placeholder card 3 -->
        <div style="border:1.5px solid #e5e8ee;border-radius:16px;background:#fff;overflow:hidden;transition:transform .25s,box-shadow .25s,border-color .25s;"
             onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 48px rgba(15,31,58,.1)';this.style.borderColor='#00B8D4';"
             onmouseout="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#e5e8ee';">
          <div style="position:relative;height:200px;background:linear-gradient(135deg,#00B8D4,#00d9a0);overflow:hidden;">
            <span style="position:absolute;top:12px;left:12px;font-size:11px;font-weight:700;color:#00B8D4;background:rgba(0,184,212,.1);border:1px solid #00B8D4;border-radius:20px;padding:3px 10px;">Coming soon</span>
          </div>
          <div style="padding:20px;">
            <div style="font-size:12px;color:#6b7485;margin-bottom:8px;">— — ——</div>
            <h3 style="font-family:'Instrument Serif',serif;font-size:20px;color:#0f1f3a;margin:0 0 10px;line-height:1.3;">Proxeed Plus: Clinical Evidence</h3>
            <p style="font-size:13px;color:#6b7485;margin:0 0 16px;line-height:1.6;">An in-depth review of the peer-reviewed studies supporting Proxeed Plus efficacy.</p>
            <span style="font-size:13px;font-weight:600;color:#00B8D4;">Read more →</span>
          </div>
        </div>

      {% endif %}

    </div>

    <!-- CTA -->
    <div style="text-align:center;margin-top:48px;">
      <a href="/blogs/news" style="font-size:15px;font-weight:600;color:#00B8D4;text-decoration:none;border:1.5px solid #00B8D4;border-radius:100px;padding:12px 32px;display:inline-block;transition:background .2s,color .2s;"
         onmouseover="this.style.background='#00B8D4';this.style.color='#fff';"
         onmouseout="this.style.background='';this.style.color='#00B8D4';">
        View all articles →
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "News Preview",
  "settings": [
    {"type": "blog", "id": "blog", "label": "Blog"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "From our <em>blog</em>"}
  ],
  "presets": [{"name": "News Preview"}]
}
{% endschema %}
