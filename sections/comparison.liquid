<section class="lx-compare">
  <div class="lx-container">

    <div class="lx-section-head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="lx-compare__wrap lx-fade-in">
      <div class="lx-compare__table" role="table" aria-label="{{ section.settings.col_brand | default: 'Our brand' }} vs {{ section.settings.col_generic | default: 'Generic supplement' }} comparison">

        <div class="lx-compare__head-row" role="row">
          <div class="lx-compare__th lx-compare__th--feat" role="columnheader">Features</div>
          <div class="lx-compare__th lx-compare__th--generic" role="columnheader">
            <span class="lx-compare__th-icon lx-compare__th-icon--bad" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </span>
            {{ section.settings.col_generic | default: 'Generic Supplement' }}
          </div>
          <div class="lx-compare__th lx-compare__th--proxeed" role="columnheader">
            {% if section.settings.col_brand_badge != blank %}
            <span class="lx-badge lx-badge--mint">{{ section.settings.col_brand_badge }}</span>
            {% endif %}
            {{ section.settings.col_brand | default: 'Proxeed Plus' }}
          </div>
        </div>

        {% for block in section.blocks %}
          {% if block.type == 'row' %}
          {% assign is_last = false %}
          {% if forloop.last %}{% assign is_last = true %}{% endif %}
          <div class="lx-compare__row{% if forloop.index0 == 0 %} lx-compare__row--first{% endif %}{% if is_last %} lx-compare__row--last{% endif %}{% if forloop.index0 == 1 or forloop.index0 == 3 or forloop.index0 == 5 %} lx-compare__row--alt{% endif %}" role="row" {{ block.shopify_attributes }}>
            <div class="lx-compare__td lx-compare__td--feat" role="cell">{{ block.settings.feature }}</div>
            <div class="lx-compare__td lx-compare__td--{% if block.settings.generic == 'yes' %}yes{% elsif block.settings.generic == 'partial' %}maybe{% else %}no{% endif %}" role="cell">
              {% if block.settings.generic == 'yes' %}
                <span class="lx-compare__yes" aria-label="Yes">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
              {% elsif block.settings.generic == 'partial' %}
                <span class="lx-compare__maybe" aria-label="Partial">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/></svg>
                </span>
              {% else %}
                <span class="lx-compare__no" aria-label="No">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </span>
              {% endif %}
            </div>
            <div class="lx-compare__td lx-compare__td--proxeed lx-compare__td--{% if block.settings.brand == 'yes' %}yes{% elsif block.settings.brand == 'partial' %}maybe{% else %}no{% endif %}" role="cell">
              {% if block.settings.brand == 'yes' %}
                <span class="lx-compare__yes lx-compare__yes--brand" aria-label="Yes">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
              {% elsif block.settings.brand == 'partial' %}
                <span class="lx-compare__maybe" aria-label="Partial">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M5 12h14"/></svg>
                </span>
              {% else %}
                <span class="lx-compare__no" aria-label="No">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </span>
              {% endif %}
            </div>
          </div>
          {% endif %}
        {% endfor %}

      </div>

      <div class="lx-compare__cta">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lx-btn lx-btn--mint lx-btn--lg">
          {{ section.settings.cta_label | default: 'Shop Now' }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        {% if section.settings.cta_note != blank %}
        <p class="lx-compare__cta-note">{{ section.settings.cta_note }}</p>
        {% endif %}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Comparison",
  "settings": [
    {"type":"text","id":"badge","label":"Badge","default":"The Proxeed Difference"},
    {"type":"textarea","id":"heading","label":"Heading","default":"Why Proxeed outperforms\ngeneric supplements"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Not all fertility supplements are equal. Proxeed's clinically formulated ingredients deliver results that generic multi-vitamins simply cannot match."},
    {"type":"text","id":"col_generic","label":"Competitor Column Name","default":"Generic Supplement"},
    {"type":"text","id":"col_brand","label":"Brand Column Name","default":"Proxeed Plus"},
    {"type":"text","id":"col_brand_badge","label":"Brand Column Badge","default":"Recommended"},
    {"type":"text","id":"cta_label","label":"CTA Button Label","default":"Shop Proxeed"},
    {"type":"url","id":"cta_url","label":"CTA Button URL"},
    {"type":"text","id":"cta_note","label":"CTA Note","default":"Clinically proven · Halal certified · Free UK delivery over £50"}
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {"type":"text","id":"feature","label":"Feature","default":"Clinically tested"},
        {
          "type":"select","id":"generic","label":"Generic column",
          "options":[{"value":"no","label":"No (✕)"},{"value":"partial","label":"Partial (~)"},{"value":"yes","label":"Yes (✓)"}],
          "default":"no"
        },
        {
          "type":"select","id":"brand","label":"Brand column",
          "options":[{"value":"no","label":"No (✕)"},{"value":"partial","label":"Partial (~)"},{"value":"yes","label":"Yes (✓)"}],
          "default":"yes"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Comparison",
    "blocks": [
      {"type":"row","settings":{"feature":"Clinically tested for sperm parameters","generic":"no","brand":"yes"}},
      {"type":"row","settings":{"feature":"Halal certified","generic":"no","brand":"yes"}},
      {"type":"row","settings":{"feature":"Patented L-Carnitine Fumarate","generic":"no","brand":"yes"}},
      {"type":"row","settings":{"feature":"Antioxidant protection complex","generic":"partial","brand":"yes"}},
      {"type":"row","settings":{"feature":"Peer-reviewed clinical evidence","generic":"no","brand":"yes"}},
      {"type":"row","settings":{"feature":"Free UK delivery on £50+","generic":"no","brand":"yes"}},
      {"type":"row","settings":{"feature":"Expert fertility specialist support","generic":"no","brand":"yes"}}
    ]
  }]
}
{% endschema %}
