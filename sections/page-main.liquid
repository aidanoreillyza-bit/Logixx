<!-- ══════════════════════════════════════════════════════════
     PAGE MAIN  —  Premium page header + content layout
     ══════════════════════════════════════════════════════════ -->

<!-- Dark-navy page header -->
<div class="lx-page-hero">
  <div class="lx-page-hero__orb lx-page-hero__orb--1" aria-hidden="true"></div>
  <div class="lx-page-hero__orb lx-page-hero__orb--2" aria-hidden="true"></div>
  <div class="lx-container lx-page-hero__inner">
    <div class="lx-page-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>{{ page.title }}</span>
    </div>
    <h1 class="lx-page-hero__title">{{ page.title }}</h1>
  </div>
</div>

<!-- Content -->
<section class="lx-page">
  <div class="lx-container">
    <div class="lx-page__body">
      <div class="lx-rte">{{ page.content }}</div>
    </div>
  </div>
</section>

<style>
/* ══════════════════════════════════════════════════════════
   PAGE HERO HEADER
   ══════════════════════════════════════════════════════════ */
.lx-page-hero {
  position: relative;
  background: var(--c-navy, #0a1628);
  overflow: hidden;
  padding: 64px 0 72px;
}

.lx-page-hero__orb {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(72px);
}
.lx-page-hero__orb--1 {
  width: 480px; height: 480px;
  background: radial-gradient(circle, rgba(0,194,184,.14) 0%, transparent 70%);
  top: -200px; left: -160px;
}
.lx-page-hero__orb--2 {
  width: 340px; height: 340px;
  background: radial-gradient(circle, rgba(69,186,232,.10) 0%, transparent 70%);
  bottom: -120px; right: -100px;
}

.lx-page-hero__inner {
  position: relative;
  z-index: 2;
}

/* Breadcrumb */
.lx-page-hero__breadcrumb {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .04em;
  color: rgba(255,255,255,.45);
  text-transform: uppercase;
  margin-bottom: 20px;
}
.lx-page-hero__breadcrumb a {
  color: rgba(255,255,255,.45);
  transition: color .2s ease;
}
.lx-page-hero__breadcrumb a:hover {
  color: var(--c-mint, #00C2B8);
}
.lx-page-hero__breadcrumb span:last-child {
  color: rgba(255,255,255,.75);
}

/* Title */
.lx-page-hero__title {
  font-family: var(--font-head);
  font-size: clamp(1.9rem, 4vw, 2.9rem);
  font-weight: 800;
  color: #fff;
  letter-spacing: -.025em;
  line-height: 1.1;
  margin: 0;
  position: relative;
  display: inline-block;
}
.lx-page-hero__title::after {
  content: '';
  display: block;
  width: 48px;
  height: 3px;
  background: linear-gradient(90deg, var(--c-mint, #00C2B8) 0%, #45bae8 100%);
  border-radius: 4px;
  margin-top: 14px;
}

/* ══════════════════════════════════════════════════════════
   PAGE CONTENT
   ══════════════════════════════════════════════════════════ */
.lx-page {
  padding: 64px 0 96px;
}
.lx-page__body {
  max-width: 760px;
}

@media (max-width: 600px) {
  .lx-page-hero { padding: 48px 0 56px; }
  .lx-page { padding: 48px 0 72px; }
}
</style>

{% schema %}
{
  "name": "Page",
  "settings":[],
  "presets":[{"name":"Page"}]
}
{% endschema %}
