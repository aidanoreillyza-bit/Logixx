{% assign trust_items = section.blocks | where: 'type', 'item' %}
{% assign logo_items  = section.blocks | where: 'type', 'logo' %}

<section class="lx-trust" aria-label="Certifications, partners and trust signals">

  {%- comment -%} ── Header ────────────────────────────────────── {%- endcomment -%}
  <div class="lx-container">
    <div class="lx-trust__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lx-trust__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <p class="lx-trust__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Row 1 – trust / certification items ──────── {%- endcomment -%}
  {%- if trust_items.size > 0 -%}
  <div class="lx-trust__track lx-trust__track--fwd" aria-hidden="true">
    <div class="lx-trust__row lx-trust__row--fwd">
      {% for i in (1..2) %}
        {% for block in trust_items %}
          <div class="lx-trust__item">
            <span class="lx-trust__icon-wrap">
              {% case block.settings.icon %}
              {% when 'shield' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              {% when 'check-circle' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
              </svg>
              {% when 'globe' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              {% when 'book' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
              {% when 'truck' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              {% when 'star' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {% when 'award' %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
              {% else %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
              </svg>
              {% endcase %}
            </span>
            <span class="lx-trust__item-text">{{ block.settings.label }}</span>
          </div>
          <div class="lx-trust__sep" aria-hidden="true">
            <svg width="6" height="6" viewBox="0 0 6 6" fill="none"><circle cx="3" cy="3" r="3" fill="url(#dot-grad)"/><defs><radialGradient id="dot-grad" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#00E5D5"/><stop offset="100%" stop-color="#00C2B8" stop-opacity="0.4"/></radialGradient></defs></svg>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── Row 2 – partner / media logos ─────────────── {%- endcomment -%}
  {%- if logo_items.size > 0 -%}
  <div class="lx-trust__track lx-trust__track--rev" aria-hidden="true">
    <div class="lx-trust__row lx-trust__row--rev">
      {% for i in (1..2) %}
        {% for block in logo_items %}
          <div class="lx-trust__logo-item">
            {%- if block.settings.logo != blank -%}
              <img
                src="{{ block.settings.logo | image_url: width: 160 }}"
                alt="{{ block.settings.alt | default: block.settings.name }}"
                width="120"
                height="44"
                loading="lazy"
                class="lx-trust__logo-img"
              >
            {%- else -%}
              <span class="lx-trust__logo-placeholder">{{ block.settings.name | default: 'Partner' }}</span>
            {%- endif -%}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── Decorative dot grid ───────────────────────── {%- endcomment -%}
  <div class="lx-trust__dots" aria-hidden="true"></div>

</section>

{% schema %}
{
  "name": "Brand Trust & Partners",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Label",
      "default": "Trusted & Certified"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Backed by Science. Trusted by Partners."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust / Certification Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value":"shield","label":"Shield"},
            {"value":"check-circle","label":"Check Circle"},
            {"value":"globe","label":"Globe"},
            {"value":"book","label":"Book"},
            {"value":"truck","label":"Truck"},
            {"value":"star","label":"Star"},
            {"value":"award","label":"Award"}
          ],
          "default": "check-circle"
        },
        {"type":"text","id":"label","label":"Label","default":"Certified"}
      ]
    },
    {
      "type": "logo",
      "name": "Partner Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Partner Name",
          "default": "Partner"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt Text"
        }
      ]
    }
  ],
  "presets": [{
    "name": "Brand Trust & Partners",
    "blocks": [
      {"type":"item","settings":{"icon":"shield","label":"Halal Certified"}},
      {"type":"item","settings":{"icon":"check-circle","label":"GMP Certified"}},
      {"type":"item","settings":{"icon":"globe","label":"15+ Years Experience"}},
      {"type":"item","settings":{"icon":"book","label":"Peer-Reviewed Science"}},
      {"type":"item","settings":{"icon":"truck","label":"Free UK Delivery £50+"}},
      {"type":"item","settings":{"icon":"award","label":"Award-Winning Formula"}},
      {"type":"item","settings":{"icon":"star","label":"5,000+ Happy Customers"}},
      {"type":"logo","settings":{"name":"The Times"}},
      {"type":"logo","settings":{"name":"NHS"}},
      {"type":"logo","settings":{"name":"Fertility Network UK"}},
      {"type":"logo","settings":{"name":"The Guardian"}},
      {"type":"logo","settings":{"name":"Boots"}}
    ]
  }]
}
{% endschema %}
