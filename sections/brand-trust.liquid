<section class="lx-trust" aria-label="Certifications and trust signals">
  <div class="lx-container">
    <p class="lx-trust__label">Trusted &amp; Certified</p>
    <div class="lx-trust__row">

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span>Halal Certified</span>
      </div>

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
        </svg>
        <span>GMP Certified</span>
      </div>

      <div class="lx-trust__sep" aria-hidden="true"></div>

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="6"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/>
        </svg>
        <span>15+ Years Experience</span>
      </div>

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        <span>Peer-Reviewed Science</span>
      </div>

      <div class="lx-trust__sep" aria-hidden="true"></div>

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
        <span>Free UK Delivery £50+</span>
      </div>

      <div class="lx-trust__item">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M9 12l2 2 4-4"/>
        </svg>
        <span>Discreet Packaging</span>
      </div>

    </div>
  </div>
</section>

