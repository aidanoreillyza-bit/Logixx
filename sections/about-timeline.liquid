<!-- ══════════════════════════════════════════════════════════
     ABOUT TIMELINE  —  Company story / milestone timeline
     ══════════════════════════════════════════════════════════ -->
<section class="lx-timeline">
  <div class="lx-container">

    <div class="lx-section-head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="lx-timeline__track" role="list">
      <!-- vertical spine -->
      <div class="lx-timeline__spine" aria-hidden="true"></div>

      {% for block in section.blocks %}
        {% if block.type == 'milestone' %}
        {% assign is_even = forloop.index | modulo: 2 %}
        <div class="lx-timeline__item{% if is_even == 0 %} lx-timeline__item--right{% endif %} lx-fade-in"
             role="listitem" {{ block.shopify_attributes }}>

          <div class="lx-timeline__year-col">
            <div class="lx-timeline__year">{{ block.settings.year }}</div>
          </div>

          <div class="lx-timeline__dot-col" aria-hidden="true">
            <div class="lx-timeline__dot"></div>
          </div>

          <div class="lx-timeline__card-col">
            <div class="lx-timeline__card">
              {% if block.settings.label != blank %}
              <span class="lx-timeline__card-label">{{ block.settings.label }}</span>
              {% endif %}
              <h3 class="lx-timeline__card-title">{{ block.settings.title }}</h3>
              {% if block.settings.body != blank %}
              <p class="lx-timeline__card-body">{{ block.settings.body }}</p>
              {% endif %}
            </div>
          </div>

        </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
/* ══════════════════════════════════════════════════════════
   ABOUT TIMELINE
   ══════════════════════════════════════════════════════════ */
.lx-timeline {
  padding: 96px 0;
  background: var(--c-off, #f7f9fc);
  overflow: hidden;
}

/* ── Track ────────────────────────────────────────────────── */
.lx-timeline__track {
  position: relative;
  margin-top: 16px;
}

/* Central spine line */
.lx-timeline__spine {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2px;
  transform: translateX(-50%);
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(69,186,232,.25) 6%,
    rgba(69,186,232,.25) 94%,
    transparent 100%
  );
}

/* ── Item row ─────────────────────────────────────────────── */
.lx-timeline__item {
  display: grid;
  grid-template-columns: 1fr 40px 1fr;
  align-items: start;
  gap: 0;
  margin-bottom: 56px;
}
.lx-timeline__item:last-child { margin-bottom: 0; }

/* Default (odd): year left, card right */
.lx-timeline__year-col {
  display: flex;
  justify-content: flex-end;
  padding-right: 32px;
  padding-top: 18px;
}
.lx-timeline__card-col {
  padding-left: 32px;
}

/* Even rows: reverse order visually via column reorder */
.lx-timeline__item--right .lx-timeline__year-col {
  order: 3;
  justify-content: flex-start;
  padding-right: 0;
  padding-left: 32px;
}
.lx-timeline__item--right .lx-timeline__dot-col { order: 2; }
.lx-timeline__item--right .lx-timeline__card-col {
  order: 1;
  padding-left: 0;
  padding-right: 32px;
  display: flex;
  justify-content: flex-end;
}
.lx-timeline__item--right .lx-timeline__card {
  text-align: right;
}

/* ── Year label ───────────────────────────────────────────── */
.lx-timeline__year {
  font-family: var(--font-head);
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--c-navy, #0a1628);
  letter-spacing: -.02em;
  white-space: nowrap;
  background: linear-gradient(135deg, var(--c-navy, #0a1628) 0%, #45bae8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Dot ──────────────────────────────────────────────────── */
.lx-timeline__dot-col {
  display: flex;
  justify-content: center;
  padding-top: 22px;
  position: relative;
  z-index: 1;
}
.lx-timeline__dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #fff;
  border: 2.5px solid #45bae8;
  box-shadow: 0 0 0 5px rgba(69,186,232,.14);
  flex-shrink: 0;
  transition: transform var(--transition), box-shadow var(--transition);
}
.lx-timeline__item:hover .lx-timeline__dot {
  transform: scale(1.3);
  box-shadow: 0 0 0 7px rgba(69,186,232,.18);
}

/* ── Card ─────────────────────────────────────────────────── */
.lx-timeline__card {
  background: #fff;
  border-radius: 20px;
  border: 1.5px solid rgba(69,186,232,.16);
  box-shadow: 0 2px 16px rgba(10,22,40,.05);
  padding: 28px 32px;
  max-width: 400px;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  position: relative;
  overflow: hidden;
}
.lx-timeline__card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, #45bae8 0%, rgba(69,186,232,.2) 100%);
  border-radius: 20px 20px 0 0;
}
.lx-timeline__item:hover .lx-timeline__card {
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(10,22,40,.09);
  border-color: rgba(69,186,232,.3);
}
.lx-timeline__item--right .lx-timeline__card {
  text-align: right;
}
.lx-timeline__item--right .lx-timeline__card::before {
  background: linear-gradient(90deg, rgba(69,186,232,.2) 0%, #45bae8 100%);
}

.lx-timeline__card-label {
  display: inline-block;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #45bae8;
  background: rgba(69,186,232,.1);
  border-radius: 50px;
  padding: 3px 10px;
  margin-bottom: 10px;
}

.lx-timeline__card-title {
  font-family: var(--font-head);
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--c-navy, #0a1628);
  margin: 0 0 8px;
  line-height: 1.3;
}

.lx-timeline__card-body {
  font-size: .92rem;
  color: var(--c-body, #3b4758);
  line-height: 1.7;
  margin: 0;
}

/* ── Mobile: single column ────────────────────────────────── */
@media (max-width: 700px) {
  .lx-timeline__spine { left: 20px; }

  .lx-timeline__item,
  .lx-timeline__item--right {
    grid-template-columns: 40px 1fr;
    grid-template-rows: auto auto;
  }

  .lx-timeline__year-col,
  .lx-timeline__item--right .lx-timeline__year-col {
    grid-column: 2;
    grid-row: 1;
    order: unset;
    justify-content: flex-start;
    padding: 0 0 6px 20px;
  }

  .lx-timeline__dot-col,
  .lx-timeline__item--right .lx-timeline__dot-col {
    grid-column: 1;
    grid-row: 1 / 3;
    order: unset;
    padding-top: 4px;
    justify-content: center;
  }

  .lx-timeline__card-col,
  .lx-timeline__item--right .lx-timeline__card-col {
    grid-column: 2;
    grid-row: 2;
    order: unset;
    padding: 0 0 0 20px;
    justify-content: flex-start;
  }

  .lx-timeline__card,
  .lx-timeline__item--right .lx-timeline__card {
    text-align: left;
    max-width: 100%;
  }
  .lx-timeline__card::before,
  .lx-timeline__item--right .lx-timeline__card::before {
    background: linear-gradient(90deg, #45bae8 0%, rgba(69,186,232,.2) 100%);
  }

  .lx-timeline__card { padding: 22px 24px; }
  .lx-timeline__year { font-size: 1.25rem; }
}
</style>

{% schema %}
{
  "name": "About Timeline",
  "settings": [
    {"type":"text","id":"badge","label":"Badge","default":"Our Story"},
    {"type":"textarea","id":"heading","label":"Heading","default":"A decade of advancing <em>fertility science</em>"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"From a single product to an end-to-end fertility platform — here is how LogixX grew."}
  ],
  "blocks": [{
    "type": "milestone",
    "name": "Milestone",
    "settings": [
      {"type":"text","id":"year","label":"Year","default":"2010"},
      {"type":"text","id":"label","label":"Label (optional)","default":"Founded"},
      {"type":"text","id":"title","label":"Title","default":"LogixX is born"},
      {"type":"textarea","id":"body","label":"Description","default":"Describe this milestone."}
    ]
  }],
  "presets": [{
    "name": "About Timeline",
    "blocks": [
      {
        "type": "milestone",
        "settings": {
          "year": "2008",
          "label": "Founded",
          "title": "LogixX Fertility established",
          "body": "Founded with a singular goal: to make advanced fertility diagnostics and treatments accessible to everyone. Our founding team brought together clinicians, scientists, and patient advocates."
        }
      },
      {
        "type": "milestone",
        "settings": {
          "year": "2013",
          "label": "Product Launch",
          "title": "Proxeed range introduced",
          "body": "After five years of clinical development, the Proxeed supplement range launched — backed by peer-reviewed studies demonstrating measurable improvements in sperm motility and morphology."
        }
      },
      {
        "type": "milestone",
        "settings": {
          "year": "2018",
          "label": "Partnership",
          "title": "Testhim partnership formed",
          "body": "LogixX joined forces with Testhim to become the UK's leading advanced fertility diagnostic partnership, combining at-home testing with clinical-grade analysis and personalised treatment pathways."
        }
      },
      {
        "type": "milestone",
        "settings": {
          "year": "2021",
          "label": "Innovation",
          "title": "LensHooke X1 PRO launches",
          "body": "We introduced the LensHooke X1 PRO — the world's first CASA-grade home sperm analysis device — putting clinical accuracy in the hands of patients for the first time."
        }
      },
      {
        "type": "milestone",
        "settings": {
          "year": "2024",
          "label": "Milestone",
          "title": "10,000+ families supported",
          "body": "A landmark moment: more than 10,000 families across the UK and beyond have now started or grown their families with the help of LogixX products, tests, and specialist guidance."
        }
      }
    ]
  }]
}
{% endschema %}
