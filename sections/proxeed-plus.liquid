<section style="background:#f7f9fc;padding:80px 0">
<div style="max-width:1240px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
<div style="position:relative;border-radius:28px;background:#f7f9fc;min-height:460px;display:flex;align-items:center;justify-content:center;overflow:hidden;border:1.5px solid #eaecf0">
  <!-- Best Seller badge -->
  <div style="position:absolute;top:20px;left:20px;z-index:4;font-size:11px;font-weight:700;color:#fff;background:#E87722;padding:5px 16px;border-radius:100px;letter-spacing:.06em;text-transform:uppercase;box-shadow:0 4px 14px rgba(232,119,34,.45)">⭐ Best Seller</div>
  <!-- Product image -->
  {% if section.settings.image %}
  <img src="{{ section.settings.image | image_url: width: 700 }}" alt="Proxeed Plus" style="position:relative;z-index:2;width:100%;height:100%;object-fit:cover;display:block;">
  {% else %}
  <div style="position:relative;z-index:2;width:180px;height:180px;border-radius:24px;background:rgba(0,194,184,.08);border:2px dashed rgba(0,194,184,.3);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#00C2B8" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="opacity:.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
    <span style="font-size:12px;font-weight:600;color:#00C2B8;opacity:.7">Upload product image</span>
  </div>
  {% endif %}

</div>
<div>
<div style="font-size:11px;font-weight:700;color:#00C2B8;text-transform:uppercase;letter-spacing:.12em;margin-bottom:14px">Male Fertility</div>
<h2 style="font-family:'Instrument Serif',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:400;color:#0a1628;margin-bottom:20px;line-height:1.1">Proxeed <em style="font-style:italic;color:#E87722">Plus</em></h2>
<p style="font-size:16px;color:#3b4758;line-height:1.8;margin-bottom:28px">Proxeed Plus is a high-quality fertility supplement specifically designed to support healthy sperm development and maximise a man's chances of fathering a child. The ingredients provide energy to developing sperm while protecting against oxidative stress.</p>
<div style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px">
<div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758"><div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#E87722;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span><strong>L-carnitine &amp; L-carnitine fumarate</strong> — provides energy to developing sperm cells</span></div>
<div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758"><div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#E87722;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span><strong>Vitamin C &amp; E</strong> — powerful antioxidants protecting sperm from oxidative stress</span></div>
<div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758"><div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#E87722;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span><strong>Zinc &amp; Selenium</strong> — essential minerals for sperm production and DNA integrity</span></div>
<div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758"><div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#E87722;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div><span><strong>Halal Certified</strong> — suitable for all dietary requirements</span></div>
</div>
<div style="display:flex;align-items:baseline;gap:12px;margin-bottom:24px">
<span style="font-family:'Instrument Serif',Georgia,serif;font-size:2.2rem;font-weight:400;color:#0a1628">£34.99</span>
<span style="font-size:15px;color:#6b7485;text-decoration:line-through">£44.99</span>
<span style="font-size:11px;font-weight:700;color:#fff;background:#ff4d5f;padding:3px 10px;border-radius:100px">Save £10</span>
</div>
<div style="display:flex;gap:12px;flex-wrap:wrap">
<a href="/products/proxeed-plus" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#E87722;color:#fff;border-radius:100px;font-weight:700;font-size:15px;text-decoration:none;box-shadow:0 6px 20px rgba(232,119,34,.3)">Shop Proxeed Plus →</a>
<a href="/pages/male-fertility-facts" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#fff;color:#0a1628;border-radius:100px;font-weight:600;font-size:15px;text-decoration:none;border:1.5px solid #eaecf0">Learn More</a>
</div>
</div>
</div>
</section>
{% schema %}
{
  "name": "Proxeed Plus",
  "settings": [
    {"type": "image_picker", "id": "image", "label": "Product Image"}
  ],
  "presets": [{"name": "Proxeed Plus"}]
}
{% endschema %}
