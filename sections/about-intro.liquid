<!-- ══════════════════════════════════════════════════════════
     ABOUT INTRO  —  Dark hero header + white card body
     ══════════════════════════════════════════════════════════ -->
<section class="lx-about lx-fade-in">

  <!-- ── Dark hero header ─────────────────────────────────── -->
  <div class="lx-about__hero">
    <!-- floating orbs (pure CSS, no images) -->
    <div class="lx-about__orb lx-about__orb--1" aria-hidden="true"></div>
    <div class="lx-about__orb lx-about__orb--2" aria-hidden="true"></div>
    <div class="lx-about__orb lx-about__orb--3" aria-hidden="true"></div>

    <div class="lx-container lx-about__hero-inner">
      {% if section.settings.badge != blank %}
      <div class="lx-about__hero-badge">
        <span class="lx-about__hero-badge-dot" aria-hidden="true"></span>
        {{ section.settings.badge }}
      </div>
      {% endif %}

      {% if section.settings.heading != blank %}
      <h2 class="lx-about__hero-heading">{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}

      {% if section.settings.subtext != blank %}
      <p class="lx-about__hero-sub">{{ section.settings.subtext }}</p>
      {% endif %}

      <!-- decorative divider line -->
      <div class="lx-about__divider" aria-hidden="true">
        <span></span><span></span><span></span>
      </div>
    </div>
  </div>

  <!-- ── Cards area (white) ────────────────────────────────── -->
  <div class="lx-about__body">
    <div class="lx-container">

      <div class="lx-about__cards">

        <!-- Vision -->
        <article class="lx-about__card lx-about__card--vision">
          <div class="lx-about__card-top">
            <div class="lx-about__card-icon" aria-hidden="true">
              <!-- eye icon -->
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </div>
            <span class="lx-about__card-label">{{ section.settings.vision_title | default: 'Our Vision' }}</span>
          </div>
          <p class="lx-about__card-body">{{ section.settings.vision_text }}</p>
        </article>

        <!-- Mission -->
        <article class="lx-about__card lx-about__card--mission">
          <div class="lx-about__card-top">
            <div class="lx-about__card-icon" aria-hidden="true">
              <!-- target icon -->
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            </div>
            <span class="lx-about__card-label">{{ section.settings.mission_title | default: 'Our Mission' }}</span>
          </div>
          <!-- quote-style body -->
          <blockquote class="lx-about__card-quote">
            <svg class="lx-about__card-quote-mark" aria-hidden="true" width="40" height="32" viewBox="0 0 40 32" fill="currentColor">
              <path d="M0 32V19.556C0 8.593 6.222 2.37 18.667 0L20 3.11C14.37 4.148 11.111 7.111 10.222 12H17.78V32H0zm22.222 0V19.556C22.222 8.593 28.444 2.37 40.889 0L42.222 3.11c-5.63 1.038-8.889 4.001-9.778 8.89h7.556V32H22.222z"/>
            </svg>
            <p>{{ section.settings.mission_text }}</p>
          </blockquote>
        </article>

      </div>

      <!-- Tagline strip -->
      {% if section.settings.tagline != blank %}
      <div class="lx-about__tagline">
        <span class="lx-about__tagline-deco" aria-hidden="true">"</span>
        <p class="lx-about__tagline-text">{{ section.settings.tagline }}</p>
        <span class="lx-about__tagline-deco lx-about__tagline-deco--end" aria-hidden="true">"</span>
      </div>
      {% endif %}

    </div>
  </div>

</section>

<style>
/* ══════════════════════════════════════════════════════════
   ABOUT INTRO
   ══════════════════════════════════════════════════════════ */

/* ── Dark hero header ──────────────────────────────────── */
.lx-about__hero {
  position: relative;
  background: var(--c-navy-dk, #060e1a);
  overflow: hidden;
  padding: 100px 0 120px;
  text-align: center;
}

/* glowing orbs */
.lx-about__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  animation: lx-float 6s ease-in-out infinite;
  pointer-events: none;
}
.lx-about__orb--1 {
  width: 420px; height: 420px;
  background: rgba(0,194,184,.16);
  top: -120px; right: -80px;
  animation-delay: 0s;
}
.lx-about__orb--2 {
  width: 320px; height: 320px;
  background: rgba(51,102,217,.18);
  bottom: -80px; left: -60px;
  animation-delay: 3s;
}
.lx-about__orb--3 {
  width: 200px; height: 200px;
  background: rgba(0,194,184,.10);
  top: 40%; left: 50%;
  transform: translateX(-50%);
  animation-delay: 1.5s;
}

.lx-about__hero-inner {
  position: relative;
  z-index: 2;
}

/* badge */
.lx-about__hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,194,184,.12);
  border: 1px solid rgba(0,194,184,.3);
  border-radius: 50px;
  padding: 7px 18px;
  color: var(--c-mint, #00C2B8);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: 24px;
}
.lx-about__hero-badge-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--c-mint, #00C2B8);
  animation: lx-pulse 2s ease-in-out infinite;
}

/* heading */
.lx-about__hero-heading {
  font-family: var(--font-head);
  font-size: clamp(2rem, 4vw, 3rem);
  color: #fff;
  line-height: 1.15;
  margin: 0 auto 20px;
  max-width: 640px;
}

/* sub */
.lx-about__hero-sub {
  font-size: 1.08rem;
  color: rgba(255,255,255,.68);
  line-height: 1.7;
  max-width: 560px;
  margin: 0 auto 40px;
}

/* decorative 3-dot divider */
.lx-about__divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.lx-about__divider span {
  display: block;
  border-radius: 50%;
  background: var(--c-mint, #00C2B8);
}
.lx-about__divider span:nth-child(1),
.lx-about__divider span:nth-child(3) {
  width: 6px; height: 6px;
  opacity: .45;
}
.lx-about__divider span:nth-child(2) {
  width: 9px; height: 9px;
}

/* ── White body ──────────────────────────────────────────── */
.lx-about__body {
  background: #f7f9fc;
  padding: 0 0 80px;
}

/* Cards overlap the hero slightly */
.lx-about__cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  transform: translateY(-56px);
  margin-bottom: -28px;
}
@media (max-width: 768px) {
  .lx-about__cards {
    grid-template-columns: 1fr;
    transform: translateY(-36px);
  }
}

/* Card base */
.lx-about__card {
  background: #fff;
  border-radius: 24px;
  padding: 0;
  box-shadow: 0 8px 40px rgba(10,22,40,.10);
  overflow: hidden;
  transition: transform .25s, box-shadow .25s;
  display: flex;
  flex-direction: column;
}
.lx-about__card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 56px rgba(10,22,40,.14);
}

/* gradient top border */
.lx-about__card::before {
  content: '';
  display: block;
  height: 4px;
  background: linear-gradient(90deg, var(--c-mint, #00C2B8) 0%, #3366d9 100%);
}

/* card inner padding */
.lx-about__card-top {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 32px 36px 20px;
}

.lx-about__card-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  background: var(--c-mint-pale, #e6fffe);
  color: var(--c-mint, #00C2B8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.lx-about__card-label {
  font-family: var(--font-head);
  font-size: 1.25rem;
  font-weight: 800;
  color: var(--c-navy, #0a1628);
  letter-spacing: -.01em;
}

/* plain body */
.lx-about__card-body {
  font-size: .97rem;
  color: #4a5568;
  line-height: 1.8;
  padding: 0 36px 36px;
  margin: 0;
}

/* quote body */
.lx-about__card-quote {
  margin: 0;
  padding: 0 36px 36px;
  position: relative;
}
.lx-about__card-quote-mark {
  color: var(--c-mint-pale, #e6fffe);
  display: block;
  margin-bottom: 12px;
  width: 36px;
  height: auto;
}
.lx-about__card-quote p {
  font-size: .97rem;
  color: #4a5568;
  line-height: 1.8;
  margin: 0;
  font-style: italic;
}

/* ── Tagline strip ────────────────────────────────────────── */
.lx-about__tagline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  background: linear-gradient(135deg, var(--c-navy, #0a1628), var(--c-navy-lt, #152035));
  border-radius: 20px;
  padding: 36px 48px;
  margin-top: 28px;
  position: relative;
  overflow: hidden;
}
/* subtle shimmer line */
.lx-about__tagline::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg,
    rgba(0,194,184,.08) 0%,
    rgba(0,194,184,0) 50%,
    rgba(51,102,217,.08) 100%);
  pointer-events: none;
}

.lx-about__tagline-deco {
  font-family: Georgia, serif;
  font-size: 5rem;
  line-height: .7;
  color: var(--c-mint, #00C2B8);
  opacity: .35;
  user-select: none;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.lx-about__tagline-deco--end {
  align-self: flex-end;
}

.lx-about__tagline-text {
  font-family: var(--font-head);
  font-size: clamp(1.25rem, 2.5vw, 1.6rem);
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin: 0 20px;
  line-height: 1.4;
  position: relative;
  z-index: 1;
  background: linear-gradient(90deg, #fff 30%, var(--c-mint, #00C2B8) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

@media (max-width: 600px) {
  .lx-about__hero { padding: 72px 0 96px; }
  .lx-about__card-top,
  .lx-about__card-body,
  .lx-about__card-quote { padding-left: 24px; padding-right: 24px; }
  .lx-about__tagline { padding: 28px 24px; }
  .lx-about__tagline-deco { font-size: 3.5rem; }
}
</style>

{% schema %}
{
  "name": "About Intro",
  "settings": [
    {"type":"text","id":"badge","label":"Badge","default":"About Us"},
    {"type":"textarea","id":"heading","label":"Heading","default":"We are LogixX Fertility"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"The leading advanced fertility diagnostic and treatment company — combining world-class science with compassionate, personalised care."},
    {"type":"header","content":"Vision"},
    {"type":"text","id":"vision_title","label":"Vision Title","default":"Our Vision"},
    {"type":"textarea","id":"vision_text","label":"Vision Text","default":"LogixX Fertility aims to be the best advanced (male focussed) fertility diagnostic and treatment company."},
    {"type":"header","content":"Mission"},
    {"type":"text","id":"mission_title","label":"Mission Title","default":"Our Mission"},
    {"type":"textarea","id":"mission_text","label":"Mission Text","default":"LogixX Fertility in partnership with testhim are the GO-TO companies for advanced fertility diagnostics & treatments. Through this partnership we provide extensive support to HCPs and patients through research, education, training and guidance — improving clinical outcomes and the patient experience."},
    {"type":"header","content":"Tagline"},
    {"type":"text","id":"tagline","label":"Tagline","default":"You never walk alone."}
  ],
  "presets": [{"name": "About Intro"}]
}
{% endschema %}