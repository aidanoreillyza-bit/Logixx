<!-- ══════════════════════════════════════════════════════════
     ABOUT INTRO  —  Clean open layout (reference-image style)
     ══════════════════════════════════════════════════════════ -->
<section class="lx-about lx-fade-in">

  <!-- ── Header ─────────────────────────────────────────────── -->
  <div class="lx-about__head">
    <!-- decorative swoosh shapes (pure CSS) -->
    <div class="lx-about__swoosh lx-about__swoosh--1" aria-hidden="true"></div>
    <div class="lx-about__swoosh lx-about__swoosh--2" aria-hidden="true"></div>

    <div class="lx-container lx-about__head-inner">
      {% if section.settings.badge != blank %}
      <div class="lx-about__badge">
        <span class="lx-about__badge-dot" aria-hidden="true"></span>
        {{ section.settings.badge }}
      </div>
      {% endif %}

      {% if section.settings.heading != blank %}
      <h2 class="lx-about__heading">{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}

      {% if section.settings.subtext != blank %}
      <p class="lx-about__sub">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
  </div>

  <!-- ── Feature rows ────────────────────────────────────────── -->
  <div class="lx-about__features">
    <div class="lx-container">

      <!-- Vision -->
      <div class="lx-about__feat">
        <div class="lx-about__feat-icon" aria-hidden="true">
          <!-- eye icon -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <div class="lx-about__feat-content">
          <h3 class="lx-about__feat-title">{{ section.settings.vision_title | default: 'Our Vision' }}</h3>
          <p class="lx-about__feat-body">{{ section.settings.vision_text }}</p>
        </div>
      </div>

      <!-- divider -->
      <div class="lx-about__feat-sep" aria-hidden="true"></div>

      <!-- Mission -->
      <div class="lx-about__feat">
        <div class="lx-about__feat-icon" aria-hidden="true">
          <!-- target icon -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <div class="lx-about__feat-content">
          <h3 class="lx-about__feat-title">{{ section.settings.mission_title | default: 'Our Mission' }}</h3>
          <p class="lx-about__feat-body">{{ section.settings.mission_text }}</p>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Tagline strip ────────────────────────────────────────── -->
  {% if section.settings.tagline != blank %}
  <div class="lx-about__tagline-wrap">
    <div class="lx-container">
      <div class="lx-about__tagline">
        <span class="lx-about__tagline-deco" aria-hidden="true">"</span>
        <p class="lx-about__tagline-text">{{ section.settings.tagline }}</p>
        <span class="lx-about__tagline-deco lx-about__tagline-deco--end" aria-hidden="true">"</span>
      </div>
    </div>
  </div>
  {% endif %}

</section>

<style>
/* ══════════════════════════════════════════════════════════
   ABOUT INTRO  —  Clean open layout
   ══════════════════════════════════════════════════════════ */

/* ── Header ──────────────────────────────────────────────── */
.lx-about__head {
  position: relative;
  background: #fff;
  overflow: hidden;
  padding: 52px 0 44px;
  text-align: center;
}

/* Decorative swoosh blobs — pure CSS border-radius shapes */
.lx-about__swoosh {
  position: absolute;
  pointer-events: none;
  border-radius: 50%;
  opacity: .25;
}
.lx-about__swoosh--1 {
  width: 480px; height: 480px;
  background: radial-gradient(circle at 30% 40%, rgba(0,194,184,.12) 0%, transparent 70%);
  top: -180px; left: -140px;
}
.lx-about__swoosh--2 {
  width: 360px; height: 360px;
  background: radial-gradient(circle at 70% 60%, rgba(0,194,184,.09) 0%, transparent 70%);
  bottom: -120px; right: -100px;
}

.lx-about__head-inner {
  position: relative;
  z-index: 2;
  max-width: 700px;
  margin: 0 auto;
}

/* badge */
.lx-about__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,194,184,.1);
  border: 1px solid rgba(0,194,184,.28);
  border-radius: 50px;
  padding: 6px 18px;
  color: var(--c-mint-dk, #009990);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  margin-bottom: 24px;
}
.lx-about__badge-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--c-mint, #00C2B8);
  animation: lx-pulse 2s ease-in-out infinite;
}

/* heading — navy bold, mint on accent word (set via newline) */
.lx-about__heading {
  font-family: var(--font-head);
  font-size: clamp(1.75rem, 3.5vw, 2.4rem);
  color: var(--c-navy, #0a1628);
  line-height: 1.15;
  margin: 0 0 14px;
  font-weight: 800;
}
/* Wrap the company name in <em> in Shopify to get teal colour */
.lx-about__heading em {
  font-style: normal;
  color: var(--c-mint, #00C2B8);
}

/* sub */
.lx-about__sub {
  font-size: .97rem;
  color: #4a5568;
  line-height: 1.65;
  margin: 0;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}

/* ── Feature rows ────────────────────────────────────────── */
.lx-about__features {
  background: #fff;
  padding: 36px 0 44px;
}

.lx-about__feat {
  display: flex;
  align-items: flex-start;
  gap: 28px;
  padding: 0 0 0 0;
}
@media (max-width: 600px) {
  .lx-about__feat { flex-direction: column; gap: 16px; }
}

/* icon circle — cleaner, no box */
.lx-about__feat-icon {
  flex-shrink: 0;
  width: 52px; height: 52px;
  border-radius: 50%;
  background: #fff;
  border: 2px solid rgba(0,194,184,.25);
  color: var(--c-mint, #00C2B8);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 3px 10px rgba(0,194,184,.10);
  margin-top: 3px;
}

/* content */
.lx-about__feat-content {
  flex: 1;
  border-left: 3px solid var(--c-mint, #00C2B8);
  padding-left: 24px;
}

.lx-about__feat-title {
  font-family: var(--font-head);
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--c-navy, #0a1628);
  margin: 0 0 7px;
  letter-spacing: -.01em;
}

.lx-about__feat-body {
  font-size: .95rem;
  color: #4a5568;
  line-height: 1.75;
  margin: 0;
}

/* separator between Vision and Mission */
.lx-about__feat-sep {
  height: 1px;
  background: linear-gradient(90deg, var(--c-mint, #00C2B8) 0%, transparent 100%);
  opacity: .2;
  margin: 24px 0;
}

/* ── Tagline strip ────────────────────────────────────────── */
.lx-about__tagline-wrap {
  background: #fff;
  padding: 0 0 44px;
}

.lx-about__tagline {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--c-navy, #0a1628) 0%, var(--c-navy-lt, #152035) 100%);
  border-radius: 16px;
  padding: 28px 40px;
  position: relative;
  overflow: hidden;
}
.lx-about__tagline::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(0,194,184,.07) 0%, transparent 60%);
  pointer-events: none;
}

.lx-about__tagline-deco {
  font-family: Georgia, serif;
  font-size: 3.2rem;
  line-height: .7;
  color: var(--c-mint, #00C2B8);
  opacity: .3;
  user-select: none;
  flex-shrink: 0;
  position: relative; z-index: 1;
}
.lx-about__tagline-deco--end { align-self: flex-end; }

.lx-about__tagline-text {
  font-family: var(--font-head);
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  font-weight: 700;
  color: #fff;
  text-align: center;
  margin: 0 16px;
  line-height: 1.4;
  position: relative; z-index: 1;
  background: linear-gradient(90deg, #fff 30%, var(--c-mint, #00C2B8) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

@media (max-width: 600px) {
  .lx-about__head { padding: 40px 0 32px; }
  .lx-about__tagline { padding: 22px 20px; }
  .lx-about__tagline-deco { font-size: 2.5rem; }
}
</style>

{% schema %}
{
  "name": "About Intro",
  "settings": [
    {"type":"text","id":"badge","label":"Badge","default":"About Us"},
    {"type":"textarea","id":"heading","label":"Heading","default":"We are LogixX Fertility"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"The leading advanced fertility diagnostic and treatment company — combining world-class science with compassionate, personalised care."},
    {"type":"header","content":"Vision"},
    {"type":"text","id":"vision_title","label":"Vision Title","default":"Our Vision"},
    {"type":"textarea","id":"vision_text","label":"Vision Text","default":"LogixX Fertility aims to be the best advanced (male focussed) fertility diagnostic and treatment company."},
    {"type":"header","content":"Mission"},
    {"type":"text","id":"mission_title","label":"Mission Title","default":"Our Mission"},
    {"type":"textarea","id":"mission_text","label":"Mission Text","default":"LogixX Fertility in partnership with testhim are the GO-TO companies for advanced fertility diagnostics & treatments. Through this partnership we provide extensive support to HCPs and patients through research, education, training and guidance — improving clinical outcomes and the patient experience."},
    {"type":"header","content":"Tagline"},
    {"type":"text","id":"tagline","label":"Tagline","default":"You never walk alone."}
  ],
  "presets": [{"name": "About Intro"}]
}
{% endschema %}