<section class="lx-about-intro" style="background:#f7f9fc;padding:96px 0">
  <div class="lx-container">
    <div class="lx-section-head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Intro",
  "settings": [
    {"type":"text","id":"badge","label":"Badge","default":"About Us"},
    {"type":"textarea","id":"heading","label":"Heading","default":"We are LogixX Pharma"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Dedicated to advancing fertility health through clinically proven science and compassionate care."}
  ],
  "presets": [{"name": "About Intro"}]
}
{% endschema %}