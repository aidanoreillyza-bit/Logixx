<section class="lx-results">
  <div class="lx-container">
    <div class="lx-results__grid">

      <!-- LEFT COLUMN -->
      <div class="lx-fade-in">
        <div class="lx-results__label">Real Results</div>
        <h2 class="lx-results__heading">What our customers <em>achieved</em></h2>
        <p class="lx-results__desc">Backed by peer-reviewed science and thousands of success stories. Here is what couples experienced after completing a full Proxeed course.</p>

        <div class="lx-results__stats">

          <div class="lx-results__stat">
            <div class="lx-results__stat-num">67%</div>
            <div>
              <div class="lx-results__stat-title">Improvement in sperm motility</div>
              <div class="lx-results__stat-sub">Reported after 3 months of Proxeed Plus</div>
            </div>
          </div>

          <div class="lx-results__stat">
            <div class="lx-results__stat-num">90 days</div>
            <div>
              <div class="lx-results__stat-title">Sperm maturation cycle</div>
              <div class="lx-results__stat-sub">Allow a full cycle for best results</div>
            </div>
          </div>

          <div class="lx-results__stat">
            <div class="lx-results__stat-num">4–6 months</div>
            <div>
              <div class="lx-results__stat-title">Recommended course length</div>
              <div class="lx-results__stat-sub">For measurable, lasting improvements</div>
            </div>
          </div>

        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="lx-results__card lx-fade-in">

        <div class="lx-results__card-head">
          <span class="lx-results__card-title">Sperm Analysis — Before &amp; After</span>
          <span class="lx-results__card-pill">Proxeed Plus — 90 day course</span>
        </div>

        <div class="lx-results__cols">
          <div class="lx-results__col-label"></div>
          <div class="lx-results__col-label">Before</div>
          <div class="lx-results__col-label">After</div>
        </div>

        <div class="lx-results__row">
          <div class="lx-results__row-vals">
            <div class="lx-results__row-name">Motility</div>
            <div class="lx-results__row-before">28%</div>
            <div class="lx-results__row-after">47%</div>
          </div>
          <div class="lx-results__bar">
            <div class="lx-results__bar-fill" style="background:linear-gradient(90deg,#ff4d5f 37%,#00a885 37%);width:63%;"></div>
          </div>
        </div>

        <div class="lx-results__row">
          <div class="lx-results__row-vals">
            <div class="lx-results__row-name">Concentration</div>
            <div class="lx-results__row-before">12M/ml</div>
            <div class="lx-results__row-after">19M/ml</div>
          </div>
          <div class="lx-results__bar">
            <div class="lx-results__bar-fill" style="background:linear-gradient(90deg,#ff4d5f 30%,#00a885 30%);width:48%;"></div>
          </div>
        </div>

        <div class="lx-results__row">
          <div class="lx-results__row-vals">
            <div class="lx-results__row-name">Morphology</div>
            <div class="lx-results__row-before">2%</div>
            <div class="lx-results__row-after">5%</div>
          </div>
          <div class="lx-results__bar">
            <div class="lx-results__bar-fill" style="background:linear-gradient(90deg,#ff4d5f 29%,#00a885 29%);width:50%;"></div>
          </div>
        </div>

        <div class="lx-results__row">
          <div class="lx-results__row-vals">
            <div class="lx-results__row-name">DNA Fragmentation</div>
            <div class="lx-results__row-before">High</div>
            <div class="lx-results__row-after">Normal</div>
          </div>
          <div class="lx-results__bar">
            <div class="lx-results__bar-fill" style="background:linear-gradient(90deg,#ff4d5f 40%,#00a885 40%);width:80%;"></div>
          </div>
        </div>

        <p class="lx-results__disclaimer">*Individual results may vary. Based on clinical study data.</p>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Results",
  "settings": [],
  "presets": [{"name": "Results"}]
}
{% endschema %}
