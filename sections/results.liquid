<section style="background:#fff;padding:96px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">

      <!-- LEFT COLUMN -->
      <div>
        <div style="font-size:11px;font-weight:700;color:#00b894;text-transform:uppercase;letter-spacing:.1em;margin-bottom:16px;">Real Results</div>
        <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.5vw,2.6rem);color:#0f1f3a;margin:0 0 20px;line-height:1.15;">
          What our customers <em style="color:#3366d9;font-style:italic;">achieved</em>
        </h2>
        <p style="font-size:16px;color:#6b7485;line-height:1.7;margin:0 0 36px;">
          Backed by peer-reviewed science and thousands of success stories. Here is what couples experienced after completing a full Proxeed course.
        </p>

        <!-- Stat cards -->
        <div style="display:flex;flex-direction:column;gap:16px;">

          <div style="display:flex;align-items:flex-start;gap:20px;padding:20px 24px;border:1.5px solid #e5e8ee;border-radius:14px;">
            <div style="font-family:'Instrument Serif',serif;font-size:2.4rem;color:#00B8D4;line-height:1;flex-shrink:0;">67%</div>
            <div>
              <div style="font-size:15px;font-weight:700;color:#0f1f3a;margin-bottom:4px;">Improvement in sperm motility</div>
              <div style="font-size:13px;color:#6b7485;">Reported after 3 months of Proxeed Plus</div>
            </div>
          </div>

          <div style="display:flex;align-items:flex-start;gap:20px;padding:20px 24px;border:1.5px solid #e5e8ee;border-radius:14px;">
            <div style="font-family:'Instrument Serif',serif;font-size:2.4rem;color:#00B8D4;line-height:1;flex-shrink:0;white-space:nowrap;">90 days</div>
            <div>
              <div style="font-size:15px;font-weight:700;color:#0f1f3a;margin-bottom:4px;">Sperm maturation cycle</div>
              <div style="font-size:13px;color:#6b7485;">Allow a full cycle for best results</div>
            </div>
          </div>

          <div style="display:flex;align-items:flex-start;gap:20px;padding:20px 24px;border:1.5px solid #e5e8ee;border-radius:14px;">
            <div style="font-family:'Instrument Serif',serif;font-size:2.4rem;color:#00B8D4;line-height:1;flex-shrink:0;white-space:nowrap;">4-6 months</div>
            <div>
              <div style="font-size:15px;font-weight:700;color:#0f1f3a;margin-bottom:4px;">Recommended course length</div>
              <div style="font-size:13px;color:#6b7485;">For measurable, lasting improvements</div>
            </div>
          </div>

        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div style="border:1.5px solid #e5e8ee;border-radius:20px;padding:32px;">

        <!-- Card header -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:8px;">
          <span style="font-size:15px;font-weight:700;color:#0f1f3a;">Sperm Analysis — Before &amp; After</span>
          <span style="font-size:12px;font-weight:600;color:#00B8D4;background:rgba(0,184,212,.08);padding:4px 12px;border-radius:20px;">Proxeed Plus — 90 day course</span>
        </div>

        <!-- Column headers -->
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px;padding:0 4px;">
          <div style="font-size:11px;font-weight:700;color:#6b7485;text-transform:uppercase;letter-spacing:.07em;"></div>
          <div style="font-size:11px;font-weight:700;color:#6b7485;text-transform:uppercase;letter-spacing:.07em;text-align:center;">Before</div>
          <div style="font-size:11px;font-weight:700;color:#6b7485;text-transform:uppercase;letter-spacing:.07em;text-align:center;">After</div>
        </div>

        <!-- Row: Motility -->
        <div style="margin-bottom:18px;">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center;margin-bottom:6px;padding:0 4px;">
            <div style="font-size:13px;font-weight:600;color:#0f1f3a;">Motility</div>
            <div style="font-size:15px;font-weight:700;color:#ff4d5f;text-align:center;">28%</div>
            <div style="font-size:15px;font-weight:700;color:#00a885;text-align:center;">47%</div>
          </div>
          <div style="background:#f0f2f5;border-radius:4px;height:6px;overflow:hidden;">
            <div style="background:linear-gradient(90deg,#ff4d5f 37%,#00a885 37%);height:100%;width:63%;border-radius:4px;"></div>
          </div>
        </div>

        <!-- Row: Concentration -->
        <div style="margin-bottom:18px;">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center;margin-bottom:6px;padding:0 4px;">
            <div style="font-size:13px;font-weight:600;color:#0f1f3a;">Concentration</div>
            <div style="font-size:15px;font-weight:700;color:#ff4d5f;text-align:center;">12M/ml</div>
            <div style="font-size:15px;font-weight:700;color:#00a885;text-align:center;">19M/ml</div>
          </div>
          <div style="background:#f0f2f5;border-radius:4px;height:6px;overflow:hidden;">
            <div style="background:linear-gradient(90deg,#ff4d5f 30%,#00a885 30%);height:100%;width:48%;border-radius:4px;"></div>
          </div>
        </div>

        <!-- Row: Morphology -->
        <div style="margin-bottom:18px;">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center;margin-bottom:6px;padding:0 4px;">
            <div style="font-size:13px;font-weight:600;color:#0f1f3a;">Morphology</div>
            <div style="font-size:15px;font-weight:700;color:#ff4d5f;text-align:center;">2%</div>
            <div style="font-size:15px;font-weight:700;color:#00a885;text-align:center;">5%</div>
          </div>
          <div style="background:#f0f2f5;border-radius:4px;height:6px;overflow:hidden;">
            <div style="background:linear-gradient(90deg,#ff4d5f 29%,#00a885 29%);height:100%;width:50%;border-radius:4px;"></div>
          </div>
        </div>

        <!-- Row: DNA Fragmentation -->
        <div style="margin-bottom:24px;">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;align-items:center;margin-bottom:6px;padding:0 4px;">
            <div style="font-size:13px;font-weight:600;color:#0f1f3a;">DNA Fragmentation</div>
            <div style="font-size:15px;font-weight:700;color:#ff4d5f;text-align:center;">High</div>
            <div style="font-size:15px;font-weight:700;color:#00a885;text-align:center;">Normal</div>
          </div>
          <div style="background:#f0f2f5;border-radius:4px;height:6px;overflow:hidden;">
            <div style="background:linear-gradient(90deg,#ff4d5f 40%,#00a885 40%);height:100%;width:80%;border-radius:4px;"></div>
          </div>
        </div>

        <!-- Disclaimer -->
        <div style="font-size:11px;color:#9aa0ab;border-top:1px solid #e5e8ee;padding-top:16px;">
          *Individual results may vary. Based on clinical study data.
        </div>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Results",
  "settings": [],
  "presets": [{"name": "Results"}]
}
{% endschema %}
