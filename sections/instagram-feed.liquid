{% assign ig_url = section.settings.url | default: 'https://instagram.com/logixxfertility' %}
{% assign ig_handle = section.settings.handle | default: '@logixxfertility' %}

<style>
  .ig-feed-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 12px;
  }
  .ig-card {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
  }
  .ig-card-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ig-card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(8,20,40,.7);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .25s;
    border-radius: 12px;
  }
  .ig-card:hover .ig-card-overlay {
    opacity: 1;
  }
  @media (max-width: 768px) {
    .ig-feed-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<section style="background:#fff;padding:80px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;">

    <!-- Header -->
    <div style="text-align:center;margin-bottom:48px;">
      <div style="font-size:11px;font-weight:700;color:#00b894;text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px;">Follow Us</div>
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(1.9rem,3.5vw,2.6rem);color:#0f1f3a;margin:0 0 14px;line-height:1.15;">
        <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" style="color:inherit;text-decoration:none;">{{ ig_handle }}</a>
      </h2>
      <p style="font-size:15px;color:#6b7485;margin:0;">Follow our journey and join the conversation.</p>
    </div>

    <!-- Placeholder post grid -->
    <div class="ig-feed-grid">

      <!-- Post 1: dark navy + heart -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#081428,#0f2a4a);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#00B8D4" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">248</span>
        </div>
      </div>

      <!-- Post 2: cyan + leaf -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#00B8D4,#0095AD);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 22c1.25-1.25 2.09-2.97 2.5-5C5.66 11.04 9.98 7 15 7c2 0 4 .5 5.5 2S22 13 22 15c0 5.02-4.04 9.34-10 10.5-2.03.41-3.75 1.25-5 2.5z"/>
            <path d="M22 22 11 11"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">391</span>
        </div>
      </div>

      <!-- Post 3: mint + microscope -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#ecfdf5,#d1f4e3);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#0f1f3a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/>
            <path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">174</span>
        </div>
      </div>

      <!-- Post 4: navy-blue + people -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#0f2a4a,#3366d9);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">512</span>
        </div>
      </div>

      <!-- Post 5: pale mint + star -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#e6fff8,#00B8D4);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#0f1f3a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">329</span>
        </div>
      </div>

      <!-- Post 6: dark-cyan + package -->
      <div class="ig-card">
        <div class="ig-card-inner" style="background:linear-gradient(135deg,#081428,#00B8D4);">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/>
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <div class="ig-card-overlay">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span style="color:#fff;font-size:13px;font-weight:600;margin-top:6px;">207</span>
        </div>
      </div>

    </div>

    <!-- CTA row -->
    <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-top:40px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:10px;">
        <!-- Instagram icon -->
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0f1f3a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        <span style="font-size:15px;font-weight:600;color:#0f1f3a;">{{ ig_handle }}</span>
      </div>
      <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer"
         style="background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:#fff;font-size:14px;font-weight:600;border-radius:12px;padding:12px 24px;text-decoration:none;display:inline-block;border:none;">
        Follow on Instagram
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "description": "To show real Instagram posts install the free 'Instafeed' app from the Shopify App Store and replace this section.",
  "settings": [
    {"type": "text", "id": "handle", "label": "Instagram Handle", "default": "@logixxfertility"},
    {"type": "url", "id": "url", "label": "Instagram URL", "default": "https://instagram.com/logixxfertility"}
  ],
  "presets": [{"name": "Instagram Feed"}]
}
{% endschema %}
