{% assign ig_url = section.settings.url | default: 'https://instagram.com/logixxfertility' %}
{% assign ig_handle = section.settings.handle | default: '@logixxfertility' %}

<section class="lx-ig">
  <div class="lx-container">

    <div class="lx-section-head lx-fade-in">
      <span class="lx-badge lx-badge--mint">Follow Us</span>
      <h2><a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" class="lx-text-mint">{{ ig_handle }}</a></h2>
      <p>Follow our journey and join the conversation.</p>
    </div>

    <div class="lx-ig__grid lx-fade-in">
      {% for block in section.blocks %}
        {% if block.type == 'photo' %}
        <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" class="lx-ig__card" aria-label="View on Instagram" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
          <div class="lx-ig__card-inner" style="background: none; padding: 0;">
            <img
              src="{{ block.settings.image | img_url: '400x400', crop: 'center' }}"
              alt="{{ block.settings.image.alt | escape | default: 'Instagram photo' }}"
              loading="lazy"
              width="400"
              height="400"
              style="width:100%;height:100%;object-fit:cover;display:block;"
            >
          </div>
          {% else %}
          <div class="lx-ig__card-inner lx-ig__card-inner--navy">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          {% endif %}
          <div class="lx-ig__overlay">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>

    <div class="lx-ig__cta lx-fade-in">
      <div class="lx-ig__handle">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        {{ ig_handle }}
      </div>
      <a href="{{ ig_url }}" target="_blank" rel="noopener noreferrer" class="lx-ig__follow-btn">
        Follow on Instagram
      </a>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Instagram Feed",
  "description": "Upload up to 6 photos below. For a live feed that auto-updates, install the free 'Instafeed' app from the Shopify App Store and replace this section.",
  "settings": [
    {"type": "text", "id": "handle", "label": "Instagram Handle", "default": "@logixxfertility"},
    {"type": "url", "id": "url", "label": "Instagram URL", "default": "https://instagram.com/logixxfertility"}
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {"type": "image_picker", "id": "image", "label": "Photo"}
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Instagram Feed",
    "blocks": [
      {"type":"photo"},
      {"type":"photo"},
      {"type":"photo"},
      {"type":"photo"},
      {"type":"photo"},
      {"type":"photo"}
    ]
  }]
}
{% endschema %}
