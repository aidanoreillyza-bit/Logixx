<section class="lx-cta">
  <div class="lx-container">
    <div class="lx-cta__inner lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--navy">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
      {% if section.settings.subtext != blank %}
      <p class="lx-cta__sub">{{ section.settings.subtext }}</p>
      {% endif %}
      <div class="lx-cta__btns">
        {% if section.settings.btn1_label != blank %}
        <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="lx-btn lx-btn--mint lx-btn--lg">
          {{ section.settings.btn1_label }}
        </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
        <a href="{{ section.settings.btn2_url | default: '/pages/contact' }}" class="lx-btn lx-btn--ghost">
          {{ section.settings.btn2_label }}
        </a>
        {% endif %}
      </div>
      <div class="lx-cta__contacts">
        {% if section.settings.phone != blank %}
        <a href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}" class="lx-cta__contact-link">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.36 11.36 0 0 0 3.56.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.01z"/></svg>
          {{ section.settings.phone }}
        </a>
        {% endif %}
        {% if section.settings.email != blank %}
        <a href="mailto:{{ section.settings.email }}" class="lx-cta__contact-link">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>
          {{ section.settings.email }}
        </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings":[
    {"type":"text","id":"badge","label":"Badge","default":"Get Started"},
    {"type":"textarea","id":"heading","label":"Heading","default":"Start your fertility journey today"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Thousands of families across the UK trust LogixX Pharma for clinically proven fertility support."},
    {"type":"text","id":"btn1_label","label":"Primary button","default":"Shop Products"},
    {"type":"url","id":"btn1_url","label":"Primary button URL","default":"/collections/all"},
    {"type":"text","id":"btn2_label","label":"Secondary button","default":"Contact Us"},
    {"type":"url","id":"btn2_url","label":"Secondary button URL","default":"/pages/contact"},
    {"type":"text","id":"phone","label":"Phone","default":"+44 (0) 1189 011 747"},
    {"type":"text","id":"email","label":"Email","default":"info@logixxpharma.com"}
  ],
  "presets":[{"name":"CTA Banner"}]
}
{% endschema %}
