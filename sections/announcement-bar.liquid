<div class="lx-ann" role="banner" aria-label="Announcements">
  <div class="lx-ann__contact">
    {% if section.settings.phone != blank %}
    <a href="tel:{{ section.settings.phone | replace: ' ', '' }}" class="lx-ann__link">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.36 11.36 0 0 0 3.56.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.01z"/></svg>
      {{ section.settings.phone }}
    </a>
    {% endif %}
    {% if section.settings.email != blank %}
    <a href="mailto:{{ section.settings.email }}" class="lx-ann__link">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>
      {{ section.settings.email }}
    </a>
    {% endif %}
  </div>

  <div class="lx-ann__ticker-wrap" aria-hidden="true">
    <div class="lx-ann__track">
      {% assign messages = section.settings.msg_1 | append: '|||' | append: section.settings.msg_2 | append: '|||' | append: section.settings.msg_3 | append: '|||' | append: section.settings.msg_4 %}
      {% assign msg_arr = messages | split: '|||' %}
      {% for i in (1..2) %}
        {% for msg in msg_arr %}
          {% if msg != blank %}
          <span class="lx-ann__msg">{{ msg }}</span>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>

  <div class="lx-ann__contact">
    {% if section.settings.phone != blank %}
    <a href="tel:{{ section.settings.phone | replace: ' ', '' }}" class="lx-ann__link">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.36 11.36 0 0 0 3.56.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.01z"/></svg>
      {{ section.settings.phone }}
    </a>
    {% endif %}
    {% if section.settings.email != blank %}
    <a href="mailto:{{ section.settings.email }}" class="lx-ann__link">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z"/></svg>
      {{ section.settings.email }}
    </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"text","id":"phone","label":"Phone","default":"+44 (0) 1189 011 747"},
    {"type":"text","id":"email","label":"Email","default":"info@logixxpharma.com"},
    {"type":"text","id":"msg_1","label":"Message 1","default":"Free UK Delivery on orders over £50"},
    {"type":"text","id":"msg_2","label":"Message 2","default":"Discreet packaging on every order"},
    {"type":"text","id":"msg_3","label":"Message 3","default":"Clinically proven — recommended by fertility specialists"},
    {"type":"text","id":"msg_4","label":"Message 4","default":"Trusted for over 10 years worldwide"}
  ],
  "presets":[{"name":"Announcement Bar"}]
}
{% endschema %}
