<div class="announcement-bar" role="banner" aria-label="Announcement">
  <div class="announcement-inner">
    <span class="announcement-contact">
      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.25 1.01l-2.2 2.2z"/></svg>
      <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | prepend: '+' | replace: '++', '+' }}">{{ section.settings.phone }}</a>
    </span>
    <span class="announcement-ticker">
      <span class="ticker-text">{{ section.settings.ticker_text }}</span>
    </span>
    <span class="announcement-contact">
      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "type": "announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+1 (800) 555-6789"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@logixxfertility.com"
    },
    {
      "type": "textarea",
      "id": "ticker_text",
      "label": "Ticker text",
      "default": "✨ Free consultation this month \u00a0•\u00a0 85% success rate \u00a0•\u00a0 10,000+ families helped \u00a0•\u00a0 Certified fertility specialists \u00a0•\u00a0 ✨ Free consultation this month"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
