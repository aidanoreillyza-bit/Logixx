<footer class="lx-ftr" role="contentinfo">
  <div class="lx-container">
    <div class="lx-ftr__grid">

      <!-- Brand column -->
      <div class="lx-ftr__brand">
        <div class="lx-ftr__brand-logo">
          <div class="lx-logo-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
          </div>
          <div class="lx-logo-text">
            <span class="lx-logo-name">LogixX Fertility</span>
            <span class="lx-logo-tagline">Trusted Fertility Supplements</span>
          </div>
        </div>
        {% if section.settings.tagline != blank %}
        <p class="lx-ftr__desc">{{ section.settings.tagline }}</p>
        {% endif %}
        {% if section.settings.partner_badge != blank %}
        <div class="lx-ftr__partner">{{ section.settings.partner_badge }}</div>
        {% endif %}
      </div>

      <!-- Link column 1 -->
      <div class="lx-ftr__col">
        {% if section.settings.col1_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col1_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col1_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col1_title }}">
          {% for link in linklists[section.settings.col1_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Products">
          <a href="/products/proxeed-plus">Proxeed Plus</a>
          <a href="/products/proxeed-men">Proxeed Men</a>
          <a href="/products/proxeed-women">Proxeed Women</a>
          <a href="/products/lenshooke-x1-pro">LensHooke X1 PRO</a>
          <a href="/collections/all">View All Products</a>
        </nav>
        {% endif %}
      </div>

      <!-- Link column 2 -->
      <div class="lx-ftr__col">
        {% if section.settings.col2_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col2_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col2_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col2_title }}">
          {% for link in linklists[section.settings.col2_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Company">
          <a href="/pages/about">About Us</a>
          <a href="/pages/clinical-studies">Clinical Studies</a>
          <a href="/blogs/news">News & Blog</a>
          <a href="/pages/partners">Partners</a>
        </nav>
        {% endif %}
      </div>

      <!-- Link column 3 -->
      <div class="lx-ftr__col">
        {% if section.settings.col3_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col3_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col3_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col3_title }}">
          {% for link in linklists[section.settings.col3_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Support">
          <a href="/pages/contact">Contact Us</a>
          <a href="/pages/faq">FAQs</a>
          <a href="/policies/shipping-policy">Delivery Info</a>
          <a href="/policies/refund-policy">Returns Policy</a>
          <a href="/pages/privacy-policy">Privacy Policy</a>
        </nav>
        {% endif %}
        {% if section.settings.address != blank or section.settings.phone != blank %}
        <div style="margin-top:20px;">
          {% if section.settings.address != blank %}
          <p style="color:rgba(255,255,255,.4);font-size:12px;line-height:1.6;margin-bottom:8px;">{{ section.settings.address }}</p>
          {% endif %}
          {% if section.settings.phone != blank %}
          <a href="tel:{{ section.settings.phone | replace: ' ', '' }}" style="color:rgba(255,255,255,.4);font-size:12px;display:block;margin-bottom:4px;text-decoration:none;">{{ section.settings.phone }}</a>
          {% endif %}
          {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" style="color:rgba(255,255,255,.4);font-size:12px;text-decoration:none;">{{ section.settings.email }}</a>
          {% endif %}
        </div>
        {% endif %}
      </div>

    </div>

    <!-- Copyright bar -->
    <div class="lx-ftr__bar">
      <p class="lx-ftr__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright | default: 'LogixX Pharma Ltd' }}. All rights reserved.
      </p>
      <nav class="lx-ftr__legal" aria-label="Legal links">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
        <a href="/policies/refund-policy">Refund Policy</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings":[
    {"type":"text","id":"tagline","label":"Tagline","default":"Helping families grow with clinically proven fertility supplements since 2009."},
    {"type":"text","id":"partner_badge","label":"Partner badge text","default":"Official Proxeed UK Partner"},
    {"type":"link_list","id":"col1_menu","label":"Column 1 menu","default":"footer"},
    {"type":"text","id":"col1_title","label":"Column 1 title","default":"Products"},
    {"type":"link_list","id":"col2_menu","label":"Column 2 menu","default":"footer"},
    {"type":"text","id":"col2_title","label":"Column 2 title","default":"Company"},
    {"type":"link_list","id":"col3_menu","label":"Column 3 menu","default":"footer"},
    {"type":"text","id":"col3_title","label":"Column 3 title","default":"Support"},
    {"type":"text","id":"copyright","label":"Copyright name","default":"LogixX Pharma Ltd"},
    {"type":"text","id":"address","label":"Address","default":"Merlin House, Brunel Road, Reading, RG7 4AB"},
    {"type":"text","id":"phone","label":"Phone","default":"+44 (0) 1189 011 747"},
    {"type":"text","id":"email","label":"Email","default":"info@logixxpharma.com"}
  ],
  "presets":[{"name":"Footer"}]
}
{% endschema %}
