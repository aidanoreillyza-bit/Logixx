<footer class="site-footer" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="logo footer-logo" aria-label="{{ shop.name }} home">
        <span class="logo-text">Logix<span class="logo-accent">X</span></span>
      </a>
      <p class="footer-tagline">{{ section.settings.tagline }}</p>
      <address class="footer-address" aria-label="Contact information">
        {% if section.settings.phone != blank %}
          <p><a href="tel:{{ section.settings.phone }}">{{ section.settings.phone }}</a></p>
        {% endif %}
        {% if section.settings.email != blank %}
          <p><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
        {% endif %}
        {% if section.settings.address != blank %}
          <p>{{ section.settings.address | newline_to_br }}</p>
        {% endif %}
      </address>
      <div class="footer-social" aria-label="Social media links">
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" aria-label="{{ shop.name }} on Instagram" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" aria-label="{{ shop.name }} on Facebook" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_twitter != blank %}
          <a href="{{ section.settings.social_twitter }}" aria-label="{{ shop.name }} on Twitter / X" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_linkedin != blank %}
          <a href="{{ section.settings.social_linkedin }}" aria-label="{{ shop.name }} on LinkedIn" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'nav_column' %}
        <nav class="footer-nav" aria-label="{{ block.settings.title }} navigation" {{ block.shopify_attributes }}>
          <h3 class="footer-nav-title">{{ block.settings.title }}</h3>
          <ul>
            {% if block.settings.link_1_label != blank %}<li><a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a></li>{% endif %}
            {% if block.settings.link_2_label != blank %}<li><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a></li>{% endif %}
            {% if block.settings.link_3_label != blank %}<li><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a></li>{% endif %}
            {% if block.settings.link_4_label != blank %}<li><a href="{{ block.settings.link_4_url }}">{{ block.settings.link_4_label }}</a></li>{% endif %}
            {% if block.settings.link_5_label != blank %}<li><a href="{{ block.settings.link_5_url }}">{{ block.settings.link_5_label }}</a></li>{% endif %}
            {% if block.settings.link_6_label != blank %}<li><a href="{{ block.settings.link_6_url }}">{{ block.settings.link_6_label }}</a></li>{% endif %}
            {% if block.settings.link_7_label != blank %}<li><a href="{{ block.settings.link_7_url }}">{{ block.settings.link_7_label }}</a></li>{% endif %}
          </ul>
        </nav>
      {% endif %}
    {% endfor %}
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name }}. All rights reserved.</p>
      <nav class="footer-legal" aria-label="Legal navigation">
        <a href="{{ pages['privacy-policy'].url | default: '#' }}">Privacy Policy</a>
        <a href="{{ pages['terms-of-use'].url | default: '#' }}">Terms of Use</a>
        <a href="{{ pages['cookie-policy'].url | default: '#' }}">Cookie Policy</a>
        <a href="{{ pages['accessibility'].url | default: '#' }}">Accessibility</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Helping families grow since 2009. Expert fertility care you can trust." },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 (800) 555-6789" },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@logixxfertility.com" },
    { "type": "textarea", "id": "address", "label": "Address", "default": "123 Fertility Way, Suite 400\nNew York, NY 10001" },
    { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "url", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "url", "id": "social_twitter", "label": "Twitter / X URL" },
    { "type": "url", "id": "social_linkedin", "label": "LinkedIn URL" },
    { "type": "text", "id": "copyright_name", "label": "Copyright name", "default": "LogixX Fertility Ltd" }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "Links" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" }, { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" }, { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" }, { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" }, { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" }, { "type": "url", "id": "link_5_url", "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_label", "label": "Link 6 label" }, { "type": "url", "id": "link_6_url", "label": "Link 6 URL" },
        { "type": "text", "id": "link_7_label", "label": "Link 7 label" }, { "type": "url", "id": "link_7_url", "label": "Link 7 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "nav_column",
          "settings": {
            "title": "Treatments",
            "link_1_label": "IVF", "link_2_label": "IUI", "link_3_label": "Egg Freezing",
            "link_4_label": "Sperm Freezing", "link_5_label": "Donor Programmes",
            "link_6_label": "Genetic Testing (PGT)", "link_7_label": "Surrogacy Support"
          }
        },
        {
          "type": "nav_column",
          "settings": {
            "title": "Products",
            "link_1_label": "FertilBoost Pro", "link_2_label": "MaleVital Max",
            "link_3_label": "OvuTrack Home Kit", "link_4_label": "HormoneHarmony",
            "link_5_label": "Couples Bundle", "link_6_label": "SpermCheck Home Test"
          }
        },
        {
          "type": "nav_column",
          "settings": {
            "title": "Company",
            "link_1_label": "About Us", "link_2_label": "Our Team",
            "link_3_label": "Success Rates", "link_4_label": "Blog & Resources",
            "link_5_label": "Careers", "link_6_label": "Press", "link_7_label": "Contact Us"
          }
        }
      ]
    }
  ]
}
{% endschema %}
