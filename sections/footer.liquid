<footer class="lx-ftr" role="contentinfo">
  <div class="lx-container">
    <div class="lx-ftr__grid">

      <!-- Brand column -->
      <div class="lx-ftr__brand">
        <div class="lx-ftr__brand-logo">
          <div class="lx-logo-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
          </div>
          <div class="lx-logo-text">
            <span class="lx-logo-name">LogixX Fertility</span>
            <span class="lx-logo-tagline">Trusted Fertility Supplements</span>
          </div>
        </div>
        {% if section.settings.tagline != blank %}
        <p class="lx-ftr__desc">{{ section.settings.tagline }}</p>
        {% endif %}
        {% if section.settings.partner_badge != blank %}
        <div class="lx-ftr__partner">{{ section.settings.partner_badge }}</div>
        {% endif %}
        <div class="lx-ftr__socials" aria-label="Social media links">
          {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" class="lx-ftr__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          {% endif %}
          {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" class="lx-ftr__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          {% endif %}
          {% if section.settings.social_twitter != blank %}
          <a href="{{ section.settings.social_twitter }}" class="lx-ftr__social-link" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.629L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/></svg>
          </a>
          {% endif %}
          {% if section.settings.social_linkedin != blank %}
          <a href="{{ section.settings.social_linkedin }}" class="lx-ftr__social-link" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          {% endif %}
          {% if section.settings.social_youtube != blank %}
          <a href="{{ section.settings.social_youtube }}" class="lx-ftr__social-link" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          {% endif %}
        </div>
      </div>

      <!-- Link column 1 -->
      <div class="lx-ftr__col">
        {% if section.settings.col1_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col1_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col1_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col1_title }}">
          {% for link in linklists[section.settings.col1_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Products">
          <a href="/products/proxeed-plus">Proxeed Plus</a>
          <a href="/products/proxeed-men">Proxeed Men</a>
          <a href="/products/proxeed-women">Proxeed Women</a>
          <a href="/products/lenshooke-x1-pro">LensHooke X1 PRO</a>
          <a href="/collections/all">View All Products</a>
        </nav>
        {% endif %}
      </div>

      <!-- Link column 2 -->
      <div class="lx-ftr__col">
        {% if section.settings.col2_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col2_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col2_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col2_title }}">
          {% for link in linklists[section.settings.col2_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Company">
          <a href="/pages/about">About Us</a>
          <a href="/pages/clinical-studies">Clinical Studies</a>
          <a href="/blogs/news">News & Blog</a>
          <a href="/pages/partners">Partners</a>
        </nav>
        {% endif %}
      </div>

      <!-- Link column 3 -->
      <div class="lx-ftr__col">
        {% if section.settings.col3_title != blank %}
        <h4 class="lx-ftr__col-title">{{ section.settings.col3_title }}</h4>
        {% endif %}
        {% if linklists[section.settings.col3_menu] != blank %}
        <nav class="lx-ftr__links" aria-label="{{ section.settings.col3_title }}">
          {% for link in linklists[section.settings.col3_menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% endfor %}
        </nav>
        {% else %}
        <nav class="lx-ftr__links" aria-label="Support">
          <a href="/pages/contact">Contact Us</a>
          <a href="/pages/faq">FAQs</a>
          <a href="/policies/shipping-policy">Delivery Info</a>
          <a href="/policies/refund-policy">Returns Policy</a>
          <a href="/pages/privacy-policy">Privacy Policy</a>
        </nav>
        {% endif %}
        {% if section.settings.address != blank or section.settings.phone != blank %}
        <div class="lx-ftr__contact">
          {% if section.settings.address != blank %}
          <p class="lx-ftr__contact-addr">{{ section.settings.address }}</p>
          {% endif %}
          {% if section.settings.phone != blank %}
          <a href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}" class="lx-ftr__contact-link">{{ section.settings.phone }}</a>
          {% endif %}
          {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" class="lx-ftr__contact-link">{{ section.settings.email }}</a>
          {% endif %}
        </div>
        {% endif %}
      </div>

    </div>

    <!-- Copyright bar -->
    <div class="lx-ftr__bar">
      <p class="lx-ftr__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright | default: 'LogixX Pharma Ltd' }}. All rights reserved.
      </p>
      <nav class="lx-ftr__legal" aria-label="Legal links">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
        <a href="/policies/refund-policy">Refund Policy</a>
      </nav>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings":[
    {"type":"text","id":"tagline","label":"Tagline","default":"Helping families grow with clinically proven fertility supplements since 2009."},
    {"type":"text","id":"partner_badge","label":"Partner badge text","default":"Official Proxeed UK Partner"},
    {"type":"link_list","id":"col1_menu","label":"Column 1 menu","default":"footer"},
    {"type":"text","id":"col1_title","label":"Column 1 title","default":"Products"},
    {"type":"link_list","id":"col2_menu","label":"Column 2 menu","default":"footer"},
    {"type":"text","id":"col2_title","label":"Column 2 title","default":"Company"},
    {"type":"link_list","id":"col3_menu","label":"Column 3 menu","default":"footer"},
    {"type":"text","id":"col3_title","label":"Column 3 title","default":"Support"},
    {"type":"text","id":"copyright","label":"Copyright name","default":"LogixX Pharma Ltd"},
    {"type":"text","id":"address","label":"Address","default":"Merlin House, Brunel Road, Reading, RG7 4AB"},
    {"type":"text","id":"phone","label":"Phone","default":"+44 (0) 1189 011 747"},
    {"type":"text","id":"email","label":"Email","default":"info@logixxpharma.com"},
    {"type":"url","id":"social_instagram","label":"Instagram URL"},
    {"type":"url","id":"social_facebook","label":"Facebook URL"},
    {"type":"url","id":"social_twitter","label":"X / Twitter URL"},
    {"type":"url","id":"social_linkedin","label":"LinkedIn URL"},
    {"type":"url","id":"social_youtube","label":"YouTube URL"}
  ],
  "presets":[{"name":"Footer"}]
}
{% endschema %}
