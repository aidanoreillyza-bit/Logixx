<section style="background:#0f1f3a;padding:96px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;text-align:center;">

    <!-- Header -->
    <div style="margin-bottom:56px;">
      <div style="display:inline-block;font-size:11px;font-weight:700;color:#00B8D4;text-transform:uppercase;letter-spacing:.1em;margin-bottom:16px;">The Process</div>
      <h2 style="font-family:'Instrument Serif',serif;font-size:clamp(2rem,4vw,2.75rem);color:#fff;margin:0 0 16px;line-height:1.15;">
        How it <em style="color:#00B8D4;font-style:italic;">works</em>
      </h2>
      <p style="color:rgba(255,255,255,.65);font-size:16px;margin:0;">Four simple steps to support your fertility journey</p>
    </div>

    <!-- Steps row -->
    <div style="display:flex;align-items:flex-start;justify-content:center;gap:0;margin-bottom:56px;">

      <!-- Step 1 -->
      <div style="display:flex;flex-direction:column;align-items:center;flex:1;max-width:220px;">
        <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#00B8D4,#0095AD);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-family:'Instrument Serif',serif;font-size:28px;color:#fff;line-height:1;">1</span>
        </div>
        <div style="margin-top:20px;font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:10px;">Get Tested</div>
        <p style="font-size:13px;color:rgba(255,255,255,.6);max-width:180px;text-align:center;margin:0;line-height:1.6;">Start with CASA-grade semen analysis using LensHooke X1 PRO for a full picture of sperm health.</p>
      </div>

      <!-- Connector 1→2 -->
      <div style="flex:1;height:2px;border-top:2px dashed rgba(0,184,212,.3);margin-top:36px;"></div>

      <!-- Step 2 -->
      <div style="display:flex;flex-direction:column;align-items:center;flex:1;max-width:220px;">
        <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#00B8D4,#0095AD);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-family:'Instrument Serif',serif;font-size:28px;color:#fff;line-height:1;">2</span>
        </div>
        <div style="margin-top:20px;font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:10px;">Assess Stress</div>
        <p style="font-size:13px;color:rgba(255,255,255,.6);max-width:180px;text-align:center;margin:0;line-height:1.6;">MiOXSYS identifies oxidative stress — a factor in up to 40% of male infertility cases.</p>
      </div>

      <!-- Connector 2→3 -->
      <div style="flex:1;height:2px;border-top:2px dashed rgba(0,184,212,.3);margin-top:36px;"></div>

      <!-- Step 3 -->
      <div style="display:flex;flex-direction:column;align-items:center;flex:1;max-width:220px;">
        <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#00B8D4,#0095AD);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-family:'Instrument Serif',serif;font-size:28px;color:#fff;line-height:1;">3</span>
        </div>
        <div style="margin-top:20px;font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:10px;">Supplement</div>
        <p style="font-size:13px;color:rgba(255,255,255,.6);max-width:180px;text-align:center;margin:0;line-height:1.6;">Proxeed provides targeted nutrients across a 90-day sperm maturation cycle for measurable results.</p>
      </div>

      <!-- Connector 3→4 -->
      <div style="flex:1;height:2px;border-top:2px dashed rgba(0,184,212,.3);margin-top:36px;"></div>

      <!-- Step 4 -->
      <div style="display:flex;flex-direction:column;align-items:center;flex:1;max-width:220px;">
        <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#00B8D4,#0095AD);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <span style="font-family:'Instrument Serif',serif;font-size:28px;color:#fff;line-height:1;">4</span>
        </div>
        <div style="margin-top:20px;font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:10px;">Monitor Progress</div>
        <p style="font-size:13px;color:rgba(255,255,255,.6);max-width:180px;text-align:center;margin:0;line-height:1.6;">Track improvements alongside lifestyle changes and professional guidance from our team.</p>
      </div>

    </div>

    <!-- CTA -->
    <a href="/collections/all"
       style="display:inline-block;padding:14px 36px;background:#00B8D4;color:#fff;border-radius:100px;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:15px;text-decoration:none;letter-spacing:.01em;">
      Shop Products
    </a>

  </div>
</section>

