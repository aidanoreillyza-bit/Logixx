<section class="lx-spotlight lx-spotlight--women">
  <div class="lx-container">
    <div class="lx-spotlight__grid lx-spotlight__grid--reverse">

      <!-- Content column (left on desktop) -->
      <div class="lx-spotlight__content lx-fade-in">

        {% if section.settings.label != blank %}
        <span class="lx-badge lx-badge--rose">{{ section.settings.label }}</span>
        {% endif %}

        <h2 class="lx-spotlight__title lx-spotlight__title--women">
          {{ section.settings.heading | default: 'Proxeed Women' | newline_to_br }}
        </h2>

        {% if section.settings.subtext != blank %}
        <p class="lx-spotlight__sub">{{ section.settings.subtext }}</p>
        {% endif %}

        {% if section.settings.benefit_1 != blank or section.settings.benefit_2 != blank or section.settings.benefit_3 != blank or section.settings.benefit_4 != blank %}
        <ul class="lx-spotlight__benefits lx-spotlight__benefits--women" aria-label="Key benefits">
          {% assign benefits = section.settings.benefit_1 | append: '|||' | append: section.settings.benefit_2 | append: '|||' | append: section.settings.benefit_3 | append: '|||' | append: section.settings.benefit_4 %}
          {% assign benefits_arr = benefits | split: '|||' %}
          {% for b in benefits_arr %}
            {% if b != blank %}
            <li>
              <span class="lx-spotlight__benefit-icon lx-spotlight__benefit-icon--women" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              {{ b }}
            </li>
            {% endif %}
          {% endfor %}
        </ul>
        {% endif %}

        {% if section.settings.price != blank %}
        <div class="lx-spotlight__price-row">
          <span class="lx-spotlight__price">{{ section.settings.price }}</span>
          {% if section.settings.price_note != blank %}
          <span class="lx-spotlight__price-note">{{ section.settings.price_note }}</span>
          {% endif %}
        </div>
        {% endif %}

        <div class="lx-spotlight__btns">
          {% if section.settings.cta_label != blank %}
          <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lx-btn lx-btn--rose lx-btn--lg">
            {{ section.settings.cta_label }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {% endif %}
          {% if section.settings.sec_label != blank %}
          <a href="{{ section.settings.sec_url | default: '/collections/all' }}" class="lx-btn lx-btn--ghost-navy">
            {{ section.settings.sec_label }}
          </a>
          {% endif %}
        </div>

        {% if section.settings.trust_note != blank %}
        <p class="lx-spotlight__trust-note lx-spotlight__trust-note--women">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622C17.176 19.29 21 14.591 21 9a12.02 12.02 0 0 0-.382-3.016z"/></svg>
          {{ section.settings.trust_note }}
        </p>
        {% endif %}

      </div>

      <!-- Image column (right on desktop) -->
      <div class="lx-spotlight__img-col lx-fade-in">
        <div class="lx-spotlight__img-wrap lx-spotlight__img-wrap--women">
          <div class="lx-spotlight__img-orb lx-spotlight__img-orb--w1" aria-hidden="true"></div>
          <div class="lx-spotlight__img-orb lx-spotlight__img-orb--w2" aria-hidden="true"></div>
          {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | img_url: '600x' }}"
            srcset="{{ section.settings.image | img_url: '400x' }} 400w,
                    {{ section.settings.image | img_url: '600x' }} 600w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="{{ section.settings.image_alt | default: 'Proxeed Women' }}"
            loading="lazy"
            width="600"
            height="600"
            class="lx-spotlight__img"
          >
          {% else %}
          {{ 'product-2' | placeholder_svg_tag: 'lx-spotlight__img lx-spotlight__img--placeholder' }}
          {% endif %}
          {% if section.settings.badge != blank %}
          <span class="lx-spotlight__float-badge lx-spotlight__float-badge--women">{{ section.settings.badge }}</span>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
/* ── Proxeed Women Spotlight ─────────────────────────────────── */
.lx-spotlight--women {
  background: linear-gradient(135deg, #fff5f7 0%, #fff 60%);
}
.lx-spotlight__grid--reverse {
  grid-template-columns: 1fr 1fr;
}
@media (max-width: 860px) {
  .lx-spotlight__grid--reverse { grid-template-columns: 1fr; }
  .lx-spotlight__grid--reverse .lx-spotlight__img-col { order: -1; }
}

/* Women image wrap */
.lx-spotlight__img-wrap--women {
  background: linear-gradient(135deg, #fff0f4 0%, #fff 100%);
  box-shadow: 0 12px 48px rgba(219,77,109,.1);
}
.lx-spotlight__img-orb--w1 {
  position: absolute;
  width: 280px; height: 280px;
  top: -60px; left: -60px;
  background: radial-gradient(circle, rgba(219,77,109,.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.lx-spotlight__img-orb--w2 {
  position: absolute;
  width: 180px; height: 180px;
  bottom: -40px; right: -40px;
  background: radial-gradient(circle, rgba(219,77,109,.08) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* Women title */
.lx-spotlight__title--women { color: var(--c-navy, #0a1628); }

/* Women badge */
.lx-badge--rose {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  background: rgba(219,77,109,.1);
  color: #c0394f;
  border: 1px solid rgba(219,77,109,.25);
  border-radius: 50px;
  padding: 4px 12px;
}

/* Women benefit icon */
.lx-spotlight__benefit-icon--women {
  background: #db4d6d;
}

/* Women CTA button */
.lx-btn--rose {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .04em;
  padding: 14px 28px;
  border-radius: 50px;
  border: 2px solid #db4d6d;
  background: linear-gradient(120deg, #db4d6d 0%, #e8647e 100%);
  color: #fff;
  text-decoration: none;
  cursor: pointer;
  transition: transform .18s, box-shadow .18s, background .18s;
}
.lx-btn--rose:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(219,77,109,.35);
  background: linear-gradient(120deg, #c73f5e 0%, #db4d6d 100%);
}

/* Women float badge */
.lx-spotlight__float-badge--women {
  background: #db4d6d;
  color: #fff;
}

/* Women trust note */
.lx-spotlight__trust-note--women svg { color: #db4d6d; }
</style>

{% schema %}
{
  "name": "Proxeed Women",
  "settings": [
    {"type":"image_picker","id":"image","label":"Product Image"},
    {"type":"text","id":"image_alt","label":"Image Alt Text","default":"Proxeed Women female fertility supplement"},
    {"type":"text","id":"label","label":"Label Badge","default":"For Women"},
    {"type":"text","id":"badge","label":"Image Badge (e.g. New)","default":"Clinically Proven"},
    {"type":"textarea","id":"heading","label":"Heading","default":"Proxeed Women\nFemale Fertility Supplement"},
    {"type":"textarea","id":"subtext","label":"Description","default":"Specially formulated to support female reproductive health and egg quality. A comprehensive blend of myo-inositol, folate, CoQ10 and key micronutrients — clinically developed for women trying to conceive."},
    {"type":"text","id":"benefit_1","label":"Benefit 1","default":"Supports egg quality and ovarian function"},
    {"type":"text","id":"benefit_2","label":"Benefit 2","default":"Myo-inositol formula for hormonal balance"},
    {"type":"text","id":"benefit_3","label":"Benefit 3","default":"Contains active folate (5-MTHF) for early pregnancy"},
    {"type":"text","id":"benefit_4","label":"Benefit 4","default":"Halal certified · GMP manufactured"},
    {"type":"text","id":"price","label":"Price Display (e.g. £34.99)","default":"£34.99"},
    {"type":"text","id":"price_note","label":"Price Note","default":"per month's supply"},
    {"type":"text","id":"cta_label","label":"Primary Button","default":"Shop Proxeed Women"},
    {"type":"url","id":"cta_url","label":"Primary Button Link"},
    {"type":"text","id":"sec_label","label":"Secondary Button (optional)","default":"Learn More"},
    {"type":"url","id":"sec_url","label":"Secondary Button Link"},
    {"type":"text","id":"trust_note","label":"Trust Note","default":"Free UK delivery over £50 · Discreet packaging · 30-day returns"}
  ],
  "presets": [{"name": "Proxeed Women"}]
}
{% endschema %}
