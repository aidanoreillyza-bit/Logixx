    <div class="pw-split__orb2"></div>
    <img src="https://images.squarespace-cdn.com/content/v1/5d8cffaba966fa1d97ea52f9/1571952887522-TFJQE56JS1SHZPVYWJRR/Proxeed-Women-logo.jpg" alt="Proxeed Women">
    <div class="pw-split__logo-badge">
      <img src="https://images.squarespace-cdn.com/content/v1/5d8cffaba966fa1d97ea52f9/1571952887522-TFJQE56JS1SHZPVYWJRR/Proxeed-Women-logo.jpg" alt="Proxeed Women Logo">
      <span>Support oocyte quality and fertility</span>
    </div>
  </div>
</div>