<section style="background:#fff;padding:80px 0">
<div style="max-width:1240px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">

  <!-- Text side (left) -->
  <div>
    <div style="font-size:11px;font-weight:700;color:#d4608a;text-transform:uppercase;letter-spacing:.12em;margin-bottom:14px">Female Fertility</div>
    <h2 style="font-family:'Instrument Serif',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:400;color:#0a1628;margin-bottom:20px;line-height:1.1">Proxeed <em style="font-style:italic;color:#d4608a">Women</em></h2>
    <p style="font-size:16px;color:#3b4758;line-height:1.8;margin-bottom:28px">Proxeed Women is a premium female fertility supplement designed to support egg quality and overall reproductive health. Combining clinically supported nutrients, it helps optimise a woman's natural fertility and prepares the body for conception.</p>
    <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:28px">
      <div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758">
        <div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#d4608a;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <span><strong>Myo-Inositol &amp; D-chiro-inositol</strong> — supports healthy egg maturation and hormonal balance</span>
      </div>
      <div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758">
        <div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#d4608a;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <span><strong>Coenzyme Q10</strong> — powerful antioxidant that supports mitochondrial function in oocytes</span>
      </div>
      <div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758">
        <div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#d4608a;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <span><strong>Folic Acid &amp; Vitamin D</strong> — essential for early foetal development and immune health</span>
      </div>
      <div style="display:flex;align-items:center;gap:12px;font-size:14.5px;color:#3b4758">
        <div style="width:22px;height:22px;min-width:22px;border-radius:50%;background:#d4608a;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <span><strong>L-carnitine</strong> — supports cellular energy production to fuel healthy egg development</span>
      </div>
    </div>
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:24px">
      <span style="font-family:'Instrument Serif',Georgia,serif;font-size:2.2rem;font-weight:400;color:#0a1628">£34.99</span>
      <span style="font-size:15px;color:#6b7485;text-decoration:line-through">£44.99</span>
      <span style="font-size:11px;font-weight:700;color:#fff;background:#ff4d5f;padding:3px 10px;border-radius:100px">Save £10</span>
    </div>
    <div style="display:flex;gap:12px;flex-wrap:wrap">
      <a href="/products/proxeed-women" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#d4608a;color:#fff;border-radius:100px;font-weight:700;font-size:15px;text-decoration:none;box-shadow:0 6px 20px rgba(212,96,138,.3)">Shop Proxeed Women →</a>
      <a href="/pages/female-fertility" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#fff;color:#0a1628;border-radius:100px;font-weight:600;font-size:15px;text-decoration:none;border:1.5px solid #eaecf0">Learn More</a>
    </div>
  </div>

  <!-- Image side (right) -->
  <div style="position:relative;border-radius:28px;background:linear-gradient(135deg,#fff0f5,#fce4ef);min-height:460px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;padding:40px;overflow:hidden">
    <div style="position:absolute;top:-20px;left:-20px;width:140px;height:140px;border-radius:50%;background:radial-gradient(circle,rgba(212,96,138,.2),transparent 70%)"></div>
    <div style="position:absolute;bottom:-20px;right:-20px;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(212,96,138,.12),transparent 70%)"></div>
    {% if section.settings.image %}
    <img src="{{ section.settings.image | image_url: width: 600 }}" alt="Proxeed Women" style="max-height:260px;max-width:80%;object-fit:contain;position:relative;z-index:2;filter:drop-shadow(0 12px 32px rgba(0,0,0,.12))">
    {% else %}
    <div style="width:180px;height:180px;border-radius:24px;background:rgba(212,96,138,.08);border:2px dashed rgba(212,96,138,.3);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;position:relative;z-index:2">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d4608a" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="opacity:.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      <span style="font-size:12px;font-weight:600;color:#d4608a;opacity:.7">Upload product image</span>
    </div>
    {% endif %}
    <div style="background:#fff;border-radius:16px;padding:18px 24px;text-align:center;box-shadow:0 6px 24px rgba(212,96,138,.12);position:relative;z-index:2">
      <div style="font-size:11px;font-weight:700;color:#fff;background:#d4608a;padding:4px 14px;border-radius:100px;display:inline-block;margin-bottom:10px;letter-spacing:.06em;text-transform:uppercase">For Women</div>
      <div style="font-family:'Instrument Serif',Georgia,serif;font-size:1.5rem;margin-bottom:4px"><span style="color:#d4608a;font-weight:700">Pro</span><span style="color:#0a1628">xeed</span><sup style="font-size:.5em;vertical-align:super">®</sup> <span style="font-size:.9rem;font-weight:700;color:#0a1628;letter-spacing:.06em">WOMEN</span></div>
      <div style="font-size:11px;color:#d4608a;font-weight:600;text-transform:uppercase;letter-spacing:.08em">Female Fertility Supplement</div>
    </div>
  </div>

</div>
</section>

{% schema %}
{
  "name": "Proxeed Women",
  "settings": [
    {"type": "image_picker", "id": "image", "label": "Product Image"}
  ],
  "presets": [{"name": "Proxeed Women"}]
}
{% endschema %}

