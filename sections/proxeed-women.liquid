<style>
.pw-split{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;padding:80px 40px;max-width:1240px;margin:0 auto}
.pw-split__label{font-size:11px;font-weight:700;color:#d4589a;text-transform:uppercase;letter-spacing:.12em;margin-bottom:14px}
.pw-split h2{font-family:'Instrument Serif',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:400;color:#0a1628;margin-bottom:20px;line-height:1.1;letter-spacing:-.02em}
.pw-split h2 em{font-style:italic;color:#d4589a}
.pw-split__text{font-size:16px;color:#3b4758;line-height:1.8;margin-bottom:28px}
.pw-split__benefits{display:flex;flex-direction:column;gap:12px;margin-bottom:32px}
.pw-split__benefit{display:flex;align-items:flex-start;gap:12px;font-size:14.5px;color:#3b4758;line-height:1.6}
.pw-split__benefit-dot{width:22px;height:22px;min-width:22px;border-radius:50%;background:linear-gradient(135deg,#d4589a,#b03a7a);display:flex;align-items:center;justify-content:center;margin-top:2px}
.pw-split__benefit-dot svg{width:11px;height:11px;stroke:#fff;fill:none;stroke-width:3;stroke-linecap:round;stroke-linejoin:round;display:block}
.pw-split__btn{display:inline-flex;align-items:center;gap:10px;padding:15px 32px;background:linear-gradient(135deg,#d4589a,#b03a7a);color:#fff;border-radius:100px;font-weight:700;font-size:15px;text-decoration:none;box-shadow:0 8px 28px rgba(212,88,154,.3);transition:all .25s}
.pw-split__btn:hover{transform:translateY(-2px);box-shadow:0 14px 36px rgba(212,88,154,.42)}
.pw-split__img-wrap{position:relative;border-radius:28px;overflow:hidden;background:linear-gradient(135deg,#fdf0f7,#f9e0f2);min-height:460px;display:flex;align-items:center;justify-content:center}
.pw-split__img-wrap img{width:100%;height:100%;object-fit:cover;border-radius:28px}
.pw-split__logo-badge{position:absolute;bottom:24px;right:24px;background:#fff;border-radius:16px;padding:14px 18px;box-shadow:0 8px 24px rgba(0,0,0,.1);display:flex;flex-direction:column;align-items:center}
.pw-split__logo-badge img{max-width:140px;height:auto}
.pw-split__logo-badge span{font-size:11px;color:#6b7485;margin-top:4px;font-weight:500}
.pw-split__orb1{position:absolute;top:-20px;left:-20px;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(212,88,154,.15),transparent 70%)}
.pw-split__orb2{position:absolute;bottom:-20px;right:-20px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(212,88,154,.1),transparent 70%)}
@media(max-width:900px){.pw-split{grid-template-columns:1fr;padding:48px 24px}.pw-split__img-wrap{min-height:320px}}
</style>
 
<div class="pw-split">
