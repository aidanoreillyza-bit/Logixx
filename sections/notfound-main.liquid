<section class="lx-404">

  {% if section.settings.bg_image %}
  <div class="lx-404__bg">
    {{ section.settings.bg_image | image_url: width: 1920 | image_tag: loading: 'eager', class: 'lx-404__bg-img' }}
  </div>
  {% endif %}

  <div class="lx-404__overlay"></div>

  <div class="lx-404__content">
    <div aria-hidden="true" class="lx-404__number">404</div>
    <h1 class="lx-404__heading">{{ section.settings.heading }}</h1>
    <p class="lx-404__message">{{ section.settings.message }}</p>
    <a href="{{ section.settings.btn_url | default: '/' }}" class="lx-btn lx-btn--mint lx-btn--lg">
      {{ section.settings.btn_label }}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {"type":"image_picker","id":"bg_image","label":"Background Image"},
    {"type":"text","id":"heading","label":"Heading","default":"Page not found"},
    {"type":"textarea","id":"message","label":"Message","default":"Sorry, the page you were looking for doesn't exist or may have moved."},
    {"type":"text","id":"btn_label","label":"Button text","default":"Back to Home"},
    {"type":"url","id":"btn_url","label":"Button URL","default":"/"}
  ],
  "presets":[{"name":"404"}]
}
{% endschema %}
