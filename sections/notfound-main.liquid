<section style="min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;">

  {% if section.settings.bg_image %}
    <div style="position:absolute;inset:0;">
      {{ section.settings.bg_image | image_url: width: 1920 | image_tag: loading: 'eager', style: 'width:100%;height:100%;object-fit:cover;' }}
    </div>
  {% endif %}

  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(8,20,40,.85),rgba(8,20,40,.6));"></div>

  <div style="position:relative;z-index:2;text-align:center;color:#fff;padding:2rem;">
    <div aria-hidden="true" style="font-family:'Instrument Serif',serif;font-size:3rem;color:#00B8D4;line-height:1;margin-bottom:8px;">404</div>
    <h1 style="font-size:2rem;color:#fff;margin-bottom:16px;">{{ section.settings.heading }}</h1>
    <p style="color:rgba(255,255,255,.7);margin-bottom:32px;">{{ section.settings.message }}</p>
    <a href="{{ section.settings.btn_url | default: '/' }}" style="background:#00B8D4;color:#fff;padding:14px 32px;border-radius:100px;border:none;font-size:16px;font-weight:600;text-decoration:none;display:inline-block;">
      {{ section.settings.btn_label }}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "404",
  "settings": [
    {"type":"image_picker","id":"bg_image","label":"Background Image"},
    {"type":"text","id":"heading","label":"Heading","default":"Page not found"},
    {"type":"textarea","id":"message","label":"Message","default":"Sorry, the page you were looking for doesn't exist or may have moved."},
    {"type":"text","id":"btn_label","label":"Button text","default":"Back to Home"},
    {"type":"url","id":"btn_url","label":"Button URL","default":"/"}
  ],
  "presets":[{"name":"404"}]
}
{% endschema %}
