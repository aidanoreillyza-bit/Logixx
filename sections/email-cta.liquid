<section class="email-cta-section" id="email-cta" aria-labelledby="email-cta-heading">
  <div class="container email-cta-grid">
    <div class="email-cta-content">
      <span class="section-badge section-badge--light">{{ section.settings.badge_text }}</span>
      <h2 class="section-title section-title--light" id="email-cta-heading">{{ section.settings.heading }}</h2>
      <p class="email-cta-body">{{ section.settings.body_text }}</p>
      <ul class="email-cta-perks" aria-label="What you'll receive">
        {% if section.settings.perk_1 != blank %}
          <li>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {{ section.settings.perk_1 }}
          </li>
        {% endif %}
        {% if section.settings.perk_2 != blank %}
          <li>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {{ section.settings.perk_2 }}
          </li>
        {% endif %}
        {% if section.settings.perk_3 != blank %}
          <li>
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            {{ section.settings.perk_3 }}
          </li>
        {% endif %}
      </ul>
    </div>
    <div class="email-cta-form-wrap">
      {% form 'contact', contact, id: 'subscribe-form', class: 'email-cta-form', novalidate: true, aria-label: 'Newsletter signup form' %}
        {% if form.posted_successfully? %}
          <div class="form-success" role="alert" aria-live="polite">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>You're in! Check your inbox for your free fertility guide.</span>
          </div>
        {% else %}
          <div class="form-group">
            <label for="email-input" class="form-label">Email address</label>
            <input
              type="email"
              id="email-input"
              name="contact[email]"
              class="form-input"
              placeholder="you@example.com"
              autocomplete="email"
              required
              aria-required="true"
              aria-describedby="email-error"
            />
            <span class="form-error" id="email-error" role="alert" aria-live="polite">
              {{ form.errors | default_errors }}
            </span>
          </div>
          <div class="form-group">
            <label for="first-name-input" class="form-label">First name <span class="form-optional">(optional)</span></label>
            <input type="text" id="first-name-input" name="contact[first_name]" class="form-input" placeholder="Your first name" autocomplete="given-name" />
          </div>
          <button type="submit" class="btn btn-primary btn-full btn-lg">
            <span class="btn-text">{{ section.settings.submit_label }}</span>
          </button>
          <p class="form-privacy">No spam, ever. Unsubscribe any time. <a href="{{ pages['privacy-policy'].url | default: '#' }}">Privacy Policy</a>.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email CTA",
  "settings": [
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Free Consultation" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Start your fertility journey today" },
    { "type": "textarea", "id": "body_text", "label": "Body text", "default": "Join thousands of families who have trusted LogixX. Enter your email to receive our free fertility guide and book your complimentary consultation." },
    { "type": "text", "id": "perk_1", "label": "Perk 1", "default": "Free 60-minute fertility consultation" },
    { "type": "text", "id": "perk_2", "label": "Perk 2", "default": "Personalised fertility guide (PDF)" },
    { "type": "text", "id": "perk_3", "label": "Perk 3", "default": "Exclusive product discounts" },
    { "type": "text", "id": "submit_label", "label": "Submit button text", "default": "Get My Free Guide" }
  ],
  "presets": [
    { "name": "Email CTA" }
  ]
}
{% endschema %}
