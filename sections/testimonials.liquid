<section class="lx-testi">
  <div class="lx-container">
    <div class="lx-section-head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
      <h2>{{ section.settings.heading | newline_to_br }}</h2>
      {% endif %}
    </div>

    <div class="lx-testi__grid">

      <div class="lx-testi__summary lx-fade-in" aria-label="Aggregate rating summary">
        <div class="lx-testi__summary-score" aria-hidden="true">4.9</div>
        <div class="lx-testi__summary-mid">
          <div class="lx-testi__summary-stars" aria-label="5 out of 5 stars">★★★★★</div>
          <div class="lx-testi__summary-count">2,400+ verified reviews</div>
        </div>
        <div class="lx-testi__summary-bars" aria-hidden="true">
          <div class="lx-testi__summary-bar">
            <span class="lx-testi__summary-bar-lbl">5★</span>
            <div class="lx-testi__summary-bar-track"><div class="lx-testi__summary-bar-fill lx-testi__summary-bar-fill--87"></div></div>
            <span class="lx-testi__summary-bar-pct">87%</span>
          </div>
          <div class="lx-testi__summary-bar">
            <span class="lx-testi__summary-bar-lbl">4★</span>
            <div class="lx-testi__summary-bar-track"><div class="lx-testi__summary-bar-fill lx-testi__summary-bar-fill--9"></div></div>
            <span class="lx-testi__summary-bar-pct">9%</span>
          </div>
          <div class="lx-testi__summary-bar">
            <span class="lx-testi__summary-bar-lbl">3★</span>
            <div class="lx-testi__summary-bar-track"><div class="lx-testi__summary-bar-fill lx-testi__summary-bar-fill--3"></div></div>
            <span class="lx-testi__summary-bar-pct">3%</span>
          </div>
          <div class="lx-testi__summary-bar">
            <span class="lx-testi__summary-bar-lbl">2★</span>
            <div class="lx-testi__summary-bar-track"><div class="lx-testi__summary-bar-fill lx-testi__summary-bar-fill--1"></div></div>
            <span class="lx-testi__summary-bar-pct">1%</span>
          </div>
        </div>
      </div>
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
        <article class="lx-testi__card lx-fade-in" {{ block.shopify_attributes }}>
          <div class="lx-testi__stars" aria-label="5 stars">
            <span class="lx-testi__star" aria-hidden="true">★</span>
            <span class="lx-testi__star" aria-hidden="true">★</span>
            <span class="lx-testi__star" aria-hidden="true">★</span>
            <span class="lx-testi__star" aria-hidden="true">★</span>
            <span class="lx-testi__star" aria-hidden="true">★</span>
          </div>
          {% if block.settings.quote != blank %}
          <blockquote class="lx-testi__quote">"{{ block.settings.quote }}"</blockquote>
          {% endif %}
          <div class="lx-testi__author">
            <div class="lx-testi__avatar" aria-hidden="true">
              {{ block.settings.name | slice: 0, 1 | upcase }}
            </div>
            <div class="lx-testi__info">
              <div class="lx-testi__name">{{ block.settings.name }}</div>
              <div class="lx-testi__label">
                {% if block.settings.detail != blank %}{{ block.settings.detail }}{% else %}Verified Customer{% endif %}
              </div>
            </div>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings":[
    {"type":"text","id":"badge","label":"Badge","default":"Customer Stories"},
    {"type":"textarea","id":"heading","label":"Heading","default":"Real people.\nReal results."}
  ],
  "blocks":[{
    "type":"review","name":"Review",
    "settings":[
      {"type":"textarea","id":"quote","label":"Quote"},
      {"type":"text","id":"name","label":"Name"},
      {"type":"text","id":"detail","label":"Detail"}
    ]
  }],
  "presets":[{
    "name":"Testimonials",
    "blocks":[
      {"type":"review","settings":{"quote":"My partner and I tried for over 2 years. After Proxeed Plus — we're now proud parents of baby Mia.","name":"Nick, 41","detail":"Verified Customer"}},
      {"type":"review","settings":{"quote":"If you've been trying and can't conceive, get checked out and take action. We now have our perfect child.","name":"James","detail":"Verified Customer"}},
      {"type":"review","settings":{"quote":"After taking Proxeed Women, six months later I was pregnant. Now I have a beautiful baby girl.","name":"Hannah, 35","detail":"Verified Customer"}},
      {"type":"review","settings":{"quote":"I started Proxeed Women at 38. Seven months later I was pregnant — we now have a healthy baby girl.","name":"Jo, 39","detail":"Verified Customer"}}
    ]
  }]
}
{% endschema %}
