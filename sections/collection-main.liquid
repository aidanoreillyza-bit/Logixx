<section class="lx-coll">
  <div class="lx-container">
    <div class="lx-coll__head lx-fade-in">
      {% if section.settings.badge != blank %}
      <span class="lx-badge lx-badge--mint">{{ section.settings.badge }}</span>
      {% endif %}
      <h1>{{ collection.title }}</h1>
      {% if collection.description != blank %}
      <p>{{ collection.description }}</p>
      {% endif %}
    </div>

    {% if collection.products.size > 0 %}
    <div class="lx-coll__grid">
      {% for product in collection.products limit: 24 %}
      <article class="lx-pcard lx-fade-in">
        <a href="{{ product.url }}" class="lx-pcard__img-link" aria-label="{{ product.title }}">
          <div class="lx-pcard__img">
            {% if product.featured_image != blank %}
            <img
              src="{{ product.featured_image | img_url: '600x' }}"
              alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
              loading="lazy"
              width="600"
              height="450"
            >
            {% else %}
            <svg class="lx-pcard__img-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            {% endif %}
            {% if product.compare_at_price > product.price %}
            <span class="lx-pcard__sale" aria-label="Sale">SALE</span>
            {% endif %}
          </div>
        </a>
        <div class="lx-pcard__body">
          {% if product.type != blank %}
          <div class="lx-pcard__cat">{{ product.type }}</div>
          {% endif %}
          <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
          {% if product.description != blank %}
          <p class="lx-pcard__desc">{{ product.description | strip_html | truncate: 100 }}</p>
          {% endif %}
          <div class="lx-pcard__price-row">
            <span class="lx-pcard__price">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
            <span class="lx-pcard__compare">{{ product.compare_at_price | money }}</span>
            {% assign saving = product.compare_at_price | minus: product.price %}
            <span class="lx-pcard__save">Save {{ saving | money }}</span>
            {% endif %}
          </div>
          <div class="lx-pcard__add-form">
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="lx-pcard__add-btn" {% unless product.available %}disabled{% endunless %}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
                {% if product.available %}Add to Basket{% else %}Sold Out{% endif %}
              </button>
            </form>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    {% else %}
    <div class="lx-coll__empty" role="status">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
      <h2>No products found</h2>
      <p>This collection is currently empty. Check back soon!</p>
      <a href="/collections/all" class="lx-btn lx-btn--mint">Browse All Products</a>
    </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings":[
    {"type":"text","id":"badge","label":"Badge","default":"Browse"}
  ],
  "presets":[{"name":"Collection"}]
}
{% endschema %}
