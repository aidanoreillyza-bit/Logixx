{% assign sort_by = collection.sort_by | default: collection.default_sort_by %}

<!-- ── Collection hero ──────────────────────────────────────── -->
<div class="lx-coll-hero">
  <div class="lx-container">
    <h1>{{ collection.title | default: 'Shop All Products' }}</h1>
    <p class="lx-coll-hero__desc">{{ collection.description | default: 'Clinically proven fertility supplements and diagnostics' | strip_html }}</p>
    <div class="lx-coll-hero__pills">
      <span class="lx-coll-hero__pill">Free UK Delivery £50+</span>
      <span class="lx-coll-hero__pill">Clinically Proven</span>
      <span class="lx-coll-hero__pill">Halal Certified</span>
    </div>
  </div>
</div>

<!-- ── Filter bar ───────────────────────────────────────────── -->
<div class="lx-coll-bar">
  <div class="lx-coll-bar__filters" role="group" aria-label="Filter products">
    <button type="button" class="lx-coll-bar__filter is-active" data-filter="all">All Products</button>
    <button type="button" class="lx-coll-bar__filter" data-filter="male">For Him</button>
    <button type="button" class="lx-coll-bar__filter" data-filter="female">For Her</button>
    <button type="button" class="lx-coll-bar__filter" data-filter="diagnostics">Diagnostics</button>
  </div>
  <span class="lx-coll-bar__count">{{ collection.products_count }} products</span>
</div>

<!-- ── Product grid ─────────────────────────────────────────── -->
<div class="lx-coll">
  <div class="lx-container">

    {% if collection.products.size > 0 %}
    <div id="lx-pcard-grid" class="lx-coll__grid">

      {% for product in collection.products limit: 24 %}
      {% assign cat_tags = product.tags | join: ',' | downcase %}
      {% assign cat_type = product.type | downcase | strip %}
      {% assign cat_key = 'other' %}
      {% if cat_type contains 'diagnostic' or cat_tags contains 'diagnostic' %}
        {% assign cat_key = 'diagnostics' %}
      {% elsif cat_type contains 'female' or cat_tags contains 'female' or cat_tags contains 'women' %}
        {% assign cat_key = 'female' %}
      {% elsif cat_type contains 'male' or cat_tags contains 'male' or cat_tags contains 'men' %}
        {% assign cat_key = 'male' %}
      {% endif %}

      <div class="lx-coll-card" data-category="{{ cat_key }}">

        <div class="lx-coll-card__img">
          {% if product.featured_image != blank %}
          <img
            src="{{ product.featured_image | img_url: '600x' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            loading="lazy"
            width="600"
            height="450"
          >
          {% else %}
          <svg class="lx-coll-card__img-placeholder" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          {% endif %}
          {% if product.compare_at_price > product.price %}
          <span class="lx-coll-card__badge-sale">SALE</span>
          {% endif %}
          {% if product.tags contains 'bestseller' %}
          <span class="lx-coll-card__badge-best">Best Seller</span>
          {% endif %}
          <button type="button" class="lx-qv-btn"
            data-title="{{ product.title | escape }}"
            data-type="{{ product.type | escape }}"
            data-price="{{ product.price | money }}"
            data-compare="{{ product.compare_at_price | money }}"
            data-has-compare="{% if product.compare_at_price > product.price %}1{% else %}0{% endif %}"
            data-available="{% if product.available %}1{% else %}0{% endif %}"
            data-desc="{{ product.description | strip_html | truncate: 300 | escape }}"
            data-img="{% if product.featured_image != blank %}{{ product.featured_image | img_url: '600x' }}{% endif %}"
            data-img-alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            data-url="{{ product.url }}"
            data-variant="{{ product.selected_or_first_available_variant.id }}"
            data-tags="{{ product.tags | join: ',' | downcase | escape }}">
            Quick View
          </button>
        </div>

        <div class="lx-coll-card__body">
          {% if product.type != blank %}
          <div class="lx-coll-card__cat">{{ product.type }}</div>
          {% endif %}
          <a href="{{ product.url }}" class="lx-coll-card__title">{{ product.title }}</a>
          <div class="lx-coll-card__stars" aria-label="5 out of 5 stars">
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
            <span>(5.0)</span>
          </div>
          {% if product.description != blank %}
          <p class="lx-coll-card__desc">{{ product.description | strip_html | truncate: 100 }}</p>
          {% endif %}
          {% if product.available %}
          <div class="lx-qv-stock lx-qv-stock--in">
            <span class="lx-qv-stock__dot"></span>
            <span>In Stock</span>
          </div>
          {% else %}
          <div class="lx-qv-stock lx-qv-stock--out">
            <span class="lx-qv-stock__dot"></span>
            <span>Out of Stock</span>
          </div>
          {% endif %}
          <div class="lx-coll-card__price-row">
            <span class="lx-coll-card__price">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
            <span class="lx-coll-card__compare">{{ product.compare_at_price | money }}</span>
            {% assign saving = product.compare_at_price | minus: product.price %}
            <span class="lx-coll-card__save">Save {{ saving | money }}</span>
            {% endif %}
          </div>
          <div class="lx-coll-card__actions">
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="lx-coll-card__add" {% unless product.available %}disabled{% endunless %}>
                {% if product.available %}Add to Basket{% else %}Sold Out{% endif %}
              </button>
            </form>
            <a href="{{ product.url }}" class="lx-coll-card__view">View Details</a>
          </div>
        </div>

      </div>

      {% if forloop.index == 2 %}
      </div>

      <div class="lx-bundle">
        <div>
          <div class="lx-bundle__label">Bundle &amp; Save</div>
          <h2>Boost your results — try a complete bundle</h2>
          <p>Combine supplements and diagnostics for up to <strong class="lx-bundle__hl">20% off</strong> your order.</p>
        </div>
        <a href="/collections/bundles" class="lx-bundle__btn">
          Shop Bundles
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="lx-coll__grid">
      {% endif %}

      {% endfor %}

    </div>

    <div id="lx-pcard-empty" class="lx-coll__empty" hidden>
      <div class="lx-coll__empty-icon">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </div>
      <h2>No products found</h2>
      <p>Try a different filter to see more products.</p>
      <button type="button" class="lx-btn lx-btn--mint" onclick="document.querySelector('.lx-coll-bar__filter[data-filter=all]').click();">Show All Products</button>
    </div>

    {% else %}
    <div class="lx-coll__empty">
      <div class="lx-coll__empty-icon">
        <svg viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </div>
      <h2>No products found</h2>
      <p>Products coming soon.</p>
      <a href="/" class="lx-btn lx-btn--mint">Go Home</a>
    </div>
    {% endif %}

  </div>
</div>

<!-- ── Quick View modal ─────────────────────────────────────── -->
<div id="lx-qv-overlay" class="lx-qv-overlay" role="dialog" aria-modal="true" aria-labelledby="lx-qv-title">
  <div id="lx-qv-modal" class="lx-qv-modal">
    <div id="lx-qv-img-wrap" class="lx-qv-img">
      <img id="lx-qv-img" src="" alt="" hidden>
      <svg id="lx-qv-img-placeholder" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-mint)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
    </div>
    <div class="lx-qv-body">
      <button id="lx-qv-close" type="button" class="lx-qv-close" aria-label="Close quick view">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div id="lx-qv-type" class="lx-qv-type"></div>
      <h2 id="lx-qv-title" class="lx-qv-title"></h2>
      <div class="lx-qv-stars">
        <span class="lx-qv-stars__gold" aria-label="5 out of 5 stars">★★★★★</span>
        <span class="lx-qv-stars__label">(5.0)</span>
      </div>
      <p id="lx-qv-desc" class="lx-qv-desc"></p>
      <div id="lx-qv-stock" class="lx-qv-stock"></div>
      <div class="lx-qv-price-row">
        <span id="lx-qv-price" class="lx-qv-price"></span>
        <span id="lx-qv-compare" class="lx-qv-compare" hidden></span>
      </div>
      <form id="lx-qv-form" class="lx-qv-form" action="/cart/add" method="post">
        <input type="hidden" id="lx-qv-variant" name="id" value="">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="lx-qv-add">Add to Basket</button>
        <a id="lx-qv-details" href="#" class="lx-qv-details">View Details</a>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  var filterBtns = document.querySelectorAll('.lx-coll-bar__filter');
  var cards = document.querySelectorAll('.lx-coll-card');
  var emptyState = document.getElementById('lx-pcard-empty');

  function applyFilter(filter) {
    var visible = 0;
    cards.forEach(function (card) {
      var cat = (card.dataset.category || '').toLowerCase();
      var show = filter === 'all' || cat === filter;
      card.hidden = !show;
      if (show) visible++;
    });
    if (emptyState) emptyState.hidden = visible > 0;
  }

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      filterBtns.forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      applyFilter(btn.dataset.filter || 'all');
    });
  });
})();
</script>

<script>
(function () {
  var overlay  = document.getElementById('lx-qv-overlay');
  var closeBtn = document.getElementById('lx-qv-close');
  var imgEl    = document.getElementById('lx-qv-img');
  var imgPH    = document.getElementById('lx-qv-img-placeholder');

  function openModal(btn) {
    var d = btn.dataset;
    document.getElementById('lx-qv-type').textContent  = d.type || '';
    document.getElementById('lx-qv-title').textContent = d.title || '';
    document.getElementById('lx-qv-desc').textContent  = d.desc || '';
    document.getElementById('lx-qv-price').textContent = d.price || '';
    document.getElementById('lx-qv-variant').value     = d.variant || '';
    document.getElementById('lx-qv-details').href      = d.url || '#';

    var compare = document.getElementById('lx-qv-compare');
    if (d.hasCompare === '1') {
      compare.textContent = d.compare;
      compare.hidden = false;
    } else {
      compare.hidden = true;
    }

    var stock = document.getElementById('lx-qv-stock');
    if (d.available === '1') {
      stock.className = 'lx-qv-stock lx-qv-stock--in';
      stock.innerHTML = '<span class="lx-qv-stock__dot"></span><span>In Stock</span>';
    } else {
      stock.className = 'lx-qv-stock lx-qv-stock--out';
      stock.innerHTML = '<span class="lx-qv-stock__dot"></span><span>Out of Stock</span>';
    }

    if (d.img) {
      imgEl.src = d.img;
      imgEl.alt = d.imgAlt || '';
      imgEl.hidden = false;
      imgPH.hidden = true;
    } else {
      imgEl.hidden = true;
      imgPH.hidden = false;
    }

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.lx-qv-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openModal(btn);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "Collection Page",
  "settings": []
}
{% endschema %}
