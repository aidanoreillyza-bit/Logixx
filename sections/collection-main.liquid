{% assign sort_by = collection.sort_by | default: collection.default_sort_by %}

<style>
  .lx-qv-btn {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    opacity: 0;
    transition: opacity .25s, transform .25s;
    white-space: nowrap;
    pointer-events: none;
  }
  .lx-pcard:hover .lx-qv-btn {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
  #lx-qv-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(8,20,40,.72);
    z-index: 9000;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  #lx-qv-overlay.is-open {
    display: flex;
  }
  #lx-qv-modal {
    background: #fff;
    border-radius: 20px;
    max-width: 820px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    position: relative;
    box-shadow: 0 32px 80px rgba(8,20,40,.3);
  }
  @media (max-width: 600px) {
    #lx-qv-modal { grid-template-columns: 1fr; }
  }
</style>

<!-- ── Hero banner ───────────────────────────────────────────── -->
<div style="background:linear-gradient(135deg,#081428 0%,#0f2a4a 100%);padding:60px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;text-align:center;">
    <h1 style="font-family:'Instrument Serif',serif;font-size:3rem;color:#fff;margin:0 0 12px;">Shop All Products</h1>
    <p style="color:rgba(255,255,255,.65);font-size:1rem;margin:0 0 28px;">Clinically proven fertility supplements and diagnostics</p>
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:12px;">
      <span style="border:1px solid rgba(0,184,212,.3);background:rgba(0,184,212,.1);color:#00B8D4;padding:6px 16px;border-radius:100px;font-size:13px;">Free UK Delivery £50+</span>
      <span style="border:1px solid rgba(0,184,212,.3);background:rgba(0,184,212,.1);color:#00B8D4;padding:6px 16px;border-radius:100px;font-size:13px;">Clinically Proven</span>
      <span style="border:1px solid rgba(0,184,212,.3);background:rgba(0,184,212,.1);color:#00B8D4;padding:6px 16px;border-radius:100px;font-size:13px;">Halal Certified</span>
    </div>
  </div>
</div>

<!-- ── Filter bar ────────────────────────────────────────────── -->
<div style="background:#fff;border-bottom:1px solid #e5e8ee;padding:16px 28px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
  <div id="lx-filter-bar" style="display:flex;flex-wrap:wrap;gap:8px;" role="group" aria-label="Filter products">
    <button type="button" class="lx-pf-btn lx-pf-btn--active" data-filter="all"
      style="padding:8px 18px;border-radius:100px;border:1.5px solid #00B8D4;background:#00B8D4;color:#fff;font-size:13px;font-weight:600;cursor:pointer;">
      All Products
    </button>
    <button type="button" class="lx-pf-btn" data-filter="male"
      style="padding:8px 18px;border-radius:100px;border:1.5px solid #e5e8ee;background:#fff;color:#0f1f3a;font-size:13px;font-weight:600;cursor:pointer;">
      For Him
    </button>
    <button type="button" class="lx-pf-btn" data-filter="female"
      style="padding:8px 18px;border-radius:100px;border:1.5px solid #e5e8ee;background:#fff;color:#0f1f3a;font-size:13px;font-weight:600;cursor:pointer;">
      For Her
    </button>
    <button type="button" class="lx-pf-btn" data-filter="diagnostics"
      style="padding:8px 18px;border-radius:100px;border:1.5px solid #e5e8ee;background:#fff;color:#0f1f3a;font-size:13px;font-weight:600;cursor:pointer;">
      Diagnostics
    </button>
  </div>
  <span style="font-size:13px;color:#6b7485;white-space:nowrap;">{{ collection.products_count }} products</span>
</div>

<!-- ── Product grid ──────────────────────────────────────────── -->
<div style="background:#fafbfc;padding:48px 0;">
  <div style="max-width:1240px;margin:0 auto;padding:0 28px;">

    {% if collection.products.size > 0 %}
    <div id="lx-pcard-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">

      {% for product in collection.products limit: 24 %}
      {% assign cat_tags = product.tags | join: ',' | downcase %}
      {% assign cat_type = product.type | downcase | strip %}
      {% assign cat_key = 'other' %}
      {% if cat_type contains 'diagnostic' or cat_tags contains 'diagnostic' %}
        {% assign cat_key = 'diagnostics' %}
      {% elsif cat_type contains 'female' or cat_tags contains 'female' or cat_tags contains 'women' %}
        {% assign cat_key = 'female' %}
      {% elsif cat_type contains 'male' or cat_tags contains 'male' or cat_tags contains 'men' %}
        {% assign cat_key = 'male' %}
      {% endif %}

      <div class="lx-pcard" data-category="{{ cat_key }}"
        style="background:#fff;border-radius:20px;border:1.5px solid #e5e8ee;overflow:hidden;transition:transform .3s,box-shadow .3s,border-color .3s;display:flex;flex-direction:column;"
        onmouseenter="this.style.transform='translateY(-8px)';this.style.boxShadow='0 20px 50px rgba(15,31,58,.12)';this.style.borderColor='#00B8D4';"
        onmouseleave="this.style.transform='';this.style.boxShadow='';this.style.borderColor='#e5e8ee';">

        <!-- Image -->
        <div class="lx-pcard__img" style="height:220px;background:linear-gradient(135deg,#ecfdf5,#d1f4e3);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
          {% if product.featured_image != blank %}
          <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | escape | default: product.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
          {% else %}
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#00B8D4" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          {% endif %}
          {% if product.compare_at_price > product.price %}
          <span style="position:absolute;top:12px;right:12px;background:#ff4757;color:#fff;padding:4px 12px;border-radius:100px;font-size:11px;font-weight:700;">SALE</span>
          {% endif %}
          {% if product.tags contains 'bestseller' %}
          <span style="position:absolute;top:12px;left:12px;background:rgba(0,184,212,.1);color:#00B8D4;border:1px solid rgba(0,184,212,.3);padding:4px 12px;border-radius:100px;font-size:11px;font-weight:700;">Best Seller</span>
          {% endif %}
          <!-- Quick View button -->
          <button type="button" class="lx-qv-btn"
            data-title="{{ product.title | escape }}"
            data-type="{{ product.type | escape }}"
            data-price="{{ product.price | money }}"
            data-compare="{{ product.compare_at_price | money }}"
            data-has-compare="{% if product.compare_at_price > product.price %}1{% else %}0{% endif %}"
            data-available="{% if product.available %}1{% else %}0{% endif %}"
            data-desc="{{ product.description | strip_html | truncate: 300 | escape }}"
            data-img="{% if product.featured_image != blank %}{{ product.featured_image | img_url: '600x' }}{% endif %}"
            data-img-alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            data-url="{{ product.url }}"
            data-variant="{{ product.selected_or_first_available_variant.id }}"
            data-tags="{{ product.tags | join: ',' | downcase | escape }}"
            style="background:#fff;color:#0f1f3a;border:none;border-radius:10px;padding:10px 20px;font-weight:700;font-size:13px;cursor:pointer;box-shadow:0 4px 16px rgba(8,20,40,.18);">
            Quick View
          </button>
        </div>

        <!-- Body -->
        <div class="lx-pcard__body" style="padding:18px 20px 0;flex:1;">
          <div style="font-size:11px;font-weight:700;color:#00B8D4;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">{{ product.type }}</div>
          <h3 style="font-family:'Inter',sans-serif;font-size:18px;font-weight:700;color:#0f1f3a;margin-bottom:6px;letter-spacing:-.01em;">{{ product.title }}</h3>
          <!-- Star rating -->
          <div style="display:flex;align-items:center;gap:4px;margin-bottom:8px;">
            <span style="color:#f5a623;font-size:14px;letter-spacing:1px;" aria-label="5 out of 5 stars">★★★★★</span>
            <span style="font-size:12px;color:#6b7485;">(5.0)</span>
          </div>
          <p style="font-size:13px;color:#6b7485;line-height:1.6;margin-bottom:0;">{{ product.description | strip_html | truncate: 100 }}</p>
        </div>

        <!-- Footer -->
        <div class="lx-pcard__foot" style="padding:16px 20px 20px;">
          <!-- Stock indicator -->
          {% if product.available %}
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;">
            <span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;flex-shrink:0;"></span>
            <span style="font-size:12px;font-weight:600;color:#22c55e;">In Stock</span>
          </div>
          {% else %}
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;">
            <span style="width:8px;height:8px;border-radius:50%;background:#9ca3af;display:inline-block;flex-shrink:0;"></span>
            <span style="font-size:12px;font-weight:600;color:#9ca3af;">Out of Stock</span>
          </div>
          {% endif %}
          <div style="display:flex;align-items:baseline;gap:10px;margin-bottom:14px;">
            <span style="font-size:24px;font-weight:800;color:#0f1f3a;">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
            <span style="font-size:14px;color:#6b7485;text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <form action="/cart/add" method="post">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" style="width:100%;padding:11px;background:#00B8D4;color:#fff;border:none;border-radius:10px;font-weight:700;font-size:13px;cursor:pointer;">Add to Basket</button>
            </form>
            <a href="{{ product.url }}" style="display:flex;align-items:center;justify-content:center;padding:11px;background:#fff;color:#0f1f3a;border:1.5px solid #e5e8ee;border-radius:10px;font-weight:600;font-size:13px;text-decoration:none;">View Details</a>
          </div>
        </div>

      </div>

      {% if forloop.index == 2 %}
      </div><!-- /lx-pcard-grid row 1 -->

      <!-- ── Bundle suggestion banner ────────────────────────── -->
      <div style="background:linear-gradient(135deg,#081428 0%,#0f2a4a 100%);border-radius:20px;padding:36px 40px;margin:24px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px;">
        <div>
          <div style="font-size:11px;font-weight:700;color:#00B8D4;text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">Bundle &amp; Save</div>
          <h2 style="font-family:'Instrument Serif',serif;font-size:1.75rem;color:#fff;margin:0 0 8px;">Boost your results — try a complete bundle</h2>
          <p style="font-size:14px;color:rgba(255,255,255,.65);margin:0;">Combine supplements and diagnostics for up to <strong style="color:#00B8D4;">20% off</strong> your order.</p>
        </div>
        <a href="/collections/bundles" style="display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#00B8D4;color:#fff;border-radius:12px;font-weight:700;font-size:14px;text-decoration:none;white-space:nowrap;flex-shrink:0;">
          Shop Bundles
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:0">
      {% endif %}

      {% endfor %}

    </div>

    <!-- Empty state shown by JS when all cards are filtered out -->
    <div id="lx-pcard-empty" hidden style="text-align:center;padding:80px 0;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#00B8D4" stroke-width="1.5" style="margin-bottom:20px;"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <h2 style="font-size:24px;font-weight:700;color:#0f1f3a;margin-bottom:8px;">No products found</h2>
      <p style="color:#6b7485;margin-bottom:20px;">Try a different filter to see more products.</p>
      <button type="button" onclick="document.querySelector('.lx-pf-btn[data-filter=all]').click();" style="padding:12px 28px;background:#00B8D4;color:#fff;border:none;border-radius:10px;font-weight:700;font-size:14px;cursor:pointer;">Show All Products</button>
    </div>

    {% else %}
    <!-- Collection is empty in Shopify -->
    <div style="text-align:center;padding:80px 0;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#00B8D4" stroke-width="1.5" style="margin-bottom:20px;"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <h2 style="font-size:24px;font-weight:700;color:#0f1f3a;margin-bottom:8px;">No products found</h2>
      <p style="color:#6b7485;margin-bottom:20px;">Products coming soon.</p>
      <a href="/" style="display:inline-block;padding:12px 28px;background:#00B8D4;color:#fff;border-radius:10px;font-weight:700;font-size:14px;text-decoration:none;">Go Home</a>
    </div>
    {% endif %}

  </div>
</div>

<!-- ── Quick View modal ─────────────────────────────────────── -->
<div id="lx-qv-overlay" role="dialog" aria-modal="true" aria-labelledby="lx-qv-title">
  <div id="lx-qv-modal">
    <!-- Image panel -->
    <div id="lx-qv-img-wrap" style="background:linear-gradient(135deg,#ecfdf5,#d1f4e3);border-radius:20px 0 0 20px;display:flex;align-items:center;justify-content:center;min-height:340px;overflow:hidden;position:relative;">
      <img id="lx-qv-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
      <svg id="lx-qv-img-placeholder" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#00B8D4" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
    </div>
    <!-- Content panel -->
    <div style="padding:36px 32px;display:flex;flex-direction:column;gap:12px;position:relative;">
      <button id="lx-qv-close" type="button" aria-label="Close quick view"
        style="position:absolute;top:16px;right:16px;background:none;border:none;cursor:pointer;color:#6b7485;line-height:1;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div id="lx-qv-type" style="font-size:11px;font-weight:700;color:#00B8D4;text-transform:uppercase;letter-spacing:.08em;"></div>
      <h2 id="lx-qv-title" style="font-family:'Inter',sans-serif;font-size:22px;font-weight:700;color:#0f1f3a;margin:0;letter-spacing:-.01em;"></h2>
      <div style="display:flex;align-items:center;gap:4px;">
        <span style="color:#f5a623;font-size:14px;letter-spacing:1px;" aria-label="5 out of 5 stars">★★★★★</span>
        <span style="font-size:12px;color:#6b7485;">(5.0)</span>
      </div>
      <p id="lx-qv-desc" style="font-size:13px;color:#6b7485;line-height:1.7;margin:0;"></p>
      <div id="lx-qv-stock" style="display:flex;align-items:center;gap:6px;"></div>
      <div style="display:flex;align-items:baseline;gap:10px;">
        <span id="lx-qv-price" style="font-size:26px;font-weight:800;color:#0f1f3a;"></span>
        <span id="lx-qv-compare" style="font-size:14px;color:#6b7485;text-decoration:line-through;display:none;"></span>
      </div>
      <form id="lx-qv-form" action="/cart/add" method="post" style="display:flex;gap:8px;margin-top:4px;">
        <input type="hidden" id="lx-qv-variant" name="id" value="">
        <button type="submit" style="flex:1;padding:13px;background:#00B8D4;color:#fff;border:none;border-radius:10px;font-weight:700;font-size:14px;cursor:pointer;">Add to Basket</button>
        <a id="lx-qv-details" href="#" style="display:flex;align-items:center;justify-content:center;padding:13px 18px;background:#fff;color:#0f1f3a;border:1.5px solid #e5e8ee;border-radius:10px;font-weight:600;font-size:13px;text-decoration:none;white-space:nowrap;">View Details</a>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  var filterBtns = document.querySelectorAll('.lx-pf-btn');
  var cards = document.querySelectorAll('.lx-pcard');
  var emptyState = document.getElementById('lx-pcard-empty');

  function applyFilter(filter) {
    var visible = 0;
    cards.forEach(function (card) {
      var cat = (card.dataset.category || '').toLowerCase();
      var show = filter === 'all' || cat === filter;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyState) emptyState.hidden = visible > 0;
  }

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      filterBtns.forEach(function (b) {
        b.style.background = '#fff';
        b.style.color = '#0f1f3a';
        b.style.borderColor = '#e5e8ee';
      });
      btn.style.background = '#00B8D4';
      btn.style.color = '#fff';
      btn.style.borderColor = '#00B8D4';
      applyFilter(btn.dataset.filter || 'all');
    });
  });
})();
</script>

<script>
(function () {
  var overlay  = document.getElementById('lx-qv-overlay');
  var modal    = document.getElementById('lx-qv-modal');
  var closeBtn = document.getElementById('lx-qv-close');
  var imgEl    = document.getElementById('lx-qv-img');
  var imgPH    = document.getElementById('lx-qv-img-placeholder');

  function openModal(btn) {
    var d = btn.dataset;
    document.getElementById('lx-qv-type').textContent  = d.type || '';
    document.getElementById('lx-qv-title').textContent = d.title || '';
    document.getElementById('lx-qv-desc').textContent  = d.desc || '';
    document.getElementById('lx-qv-price').textContent = d.price || '';
    document.getElementById('lx-qv-variant').value     = d.variant || '';
    document.getElementById('lx-qv-details').href      = d.url || '#';

    var compare = document.getElementById('lx-qv-compare');
    if (d.hasCompare === '1') {
      compare.textContent = d.compare;
      compare.style.display = '';
    } else {
      compare.style.display = 'none';
    }

    var stock = document.getElementById('lx-qv-stock');
    if (d.available === '1') {
      stock.innerHTML = '<span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;flex-shrink:0;"></span><span style="font-size:12px;font-weight:600;color:#22c55e;">In Stock</span>';
    } else {
      stock.innerHTML = '<span style="width:8px;height:8px;border-radius:50%;background:#9ca3af;display:inline-block;flex-shrink:0;"></span><span style="font-size:12px;font-weight:600;color:#9ca3af;">Out of Stock</span>';
    }

    if (d.img) {
      imgEl.src = d.img;
      imgEl.alt = d.imgAlt || '';
      imgEl.style.display = '';
      imgPH.style.display = 'none';
    } else {
      imgEl.style.display = 'none';
      imgPH.style.display = '';
    }

    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.lx-qv-btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      openModal(btn);
    });
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>

{% schema %}
{
  "name": "Collection Page",
  "settings": []
}
{% endschema %}
