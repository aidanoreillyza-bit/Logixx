<header class="lx-hdr" role="banner">
  <div class="lx-container">
    <div class="lx-hdr__inner">

      <!-- Logo -->
      <a href="/" class="lx-hdr__logo" aria-label="LogixX Fertility – Home">
        <div class="lx-logo-text">
          <span class="lx-logo-name">
            <span class="lx-logo-name__logixx">LogixX</span>
            <span class="lx-logo-name__fertility">Fertility</span>
          </span>
          <span class="lx-logo-tagline">{{ section.settings.tagline }}</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="lx-hdr__nav" aria-label="Main navigation">
        <ul role="list">
          <li><a href="/">Home</a></li>

          <!-- Shop dropdown -->
          <li class="lx-hdr__drop">
            <a href="/collections/all">
              Shop
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/></svg>
            </a>
            <div class="lx-hdr__drop-panel" role="region" aria-label="Shop submenu">
              <a href="/products/proxeed-plus" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--mint" aria-hidden="true">🌿</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">Proxeed Plus</span>
                  <span class="lx-drop-item__sub">Complete fertility support</span>
                </div>
              </a>
              <a href="/products/proxeed-men" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--blue" aria-hidden="true">💊</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">Proxeed Men</span>
                  <span class="lx-drop-item__sub">Male fertility formula</span>
                </div>
              </a>
              <a href="/products/proxeed-women" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--gold" aria-hidden="true">✨</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">Proxeed Women</span>
                  <span class="lx-drop-item__sub">Female fertility support</span>
                </div>
              </a>
              <a href="/products/lenshooke-x1-pro" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--navy" aria-hidden="true">🔬</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">LensHooke X1 PRO</span>
                  <span class="lx-drop-item__sub">Home sperm analysis device</span>
                </div>
              </a>
            </div>
          </li>

          <!-- Male Fertility dropdown -->
          <li class="lx-hdr__drop">
            <a href="/collections/male-fertility">
              Male Fertility
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/></svg>
            </a>
            <div class="lx-hdr__drop-panel" role="region" aria-label="Male Fertility submenu">
              <a href="/products/proxeed-plus" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--mint" aria-hidden="true">🌿</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">Proxeed Plus</span>
                  <span class="lx-drop-item__sub">Sperm quality support</span>
                </div>
              </a>
              <a href="/products/proxeed-men" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--blue" aria-hidden="true">💊</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">Proxeed Men</span>
                  <span class="lx-drop-item__sub">Clinically proven formula</span>
                </div>
              </a>
              <a href="/products/lenshooke-x1-pro" class="lx-drop-item">
                <div class="lx-drop-item__icon lx-drop-item__icon--navy" aria-hidden="true">🔬</div>
                <div class="lx-drop-item__body">
                  <span class="lx-drop-item__title">LensHooke X1 PRO</span>
                  <span class="lx-drop-item__sub">At-home sperm testing</span>
                </div>
              </a>
            </div>
          </li>

          <li><a href="/collections/female-fertility">Female Fertility</a></li>
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </nav>

      <!-- Right actions -->
      <div class="lx-hdr__right">
        <button class="lx-hdr__icon-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1 0 6.5 6.5a7.5 7.5 0 0 0 10.15 10.15z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        </button>
        <a href="/cart" class="lx-hdr__icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% if cart.item_count > 0 %}
          <span class="lx-cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
          {% endif %}
        </a>
        <a href="{{ section.settings.cta_url }}" class="lx-btn lx-btn--mint lx-btn--sm" aria-label="{{ section.settings.cta_label }}">
          {{ section.settings.cta_label }}
        </a>
        <button class="lx-hdr__burger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="lx-mobile-drawer">
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Overlay -->
<div class="lx-overlay" id="lx-overlay" aria-hidden="true"></div>

<!-- Mobile Drawer -->
<nav id="lx-mobile-drawer" class="lx-drawer" aria-hidden="true" aria-label="Mobile navigation">
  <div class="lx-drawer__head">
    <div class="lx-drawer__title">Menu</div>
    <button class="lx-drawer__close" aria-label="Close navigation menu">&#x2715;</button>
  </div>
  <div class="lx-drawer__nav">
    <a href="/">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" fill="none"/><polyline points="9,22 9,12 15,12 15,22" stroke="currentColor" stroke-width="2" fill="none"/></svg>
      Home
    </a>
    <a href="/collections/all">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
      Shop All Products
    </a>
    <a href="/collections/male-fertility">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="14" r="5" stroke="currentColor" stroke-width="2" fill="none"/><path d="M19 5l-5.5 5.5M19 5h-5M19 5v5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
      Male Fertility
    </a>
    <a href="/collections/female-fertility">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="2" fill="none"/><path d="M12 13v8M9 18h6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
      Female Fertility
    </a>
    <a href="/pages/about">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/><path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
      About Us
    </a>
    <a href="/pages/contact">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" stroke="currentColor" stroke-width="2" fill="none"/></svg>
      Contact
    </a>
  </div>
  <div class="lx-drawer__footer">
    <a href="{{ section.settings.cta_url }}" class="lx-btn lx-btn--mint" style="justify-content:center;">{{ section.settings.cta_label }}</a>
    <a href="/cart" class="lx-btn lx-btn--ghost" style="justify-content:center;">View Basket ({{ cart.item_count }})</a>
    <div class="lx-drawer__contact">
      <a href="tel:{{ section.settings.phone | default: '+441189011747' | replace: ' ', '' }}">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24 11.36 11.36 0 0 0 3.56.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.01z" fill="currentColor"/></svg>
        +44 (0) 1189 011 747
      </a>
      <a href="mailto:info@logixxpharma.com">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5z" fill="currentColor"/></svg>
        info@logixxpharma.com
      </a>
    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {"type":"text","id":"tagline","label":"Tagline","default":"Trusted Fertility Supplements"},
    {"type":"url","id":"cta_url","label":"CTA URL","default":"/collections/all"},
    {"type":"text","id":"cta_label","label":"CTA label","default":"Shop Now"}
  ],
  "presets":[{"name":"Header"}]
}
{% endschema %}
