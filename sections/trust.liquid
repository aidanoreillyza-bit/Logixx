<section class="trust-section" id="trust" aria-labelledby="trust-heading">
  <div class="container">
    <h2 class="trust-heading" id="trust-heading">{{ section.settings.heading }}</h2>
    <ul class="trust-logos" role="list" aria-label="Certifications and accreditations">
      {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          <li {{ block.shopify_attributes }}>
            {% if block.settings.logo_image != blank %}
              <img
                src="{{ block.settings.logo_image | img_url: '140x60', crop: 'center' }}"
                alt="{{ block.settings.alt_text | escape }}"
                width="140"
                height="60"
                loading="lazy"
              />
            {% else %}
              <img
                src="https://placehold.co/140x60/f5f7fa/6b7485?text={{ block.settings.alt_text | url_encode }}"
                alt="{{ block.settings.alt_text | escape }}"
                width="140"
                height="60"
                loading="lazy"
              />
            {% endif %}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
    <p class="trust-body">{{ section.settings.body_text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Trust & Accreditations",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted, accredited & award-winning" },
    { "type": "textarea", "id": "body_text", "label": "Body text", "default": "LogixX Fertility is fully licensed by the Human Fertilisation & Embryology Authority (HFEA), ISO 9001 quality-certified, and a proud member of the European Society of Human Reproduction and Embryology (ESHRE) and the American Society for Reproductive Medicine (ASRM)." }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Trust logo",
      "settings": [
        { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
        { "type": "text", "id": "alt_text", "label": "Alt text", "default": "Accreditation logo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust & Accreditations",
      "blocks": [
        { "type": "logo", "settings": { "alt_text": "HFEA Licensed" } },
        { "type": "logo", "settings": { "alt_text": "ISO 9001" } },
        { "type": "logo", "settings": { "alt_text": "ESHRE Member" } },
        { "type": "logo", "settings": { "alt_text": "ASRM Member" } },
        { "type": "logo", "settings": { "alt_text": "5-Star Award 2025" } }
      ]
    }
  ]
}
{% endschema %}
