<section class="lx-pdp">
  <div class="lx-container">
    <div class="lx-pdp__grid">

      <!-- Image column (sticky) -->
      <div class="lx-pdp__img-col">
        <div class="lx-pdp__img-area">
          <div class="lx-pdp__img-orb lx-pdp__img-orb--1" aria-hidden="true"></div>
          <div class="lx-pdp__img-orb lx-pdp__img-orb--2" aria-hidden="true"></div>
          {% if product.compare_at_price > product.price %}
          <div class="lx-pdp__sale-badge" aria-label="On sale">SALE</div>
          {% endif %}
          {% if product.featured_image != blank %}
          <img
            src="{{ product.featured_image | img_url: '800x' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="800"
            height="800"
          >
          {% else %}
          <svg width="160" height="160" viewBox="0 0 24 24" fill="none" stroke="rgba(0,212,168,.4)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          {% endif %}
        </div>
      </div>

      <!-- Buy box -->
      <div class="lx-pdp__buy">

        <!-- Breadcrumb -->
        <nav class="lx-pdp__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/collections/all">Shop</a>
          <span aria-hidden="true">›</span>
          <span>{{ product.title }}</span>
        </nav>

        <!-- Category & title -->
        {% if product.type != blank %}
        <div class="lx-pdp__cat">{{ product.type }}</div>
        {% endif %}
        <h1 class="lx-pdp__title">{{ product.title }}</h1>

        <!-- Price -->
        <div class="lx-pdp__price-box">
          <span class="lx-pdp__price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
          <span class="lx-pdp__compare">{{ product.compare_at_price | money }}</span>
          {% assign saving = product.compare_at_price | minus: product.price %}
          <span class="lx-pdp__save">Save {{ saving | money }}</span>
          {% endif %}
        </div>

        <!-- Stock -->
        {% if product.available %}
        <div class="lx-pdp__stock">
          <span class="lx-pdp__stock-dot" aria-hidden="true"></span>
          In Stock — Ready to dispatch
        </div>
        {% else %}
        <div class="lx-pdp__stock" style="color:var(--c-red);">
          <span style="width:8px;height:8px;border-radius:50%;background:var(--c-red);display:inline-block;" aria-hidden="true"></span>
          Currently Out of Stock
        </div>
        {% endif %}

        <!-- Add to basket form -->
        <form action="/cart/add" method="post" class="lx-pdp__add-form">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <label for="lx-pdp-qty" style="font-size:13px;font-weight:600;color:var(--c-navy);display:block;margin-bottom:8px;">Quantity</label>
          <div class="lx-qty" style="margin-bottom:16px;">
            <button type="button" class="lx-qty__btn" data-qty="-" aria-label="Decrease quantity">−</button>
            <input
              type="number"
              id="lx-pdp-qty"
              name="quantity"
              value="1"
              min="1"
              max="99"
              aria-label="Quantity"
            >
            <button type="button" class="lx-qty__btn" data-qty="+" aria-label="Increase quantity">+</button>
          </div>

          <button
            type="submit"
            class="lx-pdp__add-btn"
            {% unless product.available %}disabled{% endunless %}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
            {% if product.available %}Add to Basket{% else %}Sold Out{% endif %}
          </button>
        </form>

        <!-- Trust items -->
        <div class="lx-pdp__trust">
          {% assign trust_items = section.settings.trust_1 | append: '|||' | append: section.settings.trust_2 | append: '|||' | append: section.settings.trust_3 | append: '|||' | append: section.settings.trust_4 %}
          {% assign trust_arr = trust_items | split: '|||' %}
          {% for item in trust_arr %}
          {% if item != blank %}
          <div class="lx-pdp__trust-item">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622C17.176 19.29 21 14.591 21 9a12.02 12.02 0 0 0-.382-3.016z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
            {{ item }}
          </div>
          {% endif %}
          {% endfor %}
        </div>

        <!-- Description -->
        {% if product.description != blank %}
        <div class="lx-pdp__desc">
          <h3>Product Description</h3>
          <div class="lx-rte">{{ product.description }}</div>
        </div>
        {% endif %}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "settings":[
    {"type":"text","id":"trust_1","label":"Trust item 1","default":"Free UK Delivery"},
    {"type":"text","id":"trust_2","label":"Trust item 2","default":"Discreet Packaging"},
    {"type":"text","id":"trust_3","label":"Trust item 3","default":"Clinically Proven"},
    {"type":"text","id":"trust_4","label":"Trust item 4","default":"30-Day Returns"}
  ],
  "presets":[{"name":"Product"}]
}
{% endschema %}
