<section class="lx-pdp">
  <div class="lx-container">

    <div class="lx-pdp__grid">

      <!-- Image column (sticky) -->
      <div class="lx-pdp__img-col">
        <div class="lx-pdp__img-area">
          <div class="lx-pdp__img-orb lx-pdp__img-orb--1" aria-hidden="true"></div>
          <div class="lx-pdp__img-orb lx-pdp__img-orb--2" aria-hidden="true"></div>
          {% if product.compare_at_price > product.price %}
          <div class="lx-pdp__sale-badge" aria-label="On sale">SALE</div>
          {% endif %}
          {% if product.featured_image != blank %}
          <img
            src="{{ product.featured_image | img_url: '800x' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
            width="800"
            height="800"
          >
          {% else %}
          <svg width="160" height="160" viewBox="0 0 24 24" fill="none" stroke="rgba(0,212,168,.4)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          {% endif %}
        </div>
      </div>

      <!-- Buy box -->
      <div class="lx-pdp__buy">

        <!-- Breadcrumb -->
        <nav class="lx-pdp__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/collections/all">Shop</a>
          <span aria-hidden="true">›</span>
          <span>{{ product.title }}</span>
        </nav>

        <!-- Category & title -->
        {% if product.type != blank %}
        <div class="lx-pdp__cat">{{ product.type }}</div>
        {% endif %}
        <h1 class="lx-pdp__title">{{ product.title }}</h1>

        <!-- Tagline -->
        {% if section.settings.tagline != blank %}
        <p class="lx-pdp__tagline">{{ section.settings.tagline }}</p>
        {% endif %}

        <!-- Price -->
        <div class="lx-pdp__price-box">
          <span class="lx-pdp__price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
          <span class="lx-pdp__compare">{{ product.compare_at_price | money }}</span>
          {% assign saving = product.compare_at_price | minus: product.price %}
          <span class="lx-pdp__save">Save {{ saving | money }}</span>
          {% endif %}
        </div>

        <!-- Stock -->
        {% if product.available %}
        <div class="lx-pdp__stock">
          <span class="lx-pdp__stock-dot" aria-hidden="true"></span>
          In Stock — Ready to dispatch
        </div>
        {% else %}
        <div class="lx-pdp__stock lx-pdp__stock--out">
          <span class="lx-pdp__stock-dot" aria-hidden="true"></span>
          Currently Out of Stock
        </div>
        {% endif %}

        <!-- Add to basket form -->
        <form action="/cart/add" method="post" class="lx-pdp__add-form">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <label for="lx-pdp-qty" class="lx-pdp__qty-label">Quantity</label>
          <div class="lx-qty">
            <button type="button" class="lx-qty__btn" data-qty="-" aria-label="Decrease quantity">−</button>
            <input
              type="number"
              id="lx-pdp-qty"
              name="quantity"
              value="1"
              min="1"
              max="99"
              aria-label="Quantity"
            >
            <button type="button" class="lx-qty__btn" data-qty="+" aria-label="Increase quantity">+</button>
          </div>

          <button
            type="submit"
            class="lx-pdp__add-btn"
            {% unless product.available %}disabled{% endunless %}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3 6h18M16 10a4 4 0 0 1-8 0"/></svg>
            {% if product.available %}Add to Basket{% else %}Sold Out{% endif %}
          </button>
        </form>

        <!-- Trust items -->
        <div class="lx-pdp__trust">
          {% assign trust_items = section.settings.trust_1 | append: '|||' | append: section.settings.trust_2 | append: '|||' | append: section.settings.trust_3 | append: '|||' | append: section.settings.trust_4 %}
          {% assign trust_arr = trust_items | split: '|||' %}
          {% for item in trust_arr %}
          {% if item != blank %}
          <div class="lx-pdp__trust-item">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622C17.176 19.29 21 14.591 21 9a12.02 12.02 0 0 0-.382-3.016z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
            {{ item }}
          </div>
          {% endif %}
          {% endfor %}
        </div>

      </div>
    </div>

    <!-- Product detail tabs -->
    {% assign has_about = false %}
    {% if product.description != blank %}{% assign has_about = true %}{% endif %}
    {% assign first_tab = 'about' %}
    {% if has_about == false and section.settings.ingredients != blank %}{% assign first_tab = 'ingredients' %}{% endif %}

    <div class="lx-pdp-tabs">
      <div class="lx-pdp-tab-nav" role="tablist" aria-label="Product details">
        {% if has_about %}
        <button class="lx-pdp-tab-btn{% if first_tab == 'about' %} active{% endif %}" role="tab" aria-selected="{% if first_tab == 'about' %}true{% else %}false{% endif %}" data-tab="about">About</button>
        {% endif %}
        {% if section.settings.ingredients != blank %}
        <button class="lx-pdp-tab-btn{% if first_tab == 'ingredients' %} active{% endif %}" role="tab" aria-selected="{% if first_tab == 'ingredients' %}true{% else %}false{% endif %}" data-tab="ingredients">Ingredients</button>
        {% endif %}
        {% if section.settings.how_to_use != blank %}
        <button class="lx-pdp-tab-btn" role="tab" aria-selected="false" data-tab="how-to-use">How to Use</button>
        {% endif %}
        {% if section.settings.clinical_note != blank %}
        <button class="lx-pdp-tab-btn" role="tab" aria-selected="false" data-tab="clinical">Clinical Evidence</button>
        {% endif %}
      </div>

      <div class="lx-pdp-tab-panels">
        {% if has_about %}
        <div class="lx-pdp-tab-panel{% if first_tab == 'about' %} active{% endif %}" role="tabpanel" data-panel="about">
          <div class="lx-rte">{{ product.description }}</div>
        </div>
        {% endif %}
        {% if section.settings.ingredients != blank %}
        <div class="lx-pdp-tab-panel{% if first_tab == 'ingredients' %} active{% endif %}" role="tabpanel" data-panel="ingredients">
          <div class="lx-ing-wrap">
            <div class="lx-ing-header">
              <div class="lx-ing-header__title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
                Nutritional Information
              </div>
              <span class="lx-ing-header__note">Per serving</span>
            </div>
            {% assign ing_rows = section.settings.ingredients | newline_to_br | split: '<br />' %}
            <table class="lx-ing-table">
              <thead>
                <tr>
                  <th>Ingredient</th>
                  <th>Amount</th>
                </tr>
              </thead>
              <tbody>
                {% for row in ing_rows %}
                  {% assign row_clean = row | strip %}
                  {% if row_clean != blank %}
                    {% assign cols = row_clean | split: '|' %}
                    <tr>
                      <td>
                        <span class="lx-ing-dot" aria-hidden="true"></span>
                        {{ cols[0] | strip }}
                      </td>
                      <td>
                        {% if cols[1] != blank %}
                        <span class="lx-ing-badge">{{ cols[1] | strip }}</span>
                        {% endif %}
                      </td>
                    </tr>
                  {% endif %}
                {% endfor %}
              </tbody>
            </table>
            <div class="lx-ing-footer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              Values are per recommended daily serving. Results may vary.
            </div>
          </div>
        </div>
        {% endif %}
        {% if section.settings.how_to_use != blank %}
        <div class="lx-pdp-tab-panel" role="tabpanel" data-panel="how-to-use">
          <div class="lx-rte">{{ section.settings.how_to_use | newline_to_br }}</div>
        </div>
        {% endif %}
        {% if section.settings.clinical_note != blank %}
        <div class="lx-pdp-tab-panel" role="tabpanel" data-panel="clinical">
          <div class="lx-rte">{{ section.settings.clinical_note | newline_to_br }}</div>
        </div>
        {% endif %}
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var btns   = document.querySelectorAll('.lx-pdp-tab-btn');
  var panels = document.querySelectorAll('.lx-pdp-tab-panel');
  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var target = this.dataset.tab;
      btns.forEach(function (b) { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      panels.forEach(function (p) { p.classList.remove('active'); });
      this.classList.add('active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.querySelector('[data-panel="' + target + '"]');
      if (panel) panel.classList.add('active');
    }.bind(btn));
  });
}());
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {"type":"text","id":"tagline","label":"Tagline","default":"Clinically proven fertility support — formulated for results."},
    {"type":"text","id":"trust_1","label":"Trust item 1","default":"Free UK Delivery"},
    {"type":"text","id":"trust_2","label":"Trust item 2","default":"Discreet Packaging"},
    {"type":"text","id":"trust_3","label":"Trust item 3","default":"Clinically Proven"},
    {"type":"text","id":"trust_4","label":"Trust item 4","default":"30-Day Returns"},
    {"type":"textarea","id":"ingredients","label":"Ingredients (one per line: Name | Amount)","default":"L-Carnitine Fumarate | 1000mg\nCoenzyme Q10 | 200mg\nVitamin E (d-alpha tocopherol) | 30mg\nZinc | 15mg\nFolic Acid | 400µg\nSelenium | 55µg\nVitamin B12 | 2.4µg"},
    {"type":"textarea","id":"how_to_use","label":"How to Use","default":"Take 2 sachets daily — one in the morning and one in the evening.\n\nMix each sachet with 200ml of water or juice. Best taken with food.\n\nFor best results, use consistently for a minimum of 90 days."},
    {"type":"textarea","id":"clinical_note","label":"Clinical Evidence","default":"Proxeed has been validated in multiple peer-reviewed clinical trials. Studies demonstrate significant improvements in sperm count, motility, progressive motility and normal morphology after a 90-day supplementation period.\n\nL-Carnitine Fumarate and the antioxidant complex in Proxeed are protected by patents and are not found in generic fertility supplements."}
  ],
  "presets": [{"name": "Product"}]
}
{% endschema %}
