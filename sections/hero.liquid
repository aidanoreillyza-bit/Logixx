<section class="lx-hero" {% if section.settings.image != blank %}style="background-image: url('{{ section.settings.image | img_url: '1600x' }}')"{% endif %}>
  <div class="lx-hero__orb lx-hero__orb--1" aria-hidden="true"></div>
  <div class="lx-hero__orb lx-hero__orb--2" aria-hidden="true"></div>
  <div class="lx-container">
    <div class="lx-hero__content lx-fade-in">
      {% if section.settings.badge != blank %}
      <div class="lx-hero__badge" aria-label="Badge">
        <span class="lx-hero__badge-dot" aria-hidden="true"></span>
        {{ section.settings.badge }}
      </div>
      {% endif %}

      <h1>{{ section.settings.heading | newline_to_br }}</h1>

      {% if section.settings.subtext != blank %}
      <p class="lx-hero__sub">{{ section.settings.subtext }}</p>
      {% endif %}

      <div class="lx-hero__btns">
        {% if section.settings.btn1_label != blank %}
        <a href="{{ section.settings.btn1_url | default: '/collections/all' }}" class="lx-btn lx-btn--mint lx-btn--lg">
          {{ section.settings.btn1_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        {% endif %}
        {% if section.settings.btn2_label != blank %}
        <a href="{{ section.settings.btn2_url | default: '/pages/about' }}" class="lx-btn lx-btn--ghost">
          {{ section.settings.btn2_label }}
        </a>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
      <div class="lx-hero__trust" role="list">
        {% for block in section.blocks %}
          {% if block.type == 'trust' %}
          <div class="lx-hero__trust-item" role="listitem" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type":"image_picker","id":"image","label":"Background image"},
    {"type":"text","id":"badge","label":"Badge text","default":"Trusted UK Fertility Specialists"},
    {"type":"textarea","id":"heading","label":"Heading","default":"The UK's Leading\nFertility Supplement\nExperts"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Clinically proven supplements to support male and female fertility — trusted by thousands of families across the UK."},
    {"type":"text","id":"btn1_label","label":"Primary button","default":"Shop Products"},
    {"type":"url","id":"btn1_url","label":"Primary button URL","default":"/collections/all"},
    {"type":"text","id":"btn2_label","label":"Secondary button","default":"Learn More"},
    {"type":"url","id":"btn2_url","label":"Secondary button URL"}
  ],
  "blocks":[
    {"type":"trust","name":"Trust item","settings":[{"type":"text","id":"text","label":"Text","default":"Free UK Delivery"}]}
  ],
  "presets":[{
    "name":"Hero",
    "blocks":[
      {"type":"trust","settings":{"text":"Free UK Delivery over £50"}},
      {"type":"trust","settings":{"text":"Clinically Proven Formula"}},
      {"type":"trust","settings":{"text":"30-Day Returns"}}
    ]
  }]
}
{% endschema %}
