<style>
/* ══════════════════════════════════════════════════════════
   PAGE-TEAM STYLES
   ══════════════════════════════════════════════════════════ */

/* ── Hero ─────────────────────────────────────────────────── */
.lx-team-hero {
  max-width: 760px;
  margin: 0 auto;
  padding: 80px 24px 56px;
  text-align: center;
}
.lx-team-hero-label {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: #00C2B8;
  background: rgba(0,194,184,.08);
  border: 1px solid rgba(0,194,184,.2);
  border-radius: 50px;
  padding: 5px 14px;
  margin-bottom: 20px;
}
.lx-team-hero h1 {
  font-family: var(--font-head, sans-serif);
  font-size: clamp(2.2rem, 5vw, 3.4rem);
  font-weight: 900;
  color: var(--c-navy, #0a1628);
  line-height: 1.1;
  margin: 0 0 20px;
}
.lx-team-hero h1 em { color: #00C2B8; font-style: italic; }
.lx-team-hero p {
  font-size: 1.05rem;
  color: var(--c-body, #3b4758);
  line-height: 1.75;
  max-width: 580px;
  margin: 0 auto;
}

/* ── Grid ─────────────────────────────────────────────────── */
.lx-team-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28px;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 24px 80px;
}
@media (max-width: 768px) {
  .lx-team-grid { grid-template-columns: 1fr; }
}

/* ── Card ─────────────────────────────────────────────────── */
.lx-tcard {
  background: #fff;
  border-radius: 20px;
  border: 1.5px solid rgba(0,194,184,.12);
  box-shadow: 0 4px 24px rgba(10,22,40,.06);
  overflow: hidden;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
}
.lx-tcard:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(10,22,40,.1);
  border-color: rgba(0,194,184,.28);
}

/* ── Card image area ─────────────────────────────────────── */
.lx-tcard__img {
  position: relative;
  height: 180px;
  background: linear-gradient(135deg, #e8faf9 0%, #d0f5f2 50%, #b8eeea 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.lx-tcard__glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 60%, rgba(0,194,184,.18) 0%, transparent 70%);
  pointer-events: none;
}
.lx-tcard__avatar {
  position: relative;
  width: 88px;
  height: 88px;
  border-radius: 50%;
  background: rgba(255,255,255,.7);
  backdrop-filter: blur(8px);
  border: 2px solid rgba(0,194,184,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(0,194,184,.15);
}
.lx-tcard__bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, #00C2B8 0%, #45bae8 100%);
}

/* ── Card body ───────────────────────────────────────────── */
.lx-tcard__body { padding: 24px 28px 28px; }
.lx-tcard__role {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #00C2B8;
  margin-bottom: 6px;
}
.lx-tcard__name {
  font-family: var(--font-head, sans-serif);
  font-size: 1.35rem;
  font-weight: 900;
  color: var(--c-navy, #0a1628);
  line-height: 1.2;
  margin-bottom: 16px;
}
.lx-tcard__bio p {
  font-size: .9rem;
  color: var(--c-body, #3b4758);
  line-height: 1.7;
  margin: 0 0 10px;
}
.lx-tcard__bio p:last-child { margin-bottom: 0; }

/* ── Positions ───────────────────────────────────────────── */
.lx-tcard__positions {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid rgba(0,194,184,.1);
}
.lx-tcard__positions-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: #00C2B8;
  margin-bottom: 10px;
}
.lx-tcard__position {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 8px;
  font-size: .84rem;
  color: var(--c-body, #3b4758);
  line-height: 1.5;
}
.lx-tcard__position:last-child { margin-bottom: 0; }
.lx-tcard__position-dot {
  flex-shrink: 0;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #00C2B8;
  margin-top: 6px;
}

/* ── Contact links ───────────────────────────────────────── */
.lx-tcard__contact {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid rgba(0,194,184,.1);
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.lx-tcard__contact a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .85rem;
  color: var(--c-navy, #0a1628);
  text-decoration: none;
  transition: color .2s ease;
}
.lx-tcard__contact a:hover { color: #00C2B8; }

/* ── CTA ─────────────────────────────────────────────────── */
.lx-team-cta {
  position: relative;
  background: var(--c-navy, #0a1628);
  text-align: center;
  padding: 88px 24px;
  overflow: hidden;
}
.lx-team-cta-glow {
  position: absolute;
  top: -60px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 300px;
  background: radial-gradient(ellipse, rgba(0,194,184,.18) 0%, transparent 70%);
  pointer-events: none;
}
.lx-team-cta h3 {
  position: relative;
  font-family: var(--font-head, sans-serif);
  font-size: clamp(1.8rem, 3.5vw, 2.6rem);
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
  margin: 0 0 16px;
}
.lx-team-cta h3 em { color: #00C2B8; font-style: italic; }
.lx-team-cta p {
  position: relative;
  font-size: 1rem;
  color: rgba(255,255,255,.72);
  line-height: 1.7;
  max-width: 480px;
  margin: 0 auto 32px;
}
.lx-team-cta a {
  position: relative;
  display: inline-block;
  background: #00C2B8;
  color: #fff;
  font-size: .95rem;
  font-weight: 700;
  text-decoration: none;
  padding: 14px 32px;
  border-radius: 50px;
  transition: background .2s ease, transform .2s ease;
}
.lx-team-cta a:hover {
  background: #00a89f;
  transform: translateY(-2px);
}
</style>

