{% doc %}
  @prompt
    make me other product showcase
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
  }

  .ai-product-showcase__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-product-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-showcase__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-product-showcase__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-showcase__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-product-showcase__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    left: 16px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
  }

  .ai-product-showcase__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-showcase__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-product-showcase__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-product-showcase__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-showcase__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
  }

  .ai-product-showcase__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | times: 0.85 }}px;
    color: {{ block.settings.description_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-product-showcase__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-product-showcase__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-product-showcase__features-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-product-showcase__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ block.settings.description_color }};
  }

  .ai-product-showcase__feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: {{ block.settings.feature_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-showcase__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-product-showcase__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-product-showcase__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-product-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-showcase__container-{{ ai_gen_id }}">
    {% if block.settings.layout == 'image_left' %}
      <div class="ai-product-showcase__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product.featured_image %}
          <img
            src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
            alt="{{ block.settings.product.featured_image.alt | escape }}"
            class="ai-product-showcase__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product.featured_image.width }}"
            height="{{ block.settings.product.featured_image.height }}"
          >
        {% else %}
          <div class="ai-product-showcase__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <div class="ai-product-showcase__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-product-showcase__content-{{ ai_gen_id }}">
      {% if block.settings.product.title %}
        <h2 class="ai-product-showcase__title-{{ ai_gen_id }}">
          {{ block.settings.product.title }}
        </h2>
      {% else %}
        <h2 class="ai-product-showcase__title-{{ ai_gen_id }}">
          {{ block.settings.custom_title }}
        </h2>
      {% endif %}

      {% if block.settings.product.description != blank %}
        <div class="ai-product-showcase__description-{{ ai_gen_id }}">
          {{ block.settings.product.description | strip_html | truncate: 200 }}
        </div>
      {% elsif block.settings.custom_description != blank %}
        <div class="ai-product-showcase__description-{{ ai_gen_id }}">
          {{ block.settings.custom_description }}
        </div>
      {% endif %}

      {% if block.settings.show_features %}
        <div class="ai-product-showcase__features-{{ ai_gen_id }}">
          {% if block.settings.feature_1 != blank %}
            <div class="ai-product-showcase__feature-{{ ai_gen_id }}">
              <svg class="ai-product-showcase__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_1 }}</span>
            </div>
          {% endif %}
          {% if block.settings.feature_2 != blank %}
            <div class="ai-product-showcase__feature-{{ ai_gen_id }}">
              <svg class="ai-product-showcase__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_2 }}</span>
            </div>
          {% endif %}
          {% if block.settings.feature_3 != blank %}
            <div class="ai-product-showcase__feature-{{ ai_gen_id }}">
              <svg class="ai-product-showcase__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_3 }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_price %}
        <div class="ai-product-showcase__price-wrapper-{{ ai_gen_id }}">
          {% if block.settings.product.price %}
            <span class="ai-product-showcase__price-{{ ai_gen_id }}">
              {{ block.settings.product.price | money }}
            </span>
            {% if block.settings.product.compare_at_price > block.settings.product.price %}
              <span class="ai-product-showcase__compare-price-{{ ai_gen_id }}">
                {{ block.settings.product.compare_at_price | money }}
              </span>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_button %}
        {% if block.settings.product.url %}
          <a href="{{ block.settings.product.url }}" class="ai-product-showcase__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% elsif block.settings.button_link %}
          <a href="{{ block.settings.button_link }}" class="ai-product-showcase__button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      {% endif %}
    </div>

    {% if block.settings.layout == 'image_right' %}
      <div class="ai-product-showcase__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product.featured_image %}
          <img
            src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
            alt="{{ block.settings.product.featured_image.alt | escape }}"
            class="ai-product-showcase__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product.featured_image.width }}"
            height="{{ block.settings.product.featured_image.height }}"
          >
        {% else %}
          <div class="ai-product-showcase__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <div class="ai-product-showcase__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Product showcase",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "custom_title",
      "label": "Custom title",
      "default": "Featured product"
    },
    {
      "type": "textarea",
      "id": "custom_description",
      "label": "Custom description"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "image_left",
          "label": "Image left"
        },
        {
          "value": "image_right",
          "label": "Image right"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "New"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show features",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Premium quality materials"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Handcrafted with care"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Perfect for all skill levels"
    },
    {
      "type": "color",
      "id": "feature_icon_color",
      "label": "Feature icon color",
      "default": "#008060"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and content",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Product showcase"
    }
  ]
}
{% endschema %}
