{% doc %}
  @prompt
    i want build table and info about product 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-product-table__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    overflow: hidden;
  }

  .ai-product-table__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-product-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-product-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-product-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-table__row-{{ ai_gen_id }}:nth-child(even) {
    background-color: {{ block.settings.row_alternate_color }};
  }

  .ai-product-table__label-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    font-weight: 600;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    width: {{ block.settings.label_width }}%;
    vertical-align: top;
    text-align: left;
  }

  .ai-product-table__value-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    color: {{ block.settings.value_color }};
    font-size: {{ block.settings.value_size }}px;
    text-align: left;
  }

  .ai-product-table__empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    background-color: #f9f9f9;
    border-radius: {{ block.settings.table_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-product-table__label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }

    .ai-product-table__value-{{ ai_gen_id }} {
      font-size: {{ block.settings.value_size | times: 0.9 }}px;
    }

    .ai-product-table__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<product-info-table-{{ ai_gen_id }} class="ai-product-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-table__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-product-table__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if product %}
      <table class="ai-product-table__table-{{ ai_gen_id }}">
        {% if block.settings.show_title %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.title_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.title }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_vendor and product.vendor != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.vendor_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.vendor }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_type and product.type != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.type_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.type }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_price %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.price_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">
              {% if product.compare_at_price > product.price %}
                <s>{{ product.compare_at_price | money }}</s>
                {{ product.price | money }}
              {% else %}
                {{ product.price | money }}
              {% endif %}
            </td>
          </tr>
        {% endif %}

        {% if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.sku_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.sku }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_barcode and product.selected_or_first_available_variant.barcode != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.barcode_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.barcode }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_availability %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.availability_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">
              {% if product.available %}
                {{ block.settings.in_stock_text }}
              {% else %}
                {{ block.settings.out_of_stock_text }}
              {% endif %}
            </td>
          </tr>
        {% endif %}

        {% if block.settings.show_tags and product.tags.size > 0 %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.tags_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ product.tags | join: ', ' }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_weight and product.selected_or_first_available_variant.weight > 0 %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.weight_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">
              {{ product.selected_or_first_available_variant.weight | weight_with_unit }}
            </td>
          </tr>
        {% endif %}

        {% if block.settings.custom_field_1_label != blank and block.settings.custom_field_1_value != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.custom_field_1_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ block.settings.custom_field_1_value }}</td>
          </tr>
        {% endif %}

        {% if block.settings.custom_field_2_label != blank and block.settings.custom_field_2_value != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.custom_field_2_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ block.settings.custom_field_2_value }}</td>
          </tr>
        {% endif %}

        {% if block.settings.custom_field_3_label != blank and block.settings.custom_field_3_value != blank %}
          <tr class="ai-product-table__row-{{ ai_gen_id }}">
            <td class="ai-product-table__label-{{ ai_gen_id }}">{{ block.settings.custom_field_3_label }}</td>
            <td class="ai-product-table__value-{{ ai_gen_id }}">{{ block.settings.custom_field_3_value }}</td>
          </tr>
        {% endif %}
      </table>
    {% else %}
      <div class="ai-product-table__empty-{{ ai_gen_id }}">
        This block displays product information. Add it to a product template to see the table.
      </div>
    {% endif %}
  </div>
</product-info-table-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductInfoTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('product-info-table-{{ ai_gen_id }}', ProductInfoTable{{ ai_gen_id }});
  })();
</script>

