{% doc %}
  @prompt
    mkae me image show case
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-image-showcase__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-image-showcase__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-showcase__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-image-showcase__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-image-showcase__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-image-showcase__item-{{ ai_gen_id }}:hover .ai-image-showcase__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.hover_zoom }});
  }

  .ai-image-showcase__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-image-showcase__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-image-showcase__caption-{{ ai_gen_id }} {
    padding: {{ block.settings.caption_padding }}px;
    text-align: {{ block.settings.caption_alignment }};
    background-color: {{ block.settings.caption_bg_color }};
  }

  .ai-image-showcase__caption-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.caption_size }}px;
    color: {{ block.settings.caption_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-image-showcase__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-image-showcase__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-image-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-image-showcase__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-image-showcase__grid-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign caption_key = 'caption_' | append: i
        assign image = block.settings[image_key]
        assign caption = block.settings[caption_key]
      %}

      <div class="ai-image-showcase__item-{{ ai_gen_id }}">
        <div class="ai-image-showcase__image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-showcase__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-showcase__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        {% if caption != blank %}
          <div class="ai-image-showcase__caption-{{ ai_gen_id }}">
            <p class="ai-image-showcase__caption-text-{{ ai_gen_id }}">{{ caption }}</p>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

