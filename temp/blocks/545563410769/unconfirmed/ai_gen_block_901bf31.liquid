{% doc %}
  @prompt
    make moving with our Partners 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-partners-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-partners-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-partners-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-partners-track-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-partners-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    width: max-content;
  }

  .ai-partners-track-{{ ai_gen_id }}.moving {
    animation: ai-partners-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-partners-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.logo_background }};
    border-radius: {{ block.settings.logo_border_radius }}px;
    padding: {{ block.settings.logo_padding }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-partners-logo-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  .ai-partners-logo-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale({{ block.settings.logo_grayscale }}%);
    opacity: {{ block.settings.logo_opacity }};
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .ai-partners-logo-{{ ai_gen_id }}:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-partners-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-partners-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-partners-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-partners-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-partners-logo-{{ ai_gen_id }} {
      width: calc({{ block.settings.logo_width }}px * 0.7);
      height: calc({{ block.settings.logo_height }}px * 0.7);
    }
  }
{% endstyle %}

<partners-carousel-{{ ai_gen_id }} class="ai-partners-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-partners-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-partners-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-partners-track-wrapper-{{ ai_gen_id }}">
      <div class="ai-partners-track-{{ ai_gen_id }}" data-speed="{{ block.settings.animation_speed }}">
        {% for i in (1..8) %}
          {% assign logo_key = 'partner_logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          {% if logo != blank %}
            <div class="ai-partners-logo-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="400"
                height="200"
              >
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</partners-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class PartnersCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.logos = [];
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-partners-track-{{ ai_gen_id }}');
        this.logos = Array.from(this.querySelectorAll('.ai-partners-logo-{{ ai_gen_id }}'));
        
        if (this.logos.length > 0) {
          this.duplicateLogos();
          this.startAnimation();
        }
      }

      duplicateLogos() {
        const clone = this.track.cloneNode(true);
        const cloneLogos = clone.querySelectorAll('.ai-partners-logo-{{ ai_gen_id }}');
        cloneLogos.forEach(logo => {
          this.track.appendChild(logo);
        });
      }

      startAnimation() {
        this.track.classList.add('moving');
      }
    }

    customElements.define('partners-carousel-{{ ai_gen_id }}', PartnersCarousel{{ ai_gen_id }});
  })();
</script>

