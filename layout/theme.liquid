<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ page_description | default: 'LogixX Fertility — Helping couples achieve their dream of parenthood with expert care, advanced science, and personalised support.' }}" />
  <title>{{ page_title | default: shop.name }}</title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <div class="cart-toast" id="cart-toast" role="status" aria-live="polite" aria-atomic="true"></div>

  {{ 'script.js' | asset_url | script_tag }}

</body>
</html>
