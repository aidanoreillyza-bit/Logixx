{% doc %}
  @prompt
    Make a Bar with all business partners moving left 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-partner-bar-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
  }

  .ai-partner-bar__wrapper-{{ ai_gen_id }} {
    display: flex;
    width: fit-content;
    animation: ai-partner-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-partner-bar__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    align-items: center;
  }

  .ai-partner-bar__logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-partner-bar__logo-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale({{ block.settings.grayscale_percent }}%);
    opacity: {{ block.settings.logo_opacity }};
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .ai-partner-bar__logo-{{ ai_gen_id }} img:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-partner-bar__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-partner-bar__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @keyframes ai-partner-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-partner-bar__wrapper-{{ ai_gen_id }}:hover {
    animation-play-state: {% if block.settings.pause_on_hover %}paused{% else %}running{% endif %};
  }

  @media screen and (max-width: 749px) {
    .ai-partner-bar__logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<partner-bar-{{ ai_gen_id }} class="ai-partner-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-partner-bar__wrapper-{{ ai_gen_id }}">
    <div class="ai-partner-bar__track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% assign logo_key = 'partner_logo_' | append: i %}
        {% assign logo = block.settings[logo_key] %}
        {% if logo != blank %}
          <div class="ai-partner-bar__logo-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo_width }}"
              height="{{ block.settings.logo_height }}"
            >
          </div>
        {% else %}
          <div class="ai-partner-bar__logo-{{ ai_gen_id }}">
            <div class="ai-partner-bar__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="ai-partner-bar__track-{{ ai_gen_id }}" aria-hidden="true">
      {% for i in (1..8) %}
        {% assign logo_key = 'partner_logo_' | append: i %}
        {% assign logo = block.settings[logo_key] %}
        {% if logo != blank %}
          <div class="ai-partner-bar__logo-{{ ai_gen_id }}">
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.logo_width }}"
              height="{{ block.settings.logo_height }}"
            >
          </div>
        {% else %}
          <div class="ai-partner-bar__logo-{{ ai_gen_id }}">
            <div class="ai-partner-bar__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</partner-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class PartnerBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-partner-bar__wrapper-{{ ai_gen_id }}');
      }
    }

    customElements.define('partner-bar-{{ ai_gen_id }}', PartnerBar{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Partner logo bar",
  "settings": [
    {
      "type": "header",
      "content": "Partner logos"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_1",
      "label": "Partner logo 1"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_2",
      "label": "Partner logo 2"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_3",
      "label": "Partner logo 3"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_4",
      "label": "Partner logo 4"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_5",
      "label": "Partner logo 5"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_6",
      "label": "Partner logo 6"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_7",
      "label": "Partner logo 7"
    },
    {
      "type": "image_picker",
      "id": "partner_logo_8",
      "label": "Partner logo 8"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "logo_spacing",
      "label": "Space between logos",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "grayscale_percent",
      "label": "Grayscale",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "logo_opacity",
      "label": "Logo opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "Partner logo bar"
    }
  ]
}
{% endschema %}
