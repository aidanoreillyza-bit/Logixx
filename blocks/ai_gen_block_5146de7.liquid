{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ── Wrapper ────────────────────────────────────────────── */
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 32px;
    background-color: {{ block.settings.background_color }};
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* Decorative radial blobs */
  .ai-timeline-{{ ai_gen_id }}::before,
  .ai-timeline-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .ai-timeline-{{ ai_gen_id }}::before {
    width: 520px; height: 520px;
    background: radial-gradient(circle, rgba(0,194,184,.07) 0%, transparent 65%);
    top: -180px; left: -180px;
  }
  .ai-timeline-{{ ai_gen_id }}::after {
    width: 380px; height: 380px;
    background: radial-gradient(circle, rgba(51,102,217,.06) 0%, transparent 65%);
    bottom: -140px; right: -140px;
  }

  /* ── Container ──────────────────────────────────────────── */
  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── Track line ─────────────────────────────────────────── */
  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 0;
    bottom: 0;
    width: {{ block.settings.line_width }}px;
    background: linear-gradient(
      180deg,
      rgba(255,255,255,.06) 0%,
      rgba(0,194,184,.18) 50%,
      rgba(255,255,255,.06) 100%
    );
    transform: translateX(-50%);
    border-radius: 2px;
  }

  /* ── Progress fill ──────────────────────────────────────── */
  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0;
    background: linear-gradient(
      180deg,
      {{ block.settings.line_active_color }} 0%,
      {{ block.settings.line_active_color }}bb 100%
    );
    box-shadow: 0 0 10px {{ block.settings.line_active_color }}55;
    transition: height 0.3s ease;
    border-radius: 2px;
  }

  /* ── Timeline item ──────────────────────────────────────── */
  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    padding-left: calc({{ block.settings.line_position }}px + 44px);
    padding-bottom: {{ block.settings.item_spacing }}px;
    opacity: 0.32;
    transform: translateX(-10px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Dot ────────────────────────────────────────────────── */
  .ai-timeline-dot-{{ ai_gen_id }} {
    position: absolute;
    left: {{ block.settings.line_position }}px;
    top: 10px;
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: rgba(255,255,255,.12);
    border: 2px solid rgba(255,255,255,.2);
    transform: translate(-50%, 0) scale(0.82);
    transition: all 0.5s ease;
    z-index: 2;
    backdrop-filter: blur(4px);
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-dot-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.dot_active_color }} 0%, {{ block.settings.dot_active_color }}cc 100%);
    border-color: {{ block.settings.dot_active_color }};
    transform: translate(-50%, 0) scale(1);
    box-shadow:
      0 0 0 {{ block.settings.dot_glow_size }}px {{ block.settings.dot_active_color }}22,
      0 0 18px {{ block.settings.dot_active_color }}44;
  }

  /* ── Glass card ─────────────────────────────────────────── */
  .ai-timeline-content-{{ ai_gen_id }} {
    background: rgba(255,255,255,.04);
    padding: {{ block.settings.card_padding }}px;
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid rgba(255,255,255,.07);
    border-left: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    backdrop-filter: blur(8px);
    transition: background .5s ease, border-color .5s ease, box-shadow .5s ease;
    position: relative;
    overflow: hidden;
  }

  /* Subtle inner sheen */
  .ai-timeline-content-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.03) 0%, transparent 55%);
    pointer-events: none;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-content-{{ ai_gen_id }} {
    background: rgba(0,194,184,.07);
    border-left-color: {{ block.settings.card_border_active_color }};
    border-color: rgba(0,194,184,.2);
    box-shadow:
      0 8px 32px rgba(0,0,0,.28),
      0 0 0 1px rgba(0,194,184,.15);
  }

  /* ── Date ───────────────────────────────────────────────── */
  .ai-timeline-date-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    font-weight: 700;
    letter-spacing: .09em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .ai-timeline-date-{{ ai_gen_id }}::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 2px;
    background: {{ block.settings.date_color }};
    opacity: .7;
    border-radius: 1px;
    flex-shrink: 0;
  }

  /* ── Title ──────────────────────────────────────────────── */
  .ai-timeline-title-{{ ai_gen_id }} {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 800;
    margin: 0 0 10px 0;
    line-height: 1.2;
    letter-spacing: -.01em;
  }

  /* ── Description ────────────────────────────────────────── */
  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.72;
    margin: 0;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media screen and (max-width: 749px) {
    .ai-timeline-{{ ai_gen_id }} {
      width: 100%;
      padding-left: 16px;
      padding-right: 16px;
    }

    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      padding-left: 56px;
    }

    .ai-timeline-dot-{{ ai_gen_id }} {
      left: 20px;
    }
  }
{% endstyle %}

